@model ActPro.Models.SearchViewModel
@{
    ViewData["Title"] = "Търсене";
}
<div class="container-fluid mt-4">
    <div class="row">
        <aside class="col-md-3 mb-4">
            <div class="position-relative">
                <iframe id="miniMap"
                        width="100%"
                        height="150"
                        frameborder="0"
                        style="border:0"
                        src="https://maps.google.com/maps?q=@(Uri.EscapeDataString(Model.City ?? "Bulgaria"))&t=&z=13&ie=UTF8&iwloc=&output=embed">
                </iframe>
                <button type="button" class="btn btn-success btn-sm position-absolute bottom-0 start-50 translate-middle-x mb-2 shadow btn-map-static"
                        data-bs-toggle="modal" data-bs-target="#largeMapModal">
                    <i class="bi bi-arrows-fullscreen me-1"></i> Уголеми картата
                </button>
            </div>
            <div class="card shadow-sm border-success">
                <div class="card-body">
                    <h5 class="card-title text-center mb-3">Филтрирай</h5>

                    <form method="get" asp-controller="Search" asp-action="Index" id="filterForm">
                        <input type="hidden" name="sortOrder" id="currentSortOrder" value="@Context.Request.Query["sortOrder"]" />

                        <label class="form-label fw-bold">Цена (евро/ч)</label>
                        <div class="price-slider-wrapper">
                            <div class="slider-track" id="sliderTrack"></div>
                            <input type="range" name="minPrice" class="form-range custom-range" min="0" max="200" id="minPriceRange" value="@Model.MinPrice">
                            <input type="range" name="maxPrice" class="form-range custom-range" min="0" max="200" id="maxPriceRange" value="@Model.MaxPrice">
                        </div>
                        <div class="d-flex justify-content-between text-muted small mt-2">
                            <div class="d-flex align-items-center">
                                <span>€</span>
                                <input type="number" id="minPriceInput" class="price-input-hidden" value="@Model.MinPrice" min="0" max="200">

                            </div>
                            <div class="d-flex align-items-center">
                                <span>€</span>
                                <input type="number" id="maxPriceInput" class="price-input-hidden" value="@Model.MaxPrice" min="0" max="200">

                            </div>
                        </div>
                        <hr />
                        <div class="mb-4 position-relative">
                            <label class="search-label-small">Населено място</label>
                            <div class="input-wrapper" style="position: relative;">
                                <i class="fas fa-map-marker-alt input-icon" style="left: 15px; top: 12px;"></i>
                                <input type="text"
                                       class="form-control form-control-custom"
                                       id="cityInput"
                                       name="city"
                                       value="@Model.City"
                                       placeholder="Избери град"
                                       style="padding-left: 40px; border: 1px solid #ced4da; border-radius: 25px; background: #f9f9f9;"
                                       autocomplete="off"
                                       required
                                       oninvalid="this.setCustomValidity('Моля, изберете населено място!')"
                                       oninput="this.setCustomValidity('')">

                            </div>
                            <div id="cityList" class="custom-dropdown-list" style="width: 100%; left: 0;"></div>
                        </div>
                        <div class="mb-4 position-relative">
                            <label class="search-label-small">Активност</label>
                            <div class="input-wrapper" style="position: relative;">
                                <i class="fas fa-running input-icon" style="left: 15px; top: 12px;"></i>
                                <input type="text"
                                       class="form-control form-control-custom"
                                       id="activityInput"
                                       name="activity"
                                       value="@Model.Activity"
                                       placeholder="Избери спорт"
                                       style="padding-left: 40px; border: 1px solid #ced4da; border-radius: 25px; background: #f9f9f9;"
                                       autocomplete="off">
                            </div>
                            <div id="activityList" class="custom-dropdown-list" style="width: 100%; left: 0;"></div>
                        </div>
                        <hr />
                        <div class="row g-0">
                            <div class="col-6 border-end pe-2">
                                <label class="form-label fw-bold mb-3 small">Капацитет</label>
                                <div class="d-flex flex-column gap-2">
                                    <div class="form-check d-flex justify-content-between align-items-center p-0">
                                        <div class="d-flex align-items-center">
                                            <input class="form-check-input m-0 me-2" type="radio" name="capacityGroup" value="small" id="smallCheck" @(Context.Request.Query["capacityGroup"] == "small" ? "checked" : "")>
                                            <label class="form-check-label small" for="smallCheck">1-4</label>
                                        </div>
                                        <span class="badge rounded-pill bg-light text-dark border-0 fw-bold" style="font-size: 0.75rem;">@Model.SmallCount</span>
                                    </div>
                                    <div class="form-check d-flex justify-content-between align-items-center p-0">
                                        <div class="d-flex align-items-center">
                                            <input class="form-check-input m-0 me-2" type="radio" name="capacityGroup" value="medium" id="mediumCheck" @(Context.Request.Query["capacityGroup"] == "medium" ? "checked" : "")>
                                            <label class="form-check-label small" for="mediumCheck">5-14</label>
                                        </div>
                                        <span class="badge rounded-pill bg-light text-dark border-0 ms-1" style="font-size: 0.7rem;">@Model.MediumCount</span>
                                    </div>
                                    <div class="form-check d-flex justify-content-between align-items-center p-0">
                                        <div class="d-flex align-items-center">
                                            <input class="form-check-input m-0 me-2" type="radio" name="capacityGroup" value="large" id="largeCheck" @(Context.Request.Query["capacityGroup"] == "large" ? "checked" : "")>
                                            <label class="form-check-label small" for="largeCheck">15+</label>
                                        </div>
                                        <span class="badge rounded-pill bg-light text-dark border-0 ms-1" style="font-size: 0.7rem;">@Model.LargeCount</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 ps-2">
                                <label class="form-label fw-bold mb-3 small">Тип база</label>
                                <div class="d-flex flex-column gap-2">
                                    <div class="form-check d-flex justify-content-between align-items-center p-0">
                                        <div class="d-flex align-items-center">
                                            <input class="form-check-input m-0 me-2" type="radio" name="isOutdoor" value="true" id="outdoorCheck" @(Context.Request.Query["isOutdoor"] == "true" ? "checked" : "")>
                                            <label class="form-check-label small" for="outdoorCheck">Открито</label>
                                        </div>
                                        <span class="badge rounded-pill bg-light text-dark border-0 fw-bold" style="font-size: 0.75rem;">@Model.OutdoorCount</span>
                                    </div>
                                    <div class="form-check d-flex justify-content-between align-items-center p-0">
                                        <div class="d-flex align-items-center">
                                            <input class="form-check-input m-0 me-2" type="radio" name="isOutdoor" value="false" id="indoorCheck" @(Context.Request.Query["isOutdoor"] == "false" ? "checked" : "")>
                                            <label class="form-check-label small" for="indoorCheck">Закрито</label>
                                        </div>
                                        <span class="badge rounded-pill bg-light text-dark border-0 fw-bold" style="font-size: 0.75rem;">@Model.IndoorCount</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr />
                        <a href="javascript:void(0);" onclick="resetSecondaryFilters('@Model.City')" class="text-success text-decoration-none small fw-bold">
                            <i class="bi bi-x-circle me-1"></i>Изчисти
                        </a>
                        <button type="submit" class="btn btn-success w-100 mt-3 shadow-sm">Приложи</button>
                    </form>
                </div>
            </div>
        </aside>
        <main class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
               @{
                    var resultsCount = Model.Results.Count();
                    var resultText = resultsCount == 1 ? "място за спорт" : "места за спорт";
                }
                <h4 class="mb-0"> 
                    @Model.City@(!string.IsNullOrEmpty(Model.Activity) ? $": {Model.Activity}" : ""): 
                    <small class="text-muted"> @(resultsCount == 1 ? "открито" : "открити") @resultsCount @resultText</small>
                </h4>
            <div class="d-flex align-items-center gap-3 mb-4">
                <button type="button" class="btn btn-outline-success shadow-sm" id="viewToggleBtn" onclick="toggleView()">
                    <i id="viewIcon" class="bi bi-grid-3x3-gap-fill"></i>
                </button>
                    <div class="dropdown search-sort-dropdown">
                        <button class="btn btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Подреди по
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <button type="button" class="dropdown-item" onclick="submitWithSort('price_asc')">Цена (най-ниска)</button>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" onclick="submitWithSort('price_desc')">Цена (най-висока)</button>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" onclick="submitWithSort('rating_des')">Рейтинг (низходящ ред)</button>
                            </li>
                            <li>
                                <button type="button" class="dropdown-item" onclick="submitWithSort('rating_asc')">Рейтинг (възходящ ред)</button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div id="resultsContainer" class="d-flex flex-column gap-3">
                @if (!Model.Results.Any())
                {
                    <div class="no-results-container text-center py-5 shadow-sm border rounded-4 bg-white">
                        <div class="no-results-icon-wrapper mb-4">
                            <i class="fas fa-search-location fa-4x text-success-dm opacity-25"></i>
                            <div class="icon-pulse"></div>
                        </div>
                        <h3 class="fw-bold text-dark">Опа! Нищо не открихме.</h3>
                        <p class="text-muted mb-4 mx-auto" style="max-width: 400px;">
                            В момента няма места, които да отговарят на избраните критерии за град <strong>@Model.City</strong>.
                            Опитайте да промените цената или да потърсите друга активност.
                        </p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="@Url.Action("Index", "Home")" class="btn btn-success px-4 rounded-pill shadow-sm">
                                <i class="bi bi-search me-2"></i>Ново търсене
                            </a>
                        </div>
                    </div>
                }
                @foreach (var place in Model.Results)
                {
                <div class="result-wrapper">
                    <div class="card border-success shadow-sm mb-3 search-result-card">
                        <div class="row g-0">
                            <div class="col-md-4">
                                <img src="@(place.PlaceImages?.OrderBy(i => i.Id).FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/400x220")"
                                     class="img-fluid search-card-img" alt="@place.Name">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body d-flex flex-column h-100">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <h5 class="card-title text-dark fw-bold">@place.Name</h5>
                                        <span class="badge bg-success-subtle text-dark border border-success-subtle">⭐ @place.Rating/5</span>
                                    </div>
                                    <p class="card-text text-muted small mb-2 text-truncate-2">@place.Description</p>
                    
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <div class="badge rounded-pill bg-light text-dark fw-normal border py-1 px-2">
                                            <i class="bi bi-geo-alt text-success me-1"></i> @place.Address, @place.City.Name
                                        </div>
                                        <div class="badge rounded-pill bg-light text-dark fw-normal border py-1 px-2">
                                            <i class="bi bi-people text-success me-1"></i> до @place.Capacity души
                                        </div>
                                        <div class="badge rounded-pill bg-light text-dark fw-normal border py-1 px-2">
                                            @if (place.IsOutdoor.Value)
                                            {
                                                <i class="bi bi-sun text-warning me-1"></i> <span>Открито</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-house-door text-primary me-1"></i> <span>Закрито</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="mt-auto pt-3 d-flex justify-content-between align-items-center border-top">
                                        <div>
                                            <span class="text-muted small">Цена:</span>
                                            <h4 class="text-success fw-bold mb-0">@place.Price евро<small class="fs-6 fw-light">/ч</small></h4>
                                        </div>
                        
                                        <a asp-controller="Reservation" asp-action="Index" asp-route-id="@place.Id" class="text-decoration-none">
                                            <span class="btn btn-success rounded-pill px-3 shadow-sm">Вижте повече</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                }
            </div>
        </main>
    </div>
</div>
<div class="modal fade" id="largeMapModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="largeMapModalLabel" aria-hidden="true" style="z-index: 2000;">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="largeMapModalLabel"><i class="bi bi-geo-alt me-2"></i>Карта: @Model.City</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" style="height: 80vh; min-height: 500px;">
                <iframe id="largeMapFrame"
                        width="100%"
                        height="100%"
                        frameborder="0"
                        style="border:0; display:block;"
                        src="https://maps.google.com/maps?q=@(Uri.EscapeDataString(Model.City ?? "Bulgaria"))&t=&z=14&ie=UTF8&iwloc=&output=embed">
                </iframe>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/search.css" asp-append-version="true" />
}
<script>
    function submitWithSort(order)
    {
        const form = document.getElementById('filterForm');
        const sortInput = document.getElementById('currentSortOrder');

        if (form && sortInput)
        {
            sortInput.value = order;
            form.submit();
        }
        else
        {
            console.error("Формата или полето за сортиране не са намерени!");
        }
    }
    const minR = document.getElementById('minPriceRange');
    const maxR = document.getElementById('maxPriceRange');
    const minInput = document.getElementById('minPriceInput');
    const maxInput = document.getElementById('maxPriceInput');
    const track = document.getElementById('sliderTrack');

    function updatePrice()
    {
        let v1 = parseInt(minR.value);
        let v2 = parseInt(maxR.value);
        let max = parseInt(minR.max);

        if (v1 > v2 - 5)
        {
            if (this.id === 'minPriceRange' || this.id === 'minPriceInput')
            {
                v1 = v2 - 5;
                minR.value = v1;
            }
            else
            {
                v2 = v1 + 5;
                maxR.value = v2;
            }
        }
        minInput.value = v1;
        maxInput.value = v2;

        if (track)
        {
            let p1 = (v1 / max) * 100;
            let p2 = (v2 / max) * 100;
            track.style.left = p1 + "%";
            track.style.width = (p2 - p1) + "%";
        }
    }

    function handleManualInput()
    {
        let val = parseInt(this.value);
        const maxLimit = parseInt(minR.max);

        if (isNaN(val)) val = 0;
        if (val < 0) val = 0;
        if (val > maxLimit) val = maxLimit;

        if (this.id === 'minPriceInput')
        {
            minR.value = val;
        }
        else
        {
            maxR.value = val;
        }
        updatePrice.call(this);
    }

    minR.addEventListener('input', updatePrice);
    maxR.addEventListener('input', updatePrice);
    minInput.addEventListener('click', function() { this.select(); });
    maxInput.addEventListener('click', function() { this.select(); });
    minInput.addEventListener('change', handleManualInput);
    maxInput.addEventListener('change', handleManualInput);

    document.addEventListener("DOMContentLoaded", function()
    {
        const params = new URLSearchParams(window.location.search);
        if (!params.has('minPrice')) minR.value = 0;
        if (!params.has('maxPrice')) maxR.value = 200;

        updatePrice.call(minR);
    });

    document.querySelectorAll('input[type="radio"]').forEach(radio => {
        radio.addEventListener('click', function()
        {
            if (this.previousValue === 'true')
            {
                this.checked = false;
                this.previousValue = 'false';
            }
            else
            {
                document.querySelectorAll(`input[name="${this.name}"]`).forEach(r => r.previousValue = 'false');
                this.previousValue = 'true';
            }
        });
    });
    const citiesData = @Html.Raw(Json.Serialize(Model.CitiesList)) || [];
    const activitiesData = @Html.Raw(Json.Serialize(Model.ActivitiesList)) || [];

    function setupAutocomplete(inputId, listId, dataArray, iconClass)
    {
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);

        const popularItemsMap =
        {
            'cityInput': ["София", "Пловдив", "Варна", "Бургас", "Благоевград"],
            'activityInput': ["Футбол", "Волейбол", "Баскетбол", "Тенис", "Фитнес"]
        };

        const labelsMap =
        {
            'cityInput': "Известни локации",
            'activityInput': "Популярни активности"
        };

        function renderList(items)
        {
            list.innerHTML = '';
            const inputValue = input.value.toLowerCase().trim();
            if (inputValue === '')
            {
                const label = document.createElement('div');
                label.className = 'dropdown-header-custom';
                label.innerHTML = `<strong>${labelsMap[inputId]}</strong>`;
                list.appendChild(label);

                popularItemsMap[inputId].forEach(item => {
                    list.appendChild(createItemDiv(item));
                });

                const divider = document.createElement('div');
                divider.className = 'dropdown-header-custom mt-2';
                divider.innerHTML = `<strong>Всички предложения</strong>`;
                list.appendChild(divider);
            }

            if (items.length === 0 && inputValue !== '')
            {
                list.style.display = 'none';
                return;
            }
            items.forEach(item => {
                list.appendChild(createItemDiv(item));
            });
            list.style.display = 'block';
        }
        function createItemDiv(item)
        {
            const div = document.createElement('div');
            div.className = 'dropdown-item-custom';
            div.innerHTML = `<i class="${iconClass}"></i> ${item}`;
            const activityIcons = {
                    'Айкидо': 'fas fa-user-ninja',
                    'Акробатика': 'fas fa-child',
                    'Бадминтон': 'fas fa-table-tennis',
                    'Балет': 'fas fa-shoe-prints',
                    'Баскетбол': 'fas fa-basketball-ball',
                    'Бейзбол': 'fas fa-baseball-ball',
                    'Билярд': 'fas fa-circle',
                    'Бокс': 'fas fa-fist-raised',
                    'Борба': 'fas fa-hand-rock',
                    'Боулинг': 'fas fa-bowling-ball',
                    'Волейбол': 'fas fa-volleyball-ball',
                    'Гимнастика': 'fas fa-walking',
                    'Голф': 'fas fa-golf-ball',
                    'Дартс': 'fas fa-bullseye',
                    'Джудо': 'fas fa-user-ninja',
                    'Йога': 'fas fa-spa',
                    'Карате': 'fas fa-hand-rock',
                    'Конна езда': 'fas fa-horse',
                    'Крикет': 'fas fa-baseball-ball',
                    'Лека атлетика': 'fas fa-running',
                    'ММА': 'fas fa-fist-raised',
                    'Падел': 'fas fa-table-tennis',
                    'Плуване': 'fas fa-swimmer',
                    'Ски': 'fas fa-skiing',
                    'Стрелба': 'fas fa-crosshairs',
                    'Таекуондо': 'fas fa-user-ninja',
                    'Танци': 'fas fa-music',
                    'Тенис': 'fas fa-table-tennis',
                    'Тенис на маса': 'fas fa-table-tennis',
                    'Фехтовка': 'fas fa-pen-nib',
                    'Фитнес': 'fas fa-dumbbell',
                    'Футбол': 'fas fa-futbol',
                    'Хандбал': 'fas fa-volleyball-ball'
             };
            const currentIcon = activityIcons[item] || iconClass;
            div.innerHTML = `<i class="${currentIcon}"></i> ${item}`;
            div.addEventListener('click', function()
            {
                input.value = item;
                input.setCustomValidity('');
                list.style.display = 'none';
                input.focus();
            });
            return div;
        }
        function handleFilter()
        {
            const text = input.value.toLowerCase().trim();
            const filtered = dataArray
                .filter(item => item.toString().toLowerCase().trim().startsWith(text))
                .sort();
            renderList(filtered);
        }
        input.addEventListener('focus', handleFilter);
        input.addEventListener('input', handleFilter);
        document.addEventListener('click', function(e)
        {
            if (e.target !== input && !list.contains(e.target))
            {
                list.style.display = 'none';
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function()
    {
        setupAutocomplete('cityInput', 'cityList', citiesData, 'fas fa-map-marker-alt');
        setupAutocomplete('activityInput', 'activityList', activitiesData, 'fas fa-running');
    });
    function resetSecondaryFilters(lastValidCity)
    {
        const cityInput = document.getElementById('cityInput');
        const activityInput = document.getElementById('activityInput');
        const minR = document.getElementById('minPriceRange');
        const maxR = document.getElementById('maxPriceRange');
        const form = document.getElementById('filterForm');

        if (cityInput && (!cityInput.value.trim()))
        {
            cityInput.value = lastValidCity || "";
        }

        if (activityInput)
        {
            activityInput.value = "";
        }

        if (minR && maxR)
        {
            minR.value = 0;
            maxR.value = 200;
            updatePrice.call(minR);
        }

        document.querySelectorAll('input[name="capacityGroup"]').forEach(radio => {
            radio.checked = false;
            radio.previousValue = 'false';
        });

        document.querySelectorAll('input[name="isOutdoor"]').forEach(radio => {
        radio.checked = false;
        radio.previousValue = 'false';
        });

        cityInput.setCustomValidity('');

        if (form)
        {
            form.submit();
        }
    }
    function toggleView() 
    {
        const container = document.getElementById('resultsContainer');
        const icon = document.getElementById('viewIcon');
        const wrappers = document.querySelectorAll('.result-wrapper');
        const isGrid = container.classList.toggle('grid-mode');

        localStorage.setItem('preferredView', isGrid ? 'grid' : 'list');
        applyViewStyles(isGrid, container, icon, wrappers);
    }
    function applyViewStyles(isGrid, container, icon, wrappers) 
    {
        if (isGrid)
        {
            container.classList.remove('flex-column', 'gap-3');
            container.classList.add('row');
            if(icon) icon.className = 'bi bi-list-ul';
            wrappers.forEach(w => w.classList.replace('col-12', 'col-md-4'));
        } 

        else
        {
            container.classList.add('flex-column', 'gap-3');
            container.classList.remove('row');
            if(icon) icon.className = 'bi bi-grid-3x3-gap-fill';
            wrappers.forEach(w => w.classList.replace('col-md-4', 'col-12'));
        }
    }
    function initView() 
    {
        const savedView = localStorage.getItem('preferredView');
        if (savedView === 'grid') 
        {
            const container = document.getElementById('resultsContainer');
            const icon = document.getElementById('viewIcon');
            const wrappers = document.querySelectorAll('.result-wrapper');
        
            if (container) 
            {
                container.classList.add('grid-mode');
                applyViewStyles(true, container, icon, wrappers);
            }
        }
    }
    document.addEventListener('DOMContentLoaded', initView);
    document.addEventListener("DOMContentLoaded", function() {
    setupAutocomplete('cityInput', 'cityList', citiesData, 'fas fa-map-marker-alt');
    setupAutocomplete('activityInput', 'activityList', activitiesData, 'fas fa-running');
    const searchForm = document.getElementById('filterForm') || document.getElementById('mainSearchForm');
    if (searchForm)
    {
        searchForm.addEventListener('submit', function (e) 
        {
            const cityInput = document.getElementById('cityInput');
            const activityInput = document.getElementById('activityInput');           
            const cityValue = cityInput.value.trim().toLowerCase();
            const activityValue = activityInput.value.trim().toLowerCase();
            const isCityValid = citiesData.some(c => c.toLowerCase() === cityValue);
            if (!isCityValid) 
            {
                e.preventDefault();
                toastr.info("Моля, изберете град от предложенията!");
                cityInput.classList.add('input-error');
                cityInput.value = '';
                cityInput.focus();
                setTimeout(() => cityInput.classList.remove('input-error'), 2000);
                return false;
            }
            const isActivityValid = activitiesData.some(a => a.toLowerCase() === activityValue);
            if (activityValue !== "" && !isActivityValid)
            {
                e.preventDefault();
                toastr.info("Моля, изберете валидна активност!");
                activityInput.classList.add('input-error');
                activityInput.value = '';
                activityInput.focus();
                setTimeout(() => activityInput.classList.remove('input-error'), 2000);
                return false;
            }
        });
    }
});
</script>