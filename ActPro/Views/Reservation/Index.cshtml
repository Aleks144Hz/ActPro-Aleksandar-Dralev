@using Microsoft.AspNetCore.Identity
@using ActPro.DAL.Entities
@inject UserManager<ActPro.DAL.ApplicationUser> UserManager
@inject SignInManager<ActPro.DAL.ApplicationUser> SignInManager
@model ActPro.Models.ReservationViewModel
@{
    ViewData["Title"] = Model.Place.Name;
    bool IsLoggedIn = User.Identity?.IsAuthenticated ?? false;
    var mainImage = Model.Place.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/800x400?text=Няма+снимка";
    var subImages = Model.Place.PlaceImages?.Skip(1).Take(2).ToList();
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var userCommentsCount = Model.Place.Comments.Count(c => c.AspNetUserId == currentUserId);
}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="display-6 fw-bold">@Model.Place.Name</h1>
            <p class="text-muted fs-5">@Model.Place.Activity?.Name в @Model.Place.City?.Name</p>
        </div>
        <div class="text-end">
            <span class="fs-4 fw-bold text-warning">
                <button type="button"
                        class="btn @(Model.IsFavorite ? "btn-warning" : "btn-outline-warning") btn-sm ms-2 favorite-btn-large"
                        data-id="@Model.Place.Id">
                    <i class="bi @(Model.IsFavorite ? "bi-star-fill" : "bi-star")"></i>
                </button> @Model.Place.Rating/5
            </span>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="row g-2">
                <div class="col-12">
                    <img src="@mainImage" class="img-fluid rounded w-100 shadow-sm" style="height: 400px; object-fit: cover;" alt="Main Image">
                </div>
                <div class="col-6">
                    <img src="@(subImages?.Count > 0 ? subImages[0].ImageUrl : "https://via.placeholder.com/400x200")"
                         class="img-fluid rounded w-100 shadow-sm" style="height: 200px; object-fit: cover;" alt="Sub 1">
                </div>
                <div class="col-6">
                    <img src="@(subImages?.Count > 1 ? subImages[1].ImageUrl : "https://via.placeholder.com/400x200")"
                         class="img-fluid rounded w-100 shadow-sm" style="height: 200px; object-fit: cover;" alt="Sub 2">
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success shadow-sm sticky-top" style="top: 20px;">
                <div class="card-body text-center">
                    <h2 class="card-title text-success mb-3">@Model.Place.Price €/ч</h2>
                    <p class="text-muted">Капацитет: до @Model.Place.Capacity души</p>
                    <button type="button" class="btn btn-success btn-lg w-100 py-3 shadow" data-bs-toggle="modal" data-bs-target="#bookingModal">
                        Запази час
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4 p-4 border-light shadow-sm">
                <h5 class="fw-bold">Описание на обекта</h5>
                <p class="text-secondary">
                    @Model.Place.Description
                </p>
                <hr />
                <div class="row text-center">
                    <div class="col-4">
                        <i class="bi bi-people fs-3 text-success"></i>
                        <p class="small mb-0">@Model.Place.Capacity души</p>
                    </div>
                    <div class="col-4">
                        <i class="bi bi-geo-alt fs-3 text-success"></i>
                        <p class="small mb-0">@Model.Place.City?.Name</p>
                    </div>
                    <div class="col-4">
                        <i class="bi bi-shield-check fs-3 text-success"></i>
                        <p class="small mb-0">Проверен</p>
                    </div>
                </div>
            </div>
            <button class="btn btn-light w-100 py-3 border shadow-sm mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#reviewsSection">
                <i class="bi bi-chat-left-text me-2"></i> Коментари и отзиви
            </button>

            <div class="collapse" id="reviewsSection">
                <div class="card card-body border-light shadow-sm mb-4">
                    <div class="reviews-list">
                        @if (Model.Place.Comments != null && Model.Place.Comments.Any())
                        {
                            @foreach (var review in Model.Place.Comments.OrderByDescending(r => r.CreatedAt))
                            {
                                <div class="d-flex mb-4 border-bottom pb-3">
                                    <div class="flex-shrink-0">
                                        @{
                                            var profilePicName = review.User?.ProfilePicturePath;
                                            var fullPath = !string.IsNullOrEmpty(profilePicName)
                                            ? "/images/profiles/" + profilePicName
                                            : null;
                                            var initial = review.User?.FirstName?[0].ToString().ToUpper() ?? "U";
                                        }
                                        @if (!string.IsNullOrEmpty(fullPath))
                                        {
                                            <img src="@fullPath"
                                                 class="rounded-circle shadow-sm"
                                                 style="width: 50px; height: 50px; object-fit: cover; border: 1px solid #dee2e6;"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                            <div class="bg-success text-white rounded-circle shadow-sm fw-bold align-items-center justify-content-center"
                                                 style="width: 50px; height: 50px; display: none; font-size: 1.2rem;">
                                                @initial
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm"
                                                 style="width: 50px; height: 50px; font-size: 1.2rem;">
                                                @initial
                                            </div>
                                        }
                                    </div>
                                    <div class="ms-3 w-100">
                                        <div class="d-flex justify-content-between">
                                            <h6 class="mb-0 fw-bold">
                                                @review.User?.FirstName @review.User?.LastName
                                                @if (review.AspNetUserId == currentUserId)
                                                {
                                                    <form asp-action="DeleteReview" method="post" style="display:inline;">
                                                        <input type="hidden" name="reviewId" value="@review.Id" />
                                                        <input type="hidden" name="placeId" value="@Model.Place.Id" />
                                                        <button type="submit"
                                                                class="btn btn-link text-danger p-0 ms-2"
                                                                title="Изтрий коментара">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </h6>
                                            <span class="text-warning small">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                                }
                                            </span>
                                        </div>
                                        <small class="text-muted">@review.CreatedAt?.ToString("dd.MM.yyyy HH:mm")</small>
                                        <p class="text-dark mt-2 mb-0 comment-text">@review.CommentText</p>
                                    </div>
                                </div>
                            }
                            <hr />
                        }
                        else
                        {
                            <p class="text-muted text-center my-4 italic">Все още няма добавени отзиви.</p>
                        }
                        @if (IsLoggedIn)
                        {
                            if (userCommentsCount < 3)
                            {
                                <h6 class="fw-bold mb-3">Остави отзив</h6>
                                <form asp-action="AddReview" method="post">
                                    <input type="hidden" name="placeId" value="@Model.Place.Id" />
                                    <div class="star-rating mb-2">
                                        <input type="radio" id="star5" name="rating" value="5" /><label for="star5"></label>
                                        <input type="radio" id="star4" name="rating" value="4" /><label for="star4"></label>
                                        <input type="radio" id="star3" name="rating" value="3" /><label for="star3"></label>
                                        <input type="radio" id="star2" name="rating" value="2" /><label for="star2"></label>
                                        <input type="radio" id="star1" name="rating" value="1" required /><label for="star1"></label>
                                    </div>
                                    <textarea name="commentText" id="commentArea"
                                      class="form-control mb-2" rows="3"
                                      placeholder="Сподели мнение..."
                                      maxlength="250"></textarea>
                                    <div id="charCounter" class="text-muted small position-absolute"
                                         style="bottom: 15px; right: 10px;">
                                        0 / 250
                                    </div>
                                    <button type="submit" class="btn btn-success">Публикувай</button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-info py-2 small">Достигнали сте лимита от 3 коментара за това място.</div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-sm alert-light border text-center small">
                                За да оставите коментар <a asp-controller="Account" asp-action="Login">присъединeте се</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="bookingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-success">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">Резервация за @Model.Place.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                @Html.AntiForgeryToken()

                <div class="d-flex align-items-center justify-content-center mb-4">
                    <button class="btn btn-outline-success rounded-circle me-2" id="prevDay" type="button">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <div id="dateScrollContainer" class="d-flex overflow-hidden" style="max-width: 545px; scroll-behavior: smooth;">
                        @for (int i = 0; i < 31; i++)
                        {
                            var date = DateTime.Now.AddDays(i);
                            <div class="text-center border rounded p-2 mx-1 date-item @(i == 0 ? "bg-success text-white" : "bg-white")"
                                 style="min-width: 70px; cursor: pointer;"
                                 data-date="@date.ToString("yyyy-MM-dd")">
                                <small class="d-block">@(i == 0 ? "Днес" : date.ToString("ddd").ToUpper())</small>
                                <strong>@date.Day</strong>
                                <small class="d-block" style="font-size: 0.7rem;">@date.ToString("MMM")</small>
                            </div>
                        }
                    </div>
                    <button class="btn btn-outline-success rounded-circle ms-2" id="nextDay" type="button">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>

                <input type="hidden" id="selectedDate" name="reservationDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                <div class="row row-cols-4 g-2 mb-4 text-center">
                    @foreach (var hour in new[] { "09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00", "16:00", "17:00", "18:00", "19:00", "20:00" })
                    {
                        <div class="col mb-2">
                            <input type="radio" name="timeSlot" id="slot-@hour" value="@hour" class="btn-check">
                            <label for="slot-@hour" class="time-slot-label btn btn-outline-success w-100">@hour</label>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-success btn-lg px-5 shadow" onclick="handleBookingClick()">
                    Резервирай
                </button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="authPromptModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Необходим е профил</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pb-4">
                <i class="bi bi-person-circle text-success" style="font-size: 4rem;"></i>
                <p class="fs-5 mt-3">За да направите резервация, трябва да сте част от ActPro.</p>
                <div class="d-grid gap-2 mt-4">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-success btn-lg">Вход</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-success">Създаване на акаунт</a>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/reservation.css" asp-append-version="true" />
}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const isUserLoggedIn = @(User.Identity.IsAuthenticated ? "true" : "false");
    document.addEventListener("DOMContentLoaded", function ()
    {
        const container = document.getElementById('dateScrollContainer');
        const selectedDateInput = document.getElementById('selectedDate');

        document.querySelectorAll('.date-item').forEach(item => {
            item.addEventListener('click', function()
            {
                document.querySelectorAll('.date-item').forEach(el => {
                    el.classList.remove('bg-success', 'text-white', 'border-success', 'shadow-sm');
                    el.classList.add('bg-white', 'text-dark');
                });
                this.classList.add('bg-success', 'text-white', 'border-success', 'shadow-sm');
                this.classList.remove('bg-white', 'text-dark');
                const pickedDate = this.getAttribute('data-date');
                selectedDateInput.value = pickedDate;
                updateTimeSlots();
            });
        });
        window.scrollDays = function(direction)
        {
            const currentActive = container.querySelector('.date-item.bg-success');
            let target = (direction === 'next') ? currentActive.nextElementSibling : currentActive.previousElementSibling;

            if (target && target.classList.contains('date-item'))
            {
                target.click();
                target.scrollIntoView({
                    behavior: 'smooth',
                    block: 'nearest',
                    inline: 'center'
                });
            }
        };
        document.getElementById('nextDay').addEventListener('click', () => scrollDays('next'));
        document.getElementById('prevDay').addEventListener('click', () => scrollDays('prev'));

        const bookingModalEl = document.getElementById('bookingModal');
        if (bookingModalEl)
        {
            bookingModalEl.addEventListener('show.bs.modal', function ()
            {
                updateTimeSlots();
            });
        }
        updateTimeSlots();
    });

    $(document).ready(function()
    {
        $(document).on('click', '.favorite-btn-large', function (e)
        {
            e.preventDefault();
            var btn = $(this);
            var pId = btn.attr('data-id');
            $.ajax({
                url: '/Account/ToggleFavorite',
                type: 'POST',
                data: { placeId: pId },
                success: function (response)
                {
                    if (response.success)
                    {
                        var icon = btn.find('i');
                        if (response.isFavorite)
                        {
                            btn.removeClass('btn-outline-warning').addClass('btn-warning');
                            icon.removeClass('bi-star').addClass('bi-star-fill');
                        }
                        else
                        {
                            btn.removeClass('btn-warning').addClass('btn-outline-warning');
                            icon.removeClass('bi-star-fill').addClass('bi-star');
                        }
                    }
                },
                error: function (xhr) 
                {
                    toastr.error(xhr.status === 401 ? "Трябва да сте влезли в профила си!" : "Грешка при комуникация.");
                }
            });
        });
    });

    function updateTimeSlots()
    {
        const selectedDateStr = document.getElementById('selectedDate').value;
        const placeId = "@Model.Place.Id";
        const url = '@Url.Action("GetOccupiedSlots", "Reservation")';
        const now = new Date();
        const todayStr = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');

        $.get(`${url}?placeId=${placeId}&date=${selectedDateStr}`, function(occupiedSlots)
        {
            document.querySelectorAll('input[name="timeSlot"]').forEach(input => {
                const label = document.querySelector(`label[for="${input.id}"]`);
                const hourValue = input.value;
                const isOccupied = occupiedSlots.includes(hourValue);
                let isPast = false;

                if (selectedDateStr === todayStr)
                {
                    const [hour, minute] = hourValue.split(':');
                    const slotTime = new Date();
                    slotTime.setHours(parseInt(hour), parseInt(minute), 0, 0);
                    if (slotTime < now) isPast = true;
                }
                if (isOccupied || isPast)
                {
                    input.disabled = true;
                    input.checked = false;
                    label.classList.add('slot-occupied');
                    label.style.opacity = "0.5";
                    label.title = isPast ? "Този час вече е минал" : "Този час вече е зает";
                }
                else
                {
                    input.disabled = false;
                    label.classList.remove('slot-occupied');
                    label.style.opacity = "1";
                    label.removeAttribute('title');
                }
            });
        });
    }

    function handleBookingClick() 
    {
        const selectedTimeInput = document.querySelector('input[name="timeSlot"]:checked');
        if (!selectedTimeInput) 
        {
            toastr.info("Моля, изберете час за вашата резервация!");
            return;
        }
        if (isUserLoggedIn)
        {
            executeBooking();
        }
        else
        {
            const bookingModal = bootstrap.Modal.getInstance(document.getElementById('bookingModal'));
            bookingModal.hide();
            const authModal = new bootstrap.Modal(document.getElementById('authPromptModal'));
            authModal.show();
        }
    }

    function executeBooking()
    {
        const selectedTimeInput = document.querySelector('input[name="timeSlot"]:checked');
        const date = document.getElementById('selectedDate').value;
        const time = selectedTimeInput.value;
        const placeId = "@Model.Place.Id";
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '@Url.Action("Book", "Reservation")';

        const data =
        {
            'placeId': placeId,
            'date': date,
            'timeSlot': time,
            '__RequestVerificationToken': token
        };

        for (const key in data)
        {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = data[key];
            form.appendChild(input);
        }
        document.body.appendChild(form);
        form.submit();
    }
 
    const textArea = document.getElementById('commentArea');
    const charCounter = document.getElementById('charCounter');

    if (textArea && charCounter) 
    {
        textArea.addEventListener('input', function () 
        {
            const length = textArea.value.length;
            charCounter.textContent = `${length} / 250`;

            if (length >= 250)
            {
                charCounter.classList.replace('text-muted', 'text-danger');
            } 
            else 
            {
                charCounter.classList.replace('text-danger', 'text-muted');
            }
        });
    }
</script>