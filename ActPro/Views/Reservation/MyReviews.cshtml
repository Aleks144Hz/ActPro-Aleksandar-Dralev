@model IEnumerable<ActPro.DAL.Entities.Comment>

@{
    ViewData["Title"] = "Моите отзиви";
}

<div class="container py-5">
    <div class="row mb-5 align-items-center">
        <div class="col-lg-8 text-center text-lg-start">
            <h2 class="fw-bold text-dark mb-2">
                <i class="bi bi-chat-left-quote-fill text-primary me-2"></i> Моите отзиви
            </h2>
            <p class="text-muted">Тук можете да видите и управлявате всички ваши отзиви за посетените обекти.</p>
        </div>
        <div class="col-lg-4 text-center text-lg-end">
            <div class="d-inline-block bg-primary bg-opacity-10 p-3 rounded-4 border border-primary border-opacity-25">
                <span class="h4 fw-bold text-primary mb-0">@Model.Count()</span>
                <span class="text-primary ms-1 small text-uppercase fw-bold">Отзива</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var review in Model)
            {
                <div class="col-12 col-xl-6">
                    <div class="card h-100 border-0 shadow-sm transition-hover" style="border-radius: 20px;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-3 p-2 me-3 text-primary">
                                        <i class="bi bi-geo-alt-fill fs-4"></i>
                                    </div>
                                    <div>
                                        <h5 class="fw-bold mb-0 text-truncate" style="max-width: 500px;">
                                        <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@review.Place.Id"
                                           class="text-decoration-none text-dark hover-success">
                                            @review.Place?.Name
                                            </a>
                                        </h5>
                                        <small class="text-muted">@review.CreatedAt</small>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="text-warning mb-1">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star text-muted opacity-25")"></i>
                                        }
                                    </div>
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">@review.Rating / 5</span>
                                </div>
                            </div>

                            <div class="bg-light p-3 rounded-4 mb-3 position-relative">
                                <i class="bi bi-quote position-absolute text-primary opacity-10" style="top: 5px; right: 10px; font-size: 2rem;"></i>
                                <p class="card-text text-secondary mb-0 style-italic">
                                    "@(string.IsNullOrEmpty(review.CommentText) ? "Няма коментар." : review.CommentText)"
                                </p>
                            </div>

                            <div class="d-flex justify-content-end align-items-center gap-3">
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill px-3 fw-bold"
                                        data-bs-toggle="modal" data-bs-target="#editModal-@review.Id">
                                    <i class="bi bi-pencil-square me-1"></i> Редактирай
                                </button>

                                <form asp-action="DeleteReview" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="reviewId" value="@review.Id" />
                                    <input type="hidden" name="placeId" value="@review.PlaceId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold">
                                        <i class="bi bi-trash3 me-1"></i> Изтрий
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editModal-@review.Id" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                            <div class="modal-header border-0 bg-primary text-white p-4" style="border-radius: 20px 20px 0 0;">
                                <h5 class="modal-title fw-bold">Редактирай отзив</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <form asp-action="EditReview" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@review.Id" />
                                <div class="modal-body p-4">
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted">ОЦЕНКА</label>
                                        <div class="d-flex gap-2 justify-content-center">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <input type="radio" class="btn-check" name="rating" id="rate-@review.Id-@i" value="@i" @(review.Rating == i ? "checked" : "")>
                                                <label class="btn btn-outline-warning rounded-circle" for="rate-@review.Id-@i">@i</label>
                                            }
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted text-uppercase">Текст на коментара</label>
                                        <textarea name="commentText" class="form-control border-0 bg-light p-3" rows="3" style="border-radius: 15px;" required>@review.CommentText</textarea>
                                    </div>
                                </div>
                                <div class="modal-footer border-0 p-4 pt-0">
                                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Отказ</button>
                                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Запази</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="bg-light d-inline-block p-5 rounded-circle mb-4">
                    <i class="bi bi-chat-dots text-muted" style="font-size: 4rem;"></i>
                </div>
                <h4 class="text-muted fw-bold">Все още нямате отзиви.</h4>
                <a href="/" class="btn btn-primary rounded-pill px-4 mt-3 shadow">Разгледайте обекти</a>
            </div>
        }
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/reservation.css" asp-append-version="true" />
}