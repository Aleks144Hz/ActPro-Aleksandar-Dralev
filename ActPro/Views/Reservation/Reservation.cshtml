@model ActPro.DAL.Entities.Place
@{
    ViewData["Title"] = Model.Name;
    bool IsLoggedIn = User.Identity?.IsAuthenticated ?? false;
    var mainImage = Model.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/800x400?text=Няма+снимка";
    var subImages = Model.PlaceImages?.Skip(1).Take(2).ToList();
}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="display-6 fw-bold">@Model.Name</h1>
            <p class="text-muted fs-5">@Model.Activity?.Name в @Model.City?.Name</p>
        </div>
        <div class="text-end">
            <span class="fs-4 fw-bold text-warning">⭐ @Model.Rating/10</span>
            <button class="btn btn-outline-danger btn-sm ms-2"><i class="bi bi-heart"></i></button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="row g-2">
                <div class="col-12">
                    <img src="@mainImage" class="img-fluid rounded w-100 shadow-sm" style="height: 400px; object-fit: cover;" alt="Main Image">
                </div>
                <div class="col-6">
                    <img src="@(subImages?.Count > 0 ? subImages[0].ImageUrl : "https://via.placeholder.com/400x200")"
                         class="img-fluid rounded w-100 shadow-sm" style="height: 200px; object-fit: cover;" alt="Sub 1">
                </div>
                <div class="col-6">
                    <img src="@(subImages?.Count > 1 ? subImages[1].ImageUrl : "https://via.placeholder.com/400x200")"
                         class="img-fluid rounded w-100 shadow-sm" style="height: 200px; object-fit: cover;" alt="Sub 2">
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-success shadow-sm sticky-top" style="top: 20px;">
                <div class="card-body text-center">
                    <h2 class="card-title text-success mb-3">@Model.Price €/ч</h2>
                    <p class="text-muted">Капацитет: до @Model.Capacity души</p>

                    <button type="button" class="btn btn-success btn-lg w-100 py-3 shadow" data-bs-toggle="modal" data-bs-target="#bookingModal">
                        Запази час
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4 p-4 border-light shadow-sm">
                <h5 class="fw-bold">Описание на обекта</h5>
                <p class="text-secondary">
                    @Model.Description
                </p>
                <hr />
                <div class="row text-center">
                    <div class="col-4">
                        <i class="bi bi-people fs-3 text-success"></i>
                        <p class="small mb-0">@Model.Capacity души</p>
                    </div>
                    <div class="col-4">
                        <i class="bi bi-geo-alt fs-3 text-success"></i>
                        <p class="small mb-0">@Model.City?.Name</p>
                    </div>
                    <div class="col-4">
                        <i class="bi bi-shield-check fs-3 text-success"></i>
                        <p class="small mb-0">Проверен</p>
                    </div>
                </div>
            </div>

            <button class="btn btn-light w-100 py-3 border shadow-sm">Коментари и отзиви</button>
        </div>
    </div>
</div>

<div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-success">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">@Model.Name</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center justify-content-center mb-4">
                    <button class="btn btn-outline-success rounded-circle me-2" id="prevDay" type="button">
                        <i class="bi bi-chevron-left"></i>
                    </button>

                    <div id="dateScrollContainer" class="d-flex overflow-hidden" style="max-width: 545px; scroll-behavior: smooth;">
                        @for (int i = 0; i < 31; i++)
                        {
                            var date = DateTime.Now.AddDays(i);
                            <div class="text-center border rounded p-2 mx-1 date-item @(i == 0 ? "bg-success text-white" : "bg-white")"
                                 style="min-width: 70px; cursor: pointer;"
                                 data-date="@date.ToString("yyyy-MM-dd")">
                                <small class="d-block">@(i == 0 ? "Днес" : date.ToString("ddd").ToUpper())</small>
                                <strong>@date.Day</strong>
                                <small class="d-block" style="font-size: 0.7rem;">@date.ToString("MMM")</small>
                            </div>
                        }
                    </div>
                    <button class="btn btn-outline-success rounded-circle ms-2" id="nextDay" type="button">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
                <input type="hidden" id="selectedDate" name="reservationDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                <div class="row row-cols-4 g-2 mb-4 text-center">
                    @foreach (var hour in new[] { "09:00", "10:00", "11:00", "12:00", "13:00", "14:00", "15:00", "16:00", "17:00", "18:00", "19:00", "20:00" })
                    {
                        <div class="col">
                            <input type="radio" class="btn-check" name="timeSlot" id="time_@hour" autocomplete="off">
                            <label class="btn btn-outline-success w-100 rounded-pill" for="time_@hour">@hour</label>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-success btn-lg px-5 shadow" data-bs-target="#guestModal" data-bs-toggle="modal">
                    Резервирай
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="guestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-success">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Завършване на резервацията</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Reservation" asp-action="Book" method="post">
                    <input type="hidden" name="placeId" value="@Model.Id" />
                    <input type="hidden" name="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="timeSlot" id="selectedTime" value="10:00" />

                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label small fw-bold">Име</label>
                            <input type="text" name="firstName" class="form-control border-success" required>
                        </div>
                        <div class="col">
                            <label class="form-label small fw-bold">Фамилия</label>
                            <input type="text" name="lastName" class="form-control border-success" required>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Телефонен номер</label>
                        <input type="tel" name="phoneNumber" class="form-control border-success" required>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-3 shadow-sm">Потвърди резервацията</button>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
    document.querySelectorAll('.date-item').forEach(item => {
        item.addEventListener('click', function() {
            document.querySelectorAll('.date-item').forEach(el => {
                el.classList.remove('bg-success', 'text-white', 'border-success', 'shadow-sm');
                el.classList.add('bg-white', 'text-dark');
            });
            this.classList.add('bg-success', 'text-white', 'border-success', 'shadow-sm');
            this.classList.remove('bg-white', 'text-dark');
            const pickedDate = this.getAttribute('data-date');
            document.getElementById('selectedDate').value = pickedDate;
        });
    });
    document.addEventListener("DOMContentLoaded", function ()
    {
            const container = document.getElementById('dateScrollContainer');
            function scrollDays(direction)
            {
                const firstItem = container.querySelector('.date-item');
                if (firstItem)
                {
                    const itemWidth = firstItem.offsetWidth + 8;
                    const scrollStep = itemWidth * 1;
                    if (direction === 'next')
                    {
                        container.scrollLeft += scrollStep;
                    }
                    else
                    {
                        container.scrollLeft -= scrollStep;
                    }
                }
            }
            document.getElementById('nextDay').addEventListener('click', () => scrollDays('next'));
            document.getElementById('prevDay').addEventListener('click', () => scrollDays('prev'));
            document.querySelectorAll('.date-item').forEach(item => {
                item.addEventListener('click', function() {
                    document.querySelectorAll('.date-item').forEach(el => {
                        el.classList.remove('bg-success', 'text-white');
                        el.classList.add('bg-white');
                    });
                    this.classList.add('bg-success', 'text-white');
                    this.classList.remove('bg-white');
                    document.getElementById('selectedDate').value = this.getAttribute('data-date');
                });
            });
    });
</script>