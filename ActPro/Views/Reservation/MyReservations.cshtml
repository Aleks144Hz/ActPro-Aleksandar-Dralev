@model IEnumerable<ActPro.DAL.Entities.Reservation>
@{
    ViewData["Title"] = "Моите резервации";
}

<div class="container mt-5 min-vh-100">
    <div class="row">
        <div class="col-lg-3 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="list-group list-group-flush rounded">
                        <a asp-action="MyReservations" class="list-group-item list-group-item-action active bg-success border-success py-3">
                            <i class="bi bi-calendar-check me-2"></i> Моите резервации
                        </a>
                        <a asp-controller="Account" asp-action="Index" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-person-circle me-2 text-info"></i> Лични данни
                        </a>
                        <a asp-controller="Account" asp-action="Index" class="list-group-item list-group-item-action py-3">
                            <i class="bi bi-star-fill me-2 text-warning"></i> Фаворити
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0">Моите резервации</h2>
                <span class="badge bg-light text-dark border p-2">Общо: @ViewBag.TotalCount</span>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">Все още нямате резервации</h4>
                        <p class="text-muted">Намерете следващото си приключение още сега!</p>
                        <a href="/" class="btn btn-success px-4 rounded-pill">Разгледай обекти</a>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var res in Model)
                    {
                        var resDate = res.ReservationDate ?? DateOnly.FromDateTime(DateTime.Now);
                        var resTime = res.ReservationTime ?? new TimeOnly(0, 0);
                        var reservationFullDateTime = resDate.ToDateTime(resTime);
                        var isPast = reservationFullDateTime < DateTime.Now;   
                        <div class="col-12">
                            <div class="card border-0 shadow-sm hover-shadow transition @(isPast ? "opacity-75" : "")">
                                <div class="card-body d-flex align-items-center p-3">
                                    <div class="flex-shrink-0 bg-light rounded p-3 text-center" style="min-width: 80px;">
                                        @if (res.ReservationDate.HasValue)
                                        {
                                            <div class="small fw-bold text-uppercase @(isPast ? "text-muted" : "text-success")">
                                                @res.ReservationDate.Value.ToString("MMM")
                                            </div>
                                            <div class="fs-4 fw-bold">@res.ReservationDate.Value.Day</div>
                                        }
                                    </div>
                                    <div class="flex-grow-1 ms-4">
                                        <h5 class="mb-1 fw-bold">
                                            <a asp-controller="Reservation" asp-action="Index" asp-route-id="@res.PlaceId" 
                                               class="text-decoration-none text-dark hover-success">
                                                @res.Place?.Name
                                            </a>
                                        </h5>
                                        <div class="text-muted small">
                                            <i class="bi bi-clock me-1"></i> @res.ReservationTime?.ToString("HH:mm") ч.
                                            <span class="mx-2">|</span>
                                            <i class="bi bi-geo-alt me-1"></i> @res.Place?.City?.Name
                                        </div>
                                    </div>
                                    <div class="ms-auto text-end">
                                        @if (isPast)
                                        {
                                            <span class="badge rounded-pill bg-secondary px-3">Изминала</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-success px-3">Предстояща</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="MyReservations" asp-route-page="@(ViewBag.CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>
                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link @(i == ViewBag.CurrentPage ? "bg-success border-success" : "text-success")"
                                           asp-action="MyReservations" asp-route-page="@i">@i</a>
                                    </li>
                                }
                                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="MyReservations" asp-route-page="@(ViewBag.CurrentPage + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .hover-success:hover {
        color: #28a745 !important; /* Твоят зелен цвят */
        text-decoration: underline !important;
    }
</style>