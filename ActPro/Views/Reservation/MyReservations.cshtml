@model IEnumerable<ActPro.DAL.Entities.Reservation>
@{
    ViewData["Title"] = "Моите резервации";
}

<div class="container mt-4 min-vh-100">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <div>
                    <h2 class="fw-bold mb-1">Моите резервации</h2>
                    <p class="text-muted small mb-0">Управлявайте вашите предстоящи и изминали посещения
                        <strong> Общо: @ViewBag.TotalCount</strong>.
                    </p>
                </div>
                <div class="btn-group">
                    <a asp-action="MyReservations" asp-route-filter="all"
                       class="btn btn-sm rounded-pill m-1 @(ViewBag.Filter == "all" || ViewBag.Filter == null ? "btn-primary" : "btn-outline-primary")">Всички</a>

                    <a asp-action="MyReservations" asp-route-filter="upcoming"
                       class="btn btn-sm rounded-pill m-1 @(ViewBag.Filter == "upcoming" ? "btn-success" : "btn-outline-success")">Предстоящи</a>

                    <a asp-action="MyReservations" asp-route-filter="past"
                       class="btn btn-sm rounded-pill m-1 @(ViewBag.Filter == "past" ? "btn-dark" : "btn-outline-dark")">Изминали</a>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="card border-0 shadow-sm text-center py-5 rounded-4">
                    <div class="card-body">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-calendar-x text-muted fs-1"></i>
                        </div>
                        <h4 class="fw-bold">Все още нямате резервации</h4>
                        <p class="text-muted mx-auto" style="max-width: 300px;">Вашата история е празна. Открийте нови интересни места и направете първата си резервация.</p>
                        <a href="/" class="btn btn-success px-4 rounded-pill shadow-sm">Разгледай обекти</a>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3" id="reservationsContainer">
                    @foreach (var res in Model)
                    {
                        var resDate = res.ReservationDate ?? DateOnly.FromDateTime(DateTime.Now);
                        var resTime = res.ReservationTime ?? new TimeOnly(0, 0);
                        var reservationFullDateTime = resDate.ToDateTime(resTime);
                        var isPast = reservationFullDateTime < DateTime.Now;

                        <div class="col-12 res-card" data-status="@(isPast ? "past" : "upcoming")">
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative transition-hover @(isPast ? "bg-light-subtle" : "")">
                                <div class="position-absolute start-0 top-0 bottom-0 @(isPast ? "bg-secondary" : "bg-success")" style="width: 10px;"></div>

                                <div class="card-body p-0">
                                    <div class="row g-0 align-items-center">
                                        <div class="col-md-2 d-none d-md-block">
                                            @if (res.Place?.PlaceImages?.Any() == true)
                                            {
                                                <img src="@(res.Place.PlaceImages?.OrderBy(i => i.Id).FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/400x220")"
                                                     class="img-fluid search-card-img" alt="@res.Place?.Name">
                                            }
                                            else
                                            {
                                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 120px;">
                                                    <i class="bi bi-image text-muted fs-2"></i>
                                                </div>
                                            }
                                        </div>

                                        <div class="col-3 col-md-1 text-center py-3 border-end">
                                            <div class="small fw-bold text-uppercase @(isPast ? "text-muted" : "text-success")">
                                                @res.ReservationDate?.ToString("MMM")
                                            </div>
                                            <div class="fs-3 fw-bold lh-1">@res.ReservationDate?.Day</div>
                                            <div class="text-muted" style="font-size: 0.7rem;">@res.ReservationDate?.Year</div>
                                        </div>

                                        <div class="col-6 col-md-6 ps-4">
                                            <h5 class="mb-1 fw-bold">
                                                <a asp-controller="Reservation" asp-action="Index" asp-route-id="@res.PlaceId"
                                                   class="text-decoration-none text-dark hover-success">
                                                    @res.Place?.Name
                                                </a>
                                            </h5>
                                            <div class="d-flex flex-wrap gap-2 text-muted small">
                                                <span><i class="bi bi-clock me-1 text-success"></i>@res.ReservationTime?.ToString("HH:mm") ч.</span>
                                                <span><i class="bi bi-geo-alt me-1 text-danger"></i>@res.Place?.City?.Name</span>
                                            </div>
                                        </div>

                                        <div class="col-3 col-md-3 text-end pe-4">
                                            @if (isPast)
                                            {
                                                <span class="badge rounded-pill bg-light text-secondary border px-3 mb-2">Изминала</span>
                                                <br />
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 mb-2">Предстояща</span>
                                                <br />
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger rounded-pill px-3 mt-2 shadow-sm btn-cancel-custom"
                                                        onclick="confirmCancel(@res.Id)">
                                                    <i class="bi bi-x-circle me-1"></i> Откажи
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-5">
                        <ul class="pagination pagination-sm justify-content-center">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-circle mx-1" asp-action="MyReservations" asp-route-page="@(ViewBag.CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link rounded-circle mx-1 @(i == ViewBag.CurrentPage ? "bg-success border-success text-white" : "text-dark")"
                                       asp-action="MyReservations" asp-route-page="@i" asp-route-filter="@ViewBag.Filter">@i</a>
                                </li>
                            }
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link rounded-circle mx-1" asp-action="MyReservations" asp-route-page="@(ViewBag.CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

@section Scripts 
{
    <script>
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() 
            {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active', 'btn-success', 'btn-dark'));
                this.classList.add('active');

                const filter = this.getAttribute('data-filter');
                document.querySelectorAll('.res-card').forEach(card => {
                    if (filter === 'all' || card.getAttribute('data-status') === filter) 
                    {
                        card.style.display = 'block';
                    }
                    else 
                    {
                        card.style.display = 'none';
                    }
                });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmCancel(id) 
        {
            Swal.fire({
                title: 'Сигурни ли сте?',
                text: "Искате ли да откажете тази резервация?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Да, откажи я!',
                cancelButtonText: 'Отказ'
            }).then((result) => {
                if (result.isConfirmed)
                {
                    $.ajax({
                        url: '/Reservation/Cancel',
                        type: 'POST',
                        data: {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response)
                        {
                            if (response.success) 
                            {
                                Swal.fire(
                                    'Отказана!',
                                    response.message,
                                    'success'
                                ).then(() => {
                                    location.reload();
                                });
                            } 
                            else 
                            {
                                Swal.fire('Грешка!', response.message, 'error');
                            }
                        },
                        error: function () 
                        {
                            Swal.fire('Грешка!', 'Възникна проблем при комуникацията със сървъра.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}
@section Styles 
{
    <link rel="stylesheet" href="~/css/reservation.css" asp-append-version="true" />
}