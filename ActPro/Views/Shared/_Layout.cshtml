@using ActPro
@using ActPro.DAL
@using ActPro.DAL.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user != null ? user.FirstName : User.Identity.Name;
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ActPro - @ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/ActPro.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="ActPro Logo" style="height: 40px;" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-shield-lock"></i> АДМИН ПАНЕЛ
                                </a>
                            </li>
                        }
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item d-flex align-items-center profile-dropdown">
                                <a class="nav-link d-flex align-items-center py-0" asp-area="" asp-controller="Account" asp-action="Index">
                                    @if (user != null && !string.IsNullOrEmpty(user.ProfilePicturePath))
                                    {
                                        <img src="/images/profiles/@user.ProfilePicturePath"
                                             class="rounded-circle shadow-sm border"
                                             style="width: 45px; height: 45px; object-fit: cover;"
                                             alt="Profile" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-circle fs-1 text-dark"></i>
                                    }
                                </a>
                                <div class="dropdown">
                                    <a class="nav-link" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    </a>
                                    <ul class="dropdown-menu shadow border-0" aria-labelledby="profileDropdown">
                                        <li><h6 class="dropdown-header">Здравей, @displayName!</h6></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Index"><i class="bi bi-person me-2"></i>Профил</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Reservation" asp-action="MyReservations"><i class="bi bi-calendar-check me-2"></i>Мои резервации</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Index"><i class="bi bi-star me-2"></i>Фаворити</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Search" asp-action="Index"><i class="bi bi-bicycle me-2"></i>Занимания</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-area ="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                                <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">
                                                    <i class="bi bi-box-arrow-right me-2"></i>Изход
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Account" asp-action="Login">Вход</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-success px-4 fw-bold shadow-sm" asp-area="" asp-controller="Account" asp-action="Register">Регистрация</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted bg-white py-3">
        <div class="container text-center">
            &copy; 2025 - ActPro - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function() 
        {
                $('.admin-table').DataTable({
                    "order": [], 
                    "ordering": true,
                    "pageLength": 10,
                    "responsive": true,
                    "columnDefs": [
                        {
                            "targets": 'no-sort',
                            "orderable": false 
                        }
                    ],
                    "language": {
                        "url": "//cdn.datatables.net/plug-ins/1.10.24/i18n/Bulgarian.json"
                    }
                });
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-left",
                "timeOut": "2500"
            };
            var success = '@(TempData["Success"] ?? TempData["SuccessMessage"])';
            var error = '@(TempData["Error"] ?? TempData["ErrorMessage"])';
            var info = '@TempData["Info"]';

            if (success) toastr.success(success);
            if (error) toastr.error(error);
            if (info) toastr.info(info);

            $(document).on('click', '.confirm-action', function (e) 
            {
                e.preventDefault();
                var form = $(this).closest('form');
                var message = $(this).attr('data-message') || "Сигурни ли сте?";

                Swal.fire({
                    title: 'Потвърждение',
                    text: message,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Да',
                    cancelButtonText: 'Отказ'
                }).then((result) => {
                    if (result.isConfirmed) 
                    {
                        form.submit();
                    }
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>