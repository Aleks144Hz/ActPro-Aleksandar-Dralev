@using ActPro
@using ActPro.DAL
@using ActPro.DAL.Entities
@using ActPro.Helpers
@using Microsoft.AspNetCore.Identity
@using static ActPro.Domain.DomainResources
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var area = ViewContext.RouteData.Values["area"]?.ToString();
    bool hideFooter = area == "Admin" || area == "Owner" || controller == "Account" || controller == "Owner" || action == "Confirmation";
    var displayName = user != null ? user.FirstName : User.Identity.Name;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en";
}
<!DOCTYPE html>
<html lang="@(isEnglish ? "en" : "bg")">
<head>
    <link rel="icon" type="image/x-icon" href="~/Logo.png">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ActPro - @ViewData["Title"]</title>
    
    @{
        var seoTitle = ViewData["SeoTitle"] as string ?? (isEnglish ? "ActPro - Book sports facilities in Bulgaria" : "ActPro - Резервирай спортни площадки и съоръжения в България");
        var seoDescription = ViewData["SeoDescription"] as string ?? (isEnglish ? "ActPro is a platform for online reservations of sports grounds, fitness centers, tennis courts, pools and other sports facilities in Bulgaria. Book easily online!" : "ActPro е платформа за онлайн резервации на спортни площадки, фитнеси, тенис кортове, басейни и други спортни съоръжения в цяла България. Лесно и бързо резервирай онлайн!");
        var seoKeywords = ViewData["SeoKeywords"] as string ?? (isEnglish ? "sports facilities, reservations, fitness, tennis, swimming, volleyball, basketball, football, sports, Bulgaria" : "спортни площадки, резервации, фитнес, тенис, плуване, волейбол, баскетбол, футбол, спорт, България");
        var seoImage = ViewData["SeoImage"] as string ?? "/Logo.png";
        var seoUrl = ViewData["SeoUrl"] as string ?? Context.Request.Scheme + "://" + Context.Request.Host + Context.Request.Path;
    }
    
    <meta name="description" content="@seoDescription" />
    <meta name="keywords" content="@seoKeywords" />
    <meta name="author" content="ActPro" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="Bulgarian" />
    <meta name="revisit-after" content="7 days" />   
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@seoUrl" />
    <meta property="og:title" content="@seoTitle" />
    <meta property="og:description" content="@seoDescription" />
    <meta property="og:image" content="@seoImage" />
    <meta property="og:site_name" content="ActPro" />
    <meta property="og:locale" content="@(isEnglish ? "en_US" : "bg_BG")" />
    <link rel="canonical" href="@seoUrl" />   
    <link rel="alternate" hreflang="bg" href="@seoUrl" />
    <link rel="alternate" hreflang="en" href="@seoUrl" />
    <link rel="alternate" hreflang="x-default" href="@seoUrl" />
    
    <link rel="icon" type="image/x-icon" href="~/Logo.png">
    <link rel="apple-touch-icon" href="~/Logo.png" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/ActPro.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="fixed-top shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/Actpro Logo.png" class="img-fluid" alt="ActPro Logo" style="height: 55px; width:auto; object-fit: contain;" />
                </a>
                <div class="d-flex align-items-center">
                    <div class="d-lg-none me-3">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a asp-controller="Account" asp-action="Index" class="d-flex align-items-center text-decoration-none shadow-none">
                                @if (user != null && !string.IsNullOrEmpty(user.ProfilePicturePath))
                                {
                                    <img src="/images/profiles/@user.ProfilePicturePath" class="rounded-circle border" style="width: 35px; height: 35px; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-person-circle text-dark d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-size: 35px; line-height: 1;"></i>
                                }
                            </a>
                        }
                        else
                        {
                            <div class="d-flex align-items-center d-lg-none me-2">
                                <a class="btn btn-success fw-bold shadow-sm px-4 py-2" style="font-size: 0.87rem; border-radius: 8px;" asp-controller="Account" asp-action="Login">@DomainResources.Login</a>
                            </div>
                        }
                    </div>
                    <button class="menu-toggle-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
                <div class="collapse navbar-collapse d-none d-lg-flex" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-1 gap-3">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom nav-link-lg" asp-area="" asp-controller="Home" asp-action="News">
                                <i class="bi bi-megaphone-fill text-success"></i> @DomainResources.News
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom nav-link-lg" asp-area="" asp-controller="Home" asp-action="Support">
                                <i class="bi bi-question-circle text-success"></i> @DomainResources.HelpCenter
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom nav-link-lg" asp-area="" asp-controller="Owner" asp-action="Index">
                                <i class="bi bi-plus-circle me-1 text-success"></i> @DomainResources.AddYourPlace
                            </a>
                        </li>
                    </ul>
                    <form asp-area="" asp-controller="Home" asp-action="SetLanguage"
                          asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" method="post" class="lang-toggle-form">
                        <input type="hidden" name="culture" id="lang-toggle-input" value="" />
                        <div class="lang-toggle" onclick="toggleLang()">
                            <span class="lang-toggle-opt @((System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "bg") ? "active" : "")">БГ</span>
                            <span class="lang-toggle-opt @((System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en") ? "active" : "")">EN</span>
                        </div>
                    </form>
                    <ul class="navbar-nav ms-3 align-items-center">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold nav-link-custom" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-shield-lock-fill"></i> @DomainResources.AdminPanel
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Owner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold nav-link-custom" asp-area="Owner" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-currency-euro"></i> @DomainResources.BusinessPanel
                                </a>
                            </li>
                        }
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item d-flex align-items-center profile-dropdown">
                                <a class="nav-link d-flex align-items-center py-0" asp-area="" asp-controller="Account" asp-action="Index">
                                    @if (user != null && !string.IsNullOrEmpty(user.ProfilePicturePath))
                                    {
                                        <img src="/images/profiles/@user.ProfilePicturePath"
                                             class="rounded-circle shadow-sm border"
                                             style="width: 45px; height: 45px; object-fit: cover;"
                                             alt="Profile" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-circle fs-1 text-dark"></i>
                                    }
                                </a>
                                <div class="dropdown">
                                    <a class="nav-link" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    </a>
                                    <ul class="dropdown-menu shadow border-0" aria-labelledby="profileDropdown">
                                        <li><h6 class="dropdown-header">@DomainResources.Hello, @displayName!</h6></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Index"><i class="bi bi-person me-2"></i>@DomainResources.Profile</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Reservation" asp-action="MyReservations"><i class="bi bi-calendar-check me-2"></i>@DomainResources.Reservations</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Reservation" asp-action="MyReviews"><i class="bi bi-chat-left-text me-2"></i>@DomainResources.Reviews</a></li>
                                        <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Settings"><i class="bi bi-gear me-2"></i>@DomainResources.Settings</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                                <button type="submit" class="dropdown-item text-danger border-0 bg-transparent">
                                                    <i class="bi bi-box-arrow-right me-2"></i>@DomainResources.Logout
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link nav-link-custom nav-link-lg" asp-area="" asp-controller="Account" asp-action="Login">@DomainResources.Login</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-success px-4 fw-bold shadow-sm" asp-area="" asp-controller="Account" asp-action="Register">@DomainResources.Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        <div class="offcanvas offcanvas-end custom-mobile-menu border-0" tabindex="-1" id="mobileMenu">
            <div class="offcanvas-body p-0" style="overflow-y: auto;">
                <div class="list-group list-group-flush side-menu-list">

                    <a asp-area="" asp-controller="Home" asp-action="Index" class="list-group-item side-item">
                        <span class="icon-wrap"><i class="bi bi-house-door"></i></span> @DomainResources.Home
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="News" class="list-group-item side-item">
                        <span class="icon-wrap"><i class="bi bi-newspaper"></i></span> @DomainResources.News
                    </a>
                    <a asp-area="" asp-controller="Home" asp-action="Support" class="list-group-item side-item">
                        <span class="icon-wrap"><i class="bi bi-question-circle"></i></span> @DomainResources.HelpCenter
                    </a>
                    <a asp-area="" asp-controller="Owner" asp-action="Index" class="list-group-item side-item">
                        <span class="icon-wrap"><i class="bi bi-plus-circle"></i></span> @DomainResources.AddPlace
                    </a>
                    <div class="side-item" onclick="document.getElementById('langFormMobile').submit();" style="cursor: pointer;">
                        <div class="icon-wrap">
                            <i class="bi bi-translate"></i> </div>
                        <span>@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "bg" ? "English" : "Български")</span>
                    </div>

                    <form id="langFormMobile" asp-area="" asp-controller="Home" asp-action="SetLanguage" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" method="post" style="display: none;">
                        <input type="hidden" name="culture" value="@(System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "bg" ? "en" : "bg")" />
                    </form>

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a asp-area="" asp-controller="Reservation" asp-action="MyReservations" class="list-group-item side-item">
                            <span class="icon-wrap text-primary"><i class="bi bi-calendar-check"></i></span> @DomainResources.Reservations
                        </a>
                        <a asp-area="" asp-controller="Reservation" asp-action="MyReviews" class="list-group-item side-item">
                            <span class="icon-wrap text-primary"><i class="bi bi-chat-left-text"></i></span> @DomainResources.Reviews
                        </a>
                        <a asp-area="" asp-controller="Account" asp-action="Settings" class="list-group-item side-item">
                            <span class="icon-wrap text-primary"><i class="bi bi-gear"></i></span> @DomainResources.Settings
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="list-group-item side-item admin-item">
                                <span class="icon-wrap text-danger"><i class="bi bi-shield-lock"></i></span> @DomainResources.AdminPanel
                            </a>
                        }
                        @if (User.IsInRole("Owner"))
                        {
                            <a asp-area="Owner" asp-controller="Dashboard" asp-action="Index" class="list-group-item side-item owner-item">
                                <span class="icon-wrap text-success"><i class="bi bi-currency-euro"></i></span> @DomainResources.BusinessPanel
                            </a>
                        }

                        <div class="px-4 mt-4 pb-4">
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-logout-custom w-100 shadow-sm bg-danger text-white">
                                    <i class="bi bi-box-arrow-right me-2 text-white"></i> @DomainResources.Logout
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </header>
    @if (User.Identity.IsAuthenticated)
    {
        bool isAccountPage = controller == "Account" && (action == "Index" || action == "Settings") || controller == "Reservation" && (action == "MyReservations" || action == "MyReviews");

        if (isAccountPage)
        {
            var userManager = Context.RequestServices.GetRequiredService<UserManager<ApplicationUser>>();
            if (user != null && !user.EmailConfirmed)
            {
                <div class="alert alert-warning text-center m-0 border-0 rounded-0 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @DomainResources.EmailNotConfirmedText
                    <a asp-controller="Account" asp-action="ResendConfirmation" asp-route-email="@user.Email" class="alert-link ms-2 text-decoration-underline">
                        @DomainResources.ResendConfirmationEmail
                    </a>
                </div>
            }
        }
    }
    <main role="main">
        @RenderBody()
    </main>
    @if (!hideFooter)
    {
        <footer class="site-footer-rich">
            <div class="container">
                <div class="row g-4 pb-5">
                    <div class="col-lg-4 col-md-12">
                        <div class="footer-brand-wrapper">
                            <h5 class="footer-title">ActPro</h5>
                            <p class="footer-text">@DomainResources.FindAndBookSports</p>
                        </div>
                        <div class="footer-socials">
                            <a href="https://www.instagram.com/actpro.bg/" class="social-icon ig"><i class="bi bi-instagram text-success"></i></a>
                            <a href="https://www.facebook.com/profile.php?id=61588195074502" class="social-icon yt"><i class="bi bi-facebook text-success"></i></a>
                            <a href="https://www.tiktok.com/@@actpro" class="social-icon tt"><i class="bi bi-tiktok text-success"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6 d-flex flex-column align-items-lg-center">
                        <h6 class="footer-subtitle-manage text-start">@DomainResources.Maintenance</h6>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <a asp-controller="Home" asp-action="Support" class="footer-link">@DomainResources.HelpCenter</a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="Home" asp-action="Terms" class="footer-link">@DomainResources.TermsOfService</a>
                            </li>
                            <li class="mb-2">
                                <a asp-controller="Home" asp-action="Privacy" class="footer-link">@DomainResources.PrivacyPolicy</a>
                            </li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <h6 class="footer-subtitle">@DomainResources.Contacts</h6>
                        <div class="footer-contact-info">
                            <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(DomainResources.CompanyAddressUrl)" target="_blank" class="contact-item text-decoration-none">
                                <div class="icon-box"><i class="bi bi-geo-alt-fill"></i></div>
                                <span>@DomainResources.Address</span>
                            </a>
                            <a href="mailto:contact@actprobg.com" class="contact-item text-decoration-none">
                                <div class="icon-box"><i class="bi bi-envelope-fill"></i></div>
                                <span>contact@actprobg.com</span>
                            </a>
                            <a href="tel:+359897734888" class="text-decoration-none text-reset">
                                <div class="icon-box"><i class="bi bi-telephone-fill"></i></div>
                                <span>+359 897 734 888</span>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="footer-bottom-divider"></div>
                <div class="footer-bottom py-4">
                    <div class="row align-items-center">
                        <div class="col-md-6 text-center text-md-start">
                            <p class="copyright mb-0">&copy; 2026 <strong>ActPro</strong>. @DomainResources.Copyright</p>
                        </div>
                        <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                            <p class="authors mb-0">
                                @DomainResources.CreatedForNOIT
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        var confirmDialogTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.ConfirmDialogTitle));
        var confirmYes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.ConfirmYes));
        var confirmCancel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.ConfirmCancel));
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function(){
                var langUrl = '@System.Threading.Thread.CurrentThread.CurrentUICulture.Name' === 'en' 
                    ? '//cdn.datatables.net/plug-ins/1.10.24/i18n/English.json'
                    : '//cdn.datatables.net/plug-ins/1.10.24/i18n/Bulgarian.json';
                $('.admin-table').DataTable({
                    "order": [],
                    "ordering": true,
                    "pageLength": 10,
                    "responsive": true,
                    "columnDefs": [
                        {
                            "targets": 'no-sort',
                            "orderable": false
                        }
                    ],
                    "language": {
                        "url": langUrl
                    }
                });
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-left",
                "timeOut": "2500"
            };
            var success = '@(TempData["Success"] ?? TempData["SuccessMessage"])';
            var error = '@(TempData["Error"] ?? TempData["ErrorMessage"])';
            var info = '@TempData["Info"]';

            if (success) toastr.success(success);
            if (error) toastr.error(error);
            if (info) toastr.info(info);

            $(document).on('click', '.confirm-action', function (e){
                e.preventDefault();
                var form = $(this).closest('form');
                var message = $(this).attr('data-message') || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.AreYouSure));

                Swal.fire({
                    title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.Confirmation)),
                    text: message,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#198754',
                    cancelButtonColor: '#d33',
                    confirmButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.Yes)),
                    cancelButtonText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.Cancel))
                }).then((result) => {
                    if (result.isConfirmed){
                        form.submit();
                    }
                });
            });
        });
        document.addEventListener('DOMContentLoaded', function (){
            const menu = document.getElementById('mobileMenu');

            menu.addEventListener('show.bs.offcanvas', function (){
                document.body.classList.add('offcanvas-open');
            });

            menu.addEventListener('hidden.bs.offcanvas', function (){
                document.body.classList.remove('offcanvas-open');
            });

            document.addEventListener('touchmove', function (e){
                if (document.body.classList.contains('offcanvas-open')){
                    if (!e.target.closest('#mobileMenu')){
                        e.preventDefault();
                    }
                }
            }, { passive: false });
        });
        
        function toggleLang() {
            const current = '@System.Threading.Thread.CurrentThread.CurrentUICulture.Name';
            document.getElementById('lang-toggle-input').value = current === 'bg' ? 'en' : 'bg';
            document.querySelector('.lang-toggle-form').submit();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>