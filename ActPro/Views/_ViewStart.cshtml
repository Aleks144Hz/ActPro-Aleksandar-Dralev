@{
    Layout = "_Layout";
    
    // Default SEO values
    ViewData["SeoTitle"] = ViewData["SeoTitle"] ?? "ActPro - Резервирай спортни площадки в България";
    ViewData["SeoDescription"] = ViewData["SeoDescription"] ?? "ActPro е водеща платформа за онлайн резервации на спортни площадки, фитнеси, тенис кортове, басейни и други спортни съоръжения в цяла България. Лесно и бързо резервирай онлайн!";
    ViewData["SeoKeywords"] = ViewData["SeoKeywords"] ?? "спортни площадки, резервации, фитнес, тенис, плуване, волейбол, баскетбол, футбол, спорт, България";
    ViewData["SeoImage"] = ViewData["SeoImage"] ?? "/Logo.png";
}
