@using ActPro.Models
@model ActPro.Models.HomeViewModel
@{
    ViewData["Title"] = "Начало";
}

<div class="container-fluid p-0">
    <section class="search-bar py-5 bg-primary text-white shadow-sm">
        <div class="container">
            <div class="search-container-styled">
                <form asp-controller="Search" asp-action="Index" method="get" id="mainSearchForm">
                    <div class="row align-items-center">
                        <div class="col-md-5 position-relative divider-end">
                            <label class="search-label-small">Населено място</label>
                            <div class="input-wrapper">
                                <i class="fas fa-map-marker-alt input-icon"></i>
                                <input type="text"
                                       class="form-control form-control-custom"
                                       id="cityInput"
                                       name="city"
                                       placeholder="Избери или въведи град"
                                       autocomplete="off"
                                       required
                                       oninvalid="this.setCustomValidity('Моля, изберете населено място!')"
                                       oninput="this.setCustomValidity('')">
                            </div>
                            <div id="cityList" class="custom-dropdown-list"></div>
                        </div>
                        <div class="col-md-5 position-relative">
                            <label class="search-label-small">Какво ще спортувате?</label>
                            <div class="input-wrapper">
                                <i class="fas fa-running input-icon"></i>
                                <input type="text"
                                       class="form-control form-control-custom"
                                       id="activityInput"
                                       name="activity"
                                       placeholder="Избери или въведи активност"
                                       autocomplete="off">
                            </div>
                            <div id="activityList" class="custom-dropdown-list"></div>
                        </div>
                        <div class="col-md-2 text-center">
                            <button type="submit" class="btn btn-success w-100 fw-bold py-2 shadow-sm" style="border-radius: 25px; height: 50px;">
                                ТЪРСИ
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </section>
    <main class="container my-5">
        <h2 class="mb-4 text-center">Топ обекти с най-висок рейтинг</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var place in Model.TopPlaces)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                        <img src="@(place.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/300x200")"
                             class="card-img-top" alt="@place.Name" style="height: 200px; object-fit: cover;">

                        <div class="card-body">
                            <h5 class="card-title fw-bold">@place.Name</h5>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt"></i> @place.City?.Name
                            </p>
                            <p class="card-text text-warning fw-bold">Рейтинг: ⭐ @place.Rating</p>
                            <a asp-controller="Reservation" asp-action="Index" asp-route-id="@place.Id"
                               class="btn btn-primary w-100 rounded-pill">Виж детайли</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}
<script>
       const citiesData = @Html.Raw(Json.Serialize(Model.CityNames));
    const activitiesData = @Html.Raw(Json.Serialize(Model.ActivityNames));

    function setupAutocomplete(inputId, listId, dataArray, iconClass) 
    {
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);

        const popularItemsMap = 
        {
            'cityInput': ["София", "Пловдив", "Варна", "Бургас", "Благоевград"],
            'activityInput': ["Футбол", "Волейбол", "Баскетбол", "Тенис", "Фитнес"]
        };

        const labelsMap = 
        {
            'cityInput': "Известни локации",
            'activityInput': "Популярни активности"
        };

        function renderList(items) 
        {
            list.innerHTML = '';
            const inputValue = input.value.toLowerCase().trim();
            if (inputValue === '') 
            {
                const label = document.createElement('div');
                label.className = 'dropdown-header-custom';
                label.innerHTML = `<strong>${labelsMap[inputId]}</strong>`;
                list.appendChild(label);

                popularItemsMap[inputId].forEach(item => {
                    list.appendChild(createItemDiv(item));
                });

                const divider = document.createElement('div');
                divider.className = 'dropdown-header-custom mt-2';
                divider.innerHTML = `<strong>Всички предложения</strong>`;
                list.appendChild(divider);
            }

            if (items.length === 0 && inputValue !== '') 
            {
                list.style.display = 'none';
                return;
            }
            items.forEach(item => {
                list.appendChild(createItemDiv(item));
            });
            list.style.display = 'block';
        }
        function createItemDiv(item) 
        {
            const div = document.createElement('div');
            div.className = 'dropdown-item-custom';
            div.innerHTML = `<i class="${iconClass}"></i> ${item}`;
            const activityIcons = {
                    'Айкидо': 'fas fa-user-ninja',
                    'Акробатика': 'fas fa-child',
                    'Бадминтон': 'fas fa-table-tennis',
                    'Балет': 'fas fa-shoe-prints',
                    'Баскетбол': 'fas fa-basketball-ball',
                    'Бейзбол': 'fas fa-baseball-ball',
                    'Билярд': 'fas fa-circle',
                    'Бокс': 'fas fa-fist-raised',
                    'Борба': 'fas fa-hand-rock',
                    'Боулинг': 'fas fa-bowling-ball',
                    'Волейбол': 'fas fa-volleyball-ball',
                    'Гимнастика': 'fas fa-walking',
                    'Голф': 'fas fa-golf-ball',
                    'Дартс': 'fas fa-bullseye',
                    'Джудо': 'fas fa-user-ninja',
                    'Йога': 'fas fa-spa',
                    'Карате': 'fas fa-hand-rock',
                    'Конна езда': 'fas fa-horse',
                    'Крикет': 'fas fa-baseball-ball',
                    'Лека атлетика': 'fas fa-running',
                    'ММА': 'fas fa-fist-raised',
                    'Падел': 'fas fa-table-tennis',
                    'Плуване': 'fas fa-swimmer',
                    'Ски': 'fas fa-skiing',
                    'Стрелба': 'fas fa-crosshairs',
                    'Таекуондо': 'fas fa-user-ninja',
                    'Танци': 'fas fa-music',
                    'Тенис': 'fas fa-table-tennis',
                    'Тенис на маса': 'fas fa-table-tennis',
                    'Фехтовка': 'fas fa-pen-nib',
                    'Фитнес': 'fas fa-dumbbell',
                    'Футбол': 'fas fa-futbol',
                    'Хандбал': 'fas fa-volleyball-ball'
             };
            const currentIcon = activityIcons[item] || iconClass;
            div.innerHTML = `<i class="${currentIcon}"></i> ${item}`;
            div.addEventListener('click', function() 
            {
                input.value = item;
                input.setCustomValidity('');
                list.style.display = 'none';
                input.focus();
            });
            return div;
        }
        function handleFilter() 
        {
            const text = input.value.toLowerCase().trim();
            const filtered = dataArray
                .filter(item => item.toString().toLowerCase().trim().startsWith(text))
                .sort();
            renderList(filtered);
        }
        input.addEventListener('focus', handleFilter);
        input.addEventListener('input', handleFilter);
        document.addEventListener('click', function(e)
        {
            if (e.target !== input && !list.contains(e.target)) 
            {
                list.style.display = 'none';
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function() 
    {
        setupAutocomplete('cityInput', 'cityList', citiesData, 'fas fa-map-marker-alt');
        setupAutocomplete('activityInput', 'activityList', activitiesData, 'fas fa-running');
    });
</script>