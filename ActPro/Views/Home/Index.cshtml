@using ActPro.Models
@model ActPro.Models.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid p-0">
    <section class="search-bar py-5 bg-primary text-white shadow-sm">
        <div class="container">
            <form asp-controller="Search" asp-action="Index" method="get" class="row g-3 justify-content-center">
                <div class="col-md-4">
                    <label class="form-label">Населено място</label>
                    <input class="form-control" list="citiesOptions" name="city" placeholder="Избери или въведи град...">
                    <datalist id="citiesOptions">
                        @foreach (var cityName in Model.CityNames)
                        {
                            <option value="@cityName"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Активност</label>
                    <input class="form-control" list="activitiesOptions" name="activity" placeholder="Избери или въведи активност...">
                    <datalist id="activitiesOptions">
                        @foreach (var actName in Model.ActivityNames)
                        {
                            <option value="@actName"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-warning w-100 fw-bold">ТЪРСИ</button>
                </div>
            </form>
        </div>
    </section>

    <main class="container my-5">
        <h2 class="mb-4 text-center">Топ обекти с най-висок рейтинг</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var place in Model.TopPlaces)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                        <img src="@(place.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/300x200")"
                             class="card-img-top" alt="@place.Name" style="height: 200px; object-fit: cover;">

                        <div class="card-body">
                            <h5 class="card-title fw-bold">@place.Name</h5>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-geo-alt"></i> @place.City?.Name
                            </p>
                            <p class="card-text text-warning fw-bold">Рейтинг: ⭐ @place.Rating</p>
                            <a asp-controller="Reservation" asp-action="Index" asp-route-id="@place.Id"
                               class="btn btn-primary w-100 rounded-pill">Виж детайли</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>
</div>

<style>
    .dropdown:hover .dropdown-menu {
        display: block;
        margin-top: 0;
    }

    .search-bar {
        border-radius: 8px;
        margin: 0 1rem;
    }
</style>