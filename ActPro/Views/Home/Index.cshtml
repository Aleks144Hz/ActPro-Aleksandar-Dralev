@using ActPro.Models
@model ActPro.Models.HomeViewModel
@{
    ViewData["Title"] = "Начало";
}
<div class="container-fluid p-0">
    <main>
        <section class="py-5 position-relative">
            <div class="container position-relative z-index-2">
                <div class="text-center mb-4 fade-in-down">
                    <h1 class="fw-bold text-dark">Намери своето място за спорт</h1>
                    <p class="text-muted">Лесно, бързо и удобно резервиране по всяко време.</p>
                </div>
                <div class="search-container-styled fade-in-up">
                    <form asp-controller="Search" asp-action="Index" method="get" id="mainSearchForm">
                        <div class="row align-items-center">
                            <div class="col-md-5 position-relative divider-end">
                                <label class="search-label-small">Населено място</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt input-icon"></i>
                                    <input type="text"
                                           class="form-control form-control-custom"
                                           id="cityInput"
                                           name="city"
                                           placeholder="Избери или въведи град"
                                           autocomplete="off"
                                           required
                                           oninvalid="this.setCustomValidity('Моля, изберете населено място!')"
                                           oninput="this.setCustomValidity('')">
                                </div>
                                <div id="cityList" class="custom-dropdown-list"></div>
                            </div>
                            <div class="col-md-5 position-relative">
                                <label class="search-label-small">Какво ще спортувате?</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-running input-icon"></i>
                                    <input type="text"
                                           class="form-control form-control-custom"
                                           id="activityInput"
                                           name="activity"
                                           placeholder="Избери или въведи активност"
                                           autocomplete="off" />
                                </div>
                                <div id="activityList" class="custom-dropdown-list"></div>
                            </div>
                            <div class="col-md-2 text-center">
                                <button type="submit" class="btn btn-success w-100 fw-bold py-2 shadow-sm" style="border-radius: 25px; height: 50px;">
                                    ТЪРСИ
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-6 pr-lg-5">
                        <span class="text-success fw-bold text-uppercase small">Какво е ActPro?</span>
                        <h2 class="fw-bold mb-4">Твоят дигитален асистент за активен живот</h2>
                        <p class="text-muted lead">ActPro е иновативна платформа, която свързва ентусиастите със спортните бази. Нашата мисия е да премахнем бариерите пред спорта, като ви дадем достъп до стотици обекти само с няколко клика.</p>
                        <ul class="list-unstyled mt-4">
                            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Резервации в реално време</li>
                            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Голямо разнообразие от спортове</li>
                        </ul>
                    </div>
                    <div class="col-lg-6">
                        <img src="~/images/Digital.png" class="img-fluid">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-4">
            <div class="container">
                <h3 class="text-center mb-4 fw-bold">Популярни категории</h3>
                <div class="sports-category-grid">
                    @{
                        int GetCount(string key) => Model.SportCounts != null && Model.SportCounts.ContainsKey(key) ? Model.SportCounts[key] : 0;

                        var sportsList = new[] {
                                        new { Name = "Футбол", Icon = "fa-futbol", Class = "football" },
                                        new { Name = "Баскетбол", Icon = "fa-basketball-ball", Class = "basketball" },
                                        new { Name = "Волейбол", Icon = "fa-volleyball-ball", Class = "volleyball" },
                                        new { Name = "Тенис", Icon = "fa-table-tennis", Class = "tennis" },
                                        new { Name = "Фитнес", Icon = "fa-dumbbell", Class = "fitness" },
                                        new { Name = "Плуване", Icon = "fa-swimmer", Class = "swimming" }
                                        };
                    }

                    @foreach (var sport in sportsList)
                    {
                        <a asp-controller="Search" asp-action="Index" asp-route-activity="@sport.Name" class="sport-card @sport.Class">
                            <div class="sport-card-icon">
                                <i class="fas @sport.Icon"></i>
                            </div>
                            <div class="sport-card-info">
                                <span class="name">@sport.Name</span>
                                <span class="count">@GetCount(sport.Name) обекта</span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center flex-row-reverse">
                    <div class="col-lg-6 ps-lg-5">
                        <span class="text-success fw-bold text-uppercase small">Ползи</span>
                        <h2 class="fw-bold mb-4">С какво ви помагаме?</h2>
                        <p class="text-muted mb-4">Забравете за десетките телефонни обаждания, за да разберете дали тенис кортът е свободен. С нас пестите време и нерви:</p>

                        <div class="benefit-list">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-clock text-success me-3 fs-4"></i>
                                <span class="fw-bold">Бързина при резервация</span>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-wallet text-success me-3 fs-4"></i>
                                <span class="fw-bold">Сигурност на плащанията</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-mobile-alt text-success me-3 fs-4"></i>
                                <span class="fw-bold">Достъпност от всяко устройство</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <img src="~/images/Benefit.png" class="img-fluid">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <h2 class="mb-5 text-center fw-bold display-6">Топ обекти с най-висок рейтинг</h2>
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var place in Model.TopPlaces)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
                                <img src="@(place.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/300x200")"
                                     class="card-img-top" alt="@place.Name" style="height: 200px; object-fit: cover;">

                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@place.Name</h5>
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-geo-alt"></i> @place.City?.Name
                                    </p>
                                    <p class="card-text text-warning fw-bold">Рейтинг: ⭐ @place.Rating</p>
                                    <a asp-controller="Reservation" asp-action="Index" asp-route-id="@place.Id"
                                       class="btn btn-success w-100 fw-bold py-2 shadow-sm">Виж детайли</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-6">
                        <span class="text-success fw-bold text-uppercase small">Решения</span>
                        <h2 class="fw-bold mb-4">Проблемите, които решаваме</h2>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">Липса на информация</h6>
                            <p class="small text-muted mb-0">Вече няма нужда да търсите контакти по форуми – всичко е на едно място.</p>
                        </div>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">Неактуални графици</h6>
                            <p class="small text-muted mb-0">Виждате само свободните часове, актуализирани в реално време.</p>
                        </div>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">Възможността за отзив</h6>
                            <p class="small text-muted mb-0">Вече можете да изразите вашето мнение относно дадения обект, който сте посетили.</p>
                        </div>
                    </div>
                    <div class="col-lg-6 text-center">
                        <img src="~/images/Solutions.png" class="img-fluid">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-5 bg-dark text-white">
            <div class="container position-relative z-index-2">
                <div class="row align-items-center">
                    <div class="col-lg-5 mb-4 mb-lg-0">
                        <h2 class="display-6 fw-bold mb-3">Имаш спортен обект?</h2>
                        <p class="lead text-white-50 mb-4">Стани част от нашата мрежа в 3 лесни стъпки и увеличи клиентите си.</p>
                        <a class="btn btn-light btn-lg rounded-pill fw-bold px-5 shadow-lg partner-cta-btn" asp-area="" asp-controller="Owner" asp-action="Index">Регистрирай го</a>
                    </div>
                    <div class="col-lg-7">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="step-circle mb-3">1</div>
                                <h6 class="fw-bold">Създаване</h6>
                                <p class="small text-white-50">Регистрирай своя бизнес.</p>
                            </div>
                            <div class="col-4">
                                <div class="step-circle mb-3">2</div>
                                <h6 class="fw-bold">Потвърждаване</h6>
                                <p class="small text-white-50">Предоставяне на документи за собственост.</p>
                            </div>
                            <div class="col-4">
                                <div class="step-circle mb-3">3</div>
                                <h6 class="fw-bold">Печели</h6>
                                <p class="small text-white-50">Приемай резервации онлайн.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="decorative-ring"></div>
        </section>
        <section class="py-6">
            <div class="container py-5">
                <div class="row justify-content-center text-center mb-5">
                    <div class="col-lg-8">
                        <h2 class="display-5 fw-bold mb-3">Нашата История и Цел</h2>
                        <p class="lead text-muted">Ние не просто правим софтуер. Ние градим общност, където здравето и спортът са приоритет за всеки.</p>
                        <div class="mx-auto" style="width: 100px; height: 4px; background-color: #198754; border-radius: 2px;"></div>
                    </div>
                </div>
                <div class="row g-4 pt-4">
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up">
                            <div class="about-icon-circle bg-success-soft mb-4">
                                <i class="fas fa-bullseye fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">Мисия</h3>
                            <p class="text-muted fs-5">Да направим спорта достъпен за всеки българин чрез модерни технологии.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up">
                            <div class="about-icon-circle bg-white-soft mb-4">
                                <i class="fas fa-eye fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">Визия</h3>
                            <p class="text-light-50 fs-5">Най-голямата екосистема за активен отдих и управление на спортни бази в страната.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up">
                            <div class="about-icon-circle bg-success-soft mb-4">
                                <i class="fas fa-handshake fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">Ценности</h3>
                            <p class="text-muted fs-5">Прозрачност, иновация и непоколебима подкрепа за местния бизнес и спортни клубове.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}
<script>
    const citiesData = @Html.Raw(Json.Serialize(Model.CityNames));
    const activitiesData = @Html.Raw(Json.Serialize(Model.ActivityNames));

    function setupAutocomplete(inputId, listId, dataArray, iconClass)
    {
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);

        const popularItemsMap =
        {
            'cityInput': ["София", "Пловдив", "Варна", "Бургас", "Благоевград"],
            'activityInput': ["Футбол", "Волейбол", "Баскетбол", "Тенис", "Фитнес"]
        };

        const labelsMap =
        {
            'cityInput': "Известни локации",
            'activityInput': "Популярни активности"
        };

        function renderList(items)
        {
            list.innerHTML = '';
            const inputValue = input.value.toLowerCase().trim();
            if (inputValue === '')
            {
                const label = document.createElement('div');
                label.className = 'dropdown-header-custom';
                label.innerHTML = `<strong>${labelsMap[inputId]}</strong>`;
                list.appendChild(label);

                popularItemsMap[inputId].forEach(item => {
                    list.appendChild(createItemDiv(item));
                });

                const divider = document.createElement('div');
                divider.className = 'dropdown-header-custom mt-2';
                divider.innerHTML = `<strong>Всички предложения</strong>`;
                list.appendChild(divider);
            }

            if (items.length === 0 && inputValue !== '')
            {
                list.style.display = 'none';
                return;
            }
            items.forEach(item => {
                list.appendChild(createItemDiv(item));
            });
            list.style.display = 'block';
        }
        function createItemDiv(item)
        {
            const div = document.createElement('div');
            div.className = 'dropdown-item-custom';
            div.innerHTML = `<i class="${iconClass}"></i> ${item}`;
            const activityIcons = {
                    'Айкидо': 'fas fa-user-ninja',
                    'Акробатика': 'fas fa-child',
                    'Бадминтон': 'fas fa-table-tennis',
                    'Балет': 'fas fa-shoe-prints',
                    'Баскетбол': 'fas fa-basketball-ball',
                    'Бейзбол': 'fas fa-baseball-ball',
                    'Билярд': 'fas fa-circle',
                    'Бокс': 'fas fa-fist-raised',
                    'Борба': 'fas fa-hand-rock',
                    'Боулинг': 'fas fa-bowling-ball',
                    'Волейбол': 'fas fa-volleyball-ball',
                    'Гимнастика': 'fas fa-walking',
                    'Голф': 'fas fa-golf-ball',
                    'Дартс': 'fas fa-bullseye',
                    'Джудо': 'fas fa-user-ninja',
                    'Йога': 'fas fa-spa',
                    'Карате': 'fas fa-hand-rock',
                    'Конна езда': 'fas fa-horse',
                    'Крикет': 'fas fa-baseball-ball',
                    'Лека атлетика': 'fas fa-running',
                    'ММА': 'fas fa-fist-raised',
                    'Падел': 'fas fa-table-tennis',
                    'Плуване': 'fas fa-swimmer',
                    'Ски': 'fas fa-skiing',
                    'Стрелба': 'fas fa-crosshairs',
                    'Таекуондо': 'fas fa-user-ninja',
                    'Танци': 'fas fa-music',
                    'Тенис': 'fas fa-table-tennis',
                    'Тенис на маса': 'fas fa-table-tennis',
                    'Фехтовка': 'fas fa-pen-nib',
                    'Фитнес': 'fas fa-dumbbell',
                    'Футбол': 'fas fa-futbol',
                    'Хандбал': 'fas fa-volleyball-ball'
                };
            const currentIcon = activityIcons[item] || iconClass;
            div.innerHTML = `<i class="${currentIcon}"></i> ${item}`;
            div.addEventListener('click', function()
            {
                input.value = item;
                input.setCustomValidity('');
                list.style.display = 'none';
                input.focus();
            });
            return div;
        }
        function handleFilter()
        {
            const text = input.value.toLowerCase().trim();
            const filtered = dataArray
                .filter(item => item.toString().toLowerCase().trim().startsWith(text))
                .sort();
            renderList(filtered);
        }
        input.addEventListener('focus', handleFilter);
        input.addEventListener('input', handleFilter);
        document.addEventListener('click', function(e)
        {
            if (e.target !== input && !list.contains(e.target))
            {
                list.style.display = 'none';
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function()
    {
        setupAutocomplete('cityInput', 'cityList', citiesData, 'fas fa-map-marker-alt');
        setupAutocomplete('activityInput', 'activityList', activitiesData, 'fas fa-running');
    });

    const searchForm = document.getElementById('mainSearchForm');
    if (searchForm)
    {
        searchForm.addEventListener('submit', function (e)
        {
            const cityInput = document.getElementById('cityInput');
            const activityInput = document.getElementById('activityInput');
            const cityValue = cityInput.value.trim().toLowerCase();
            const activityValue = activityInput.value.trim().toLowerCase();
            const isCityValid = citiesData.some(c => c.toLowerCase() === cityValue);

            if (!isCityValid)
            {
                e.preventDefault();
                toastr.info("Моля, изберете град от предложенията!");

                cityInput.classList.add('input-error');
                cityInput.value = '';
                cityInput.focus();

                setTimeout(() => cityInput.classList.remove('input-error'), 2000);
                return false;
            }
            const isActivityValid = activitiesData.some(a => a.toLowerCase() === activityValue);

            if (activityValue !== "" && !isActivityValid)
            {
                e.preventDefault();
                toastr.info("Моля, изберете валидна активност!");

                activityInput.classList.add('input-error');
                activityInput.value = '';
                activityInput.focus();

                setTimeout(() => activityInput.classList.remove('input-error'), 2000);
                return false;
            }
        });
    }
</script>