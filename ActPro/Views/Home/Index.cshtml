@using ActPro.Helpers
@using static ActPro.Domain.DomainResources
@model ActPro.Models.HomeViewModel
@{
    ViewData["Title"] = DomainResources.PageTitle;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en";
    ViewData["SeoTitle"] = isEnglish ? "ActPro - Book sports facilities and fitness all over Bulgaria" : "ActPro - Резервирай спортни площадки и фитнес в цяла България";
    ViewData["SeoDescription"] = isEnglish 
        ? "Discover and book the best sports grounds, fitness centers, tennis courts, pools and other facilities. Free and easy online reservation in Sofia, Plovdiv, Varna and many more cities!"
        : "Открий и резервирай най-добрите спортни площадки, фитнеси, тенис кортове, басейни и други съоръжения. Безплатно и лесно онлайн резервиране в София, Пловдив, Варна и още много градове!";
    ViewData["SeoKeywords"] = isEnglish ? "sports facilities, online reservation, fitness, tennis, swimming, volleyball, basketball, football, bowling, yoga, sports, Bulgaria" : "спортни площадки, резервация онлайн, фитнес, тенис, плуване, волейбол, баскетбол, футбол, боулинг, йога, спорт, България";
}
<div class="container-fluid p-0">
    <main>
        <section class="py-5 position-relative">
            <div class="container position-relative z-index-2">
                <div class="text-center mb-4 reveal reveal-up">
                    <h1 class="fw-bold text-dark">@DomainResources.SearchHeroTitle</h1>
                    <p class="text-muted">@DomainResources.SearchHeroSubtitle</p>
                </div>
                <div class="search-container-styled reveal reveal-up">
                    <form asp-controller="Search" asp-action="Index" method="get" id="mainSearchForm">
                        <div class="row align-items-center">
                            <div class="col-md-5 position-relative divider-end">
                                <label class="search-label-small">@DomainResources.LabelCity</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt input-icon"></i>
                                    <input type="text"
                                           class="form-control form-control-custom"
                                           id="cityInput"
                                           name="city"
                                           placeholder="@DomainResources.PlaceholderCity"
                                           autocomplete="off"
                                           required
                                           oninvalid="this.setCustomValidity('@DomainResources.ValidationCityRequired')"
                                           oninput="this.setCustomValidity('')">
                                </div>
                                <div id="cityList" class="custom-dropdown-list"></div>
                            </div>
                            <div class="col-md-5 position-relative">
                                <label class="search-label-small">@DomainResources.LabelActivity</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-running input-icon"></i>
                                    <input type="text"
                                           class="form-control form-control-custom"
                                           id="activityInput"
                                           name="activity"
                                           placeholder="@DomainResources.PlaceholderActivity"
                                           autocomplete="off" />
                                </div>
                                <div id="activityList" class="custom-dropdown-list"></div>
                            </div>
                            <div class="col-md-2 text-center">
                                <button type="submit" class="btn btn-success w-100 fw-bold py-2 shadow-sm" style="border-radius: 25px; height: 50px;">
                                    @DomainResources.SearchButton
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-6 pr-lg-5">
                        <div class="reveal reveal-left delay-1">
                            <span class="text-success fw-bold text-uppercase small">@DomainResources.AboutBadge</span>
                            <h2 class="fw-bold mb-4">@DomainResources.AboutTitle</h2>
                            <p class="text-muted lead">@DomainResources.AboutDescription</p>
                            <ul class="list-unstyled mt-4">
                                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> @DomainResources.FeatureRealTime</li>
                                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> @DomainResources.FeatureVariety</li>
                                <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> @DomainResources.FeatureAllDevices</li>

                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-6 reveal reveal-right delay-1">
                        <img src="~/images/Show.png" class="img-fluid custom-section-img">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-4">
            <div class="container">
                <h3 class="text-center mb-4 fw-bold reveal reveal-up delay-1">@DomainResources.CategoriesTitle</h3>
                <div class="sports-category-grid">
                    @{
                        int GetCount(string key) => Model.SportCounts != null && Model.SportCounts.ContainsKey(key) ? Model.SportCounts[key] : 0;

                        var sportsList = new[] {
                                        new { Name = @DomainResources.SportFootball, Icon = "fa-futbol", Class = "football" },
                                        new { Name = @DomainResources.SportBasketball, Icon = "fa-basketball-ball", Class = "basketball" },
                                        new { Name = @DomainResources.SportVolleyball, Icon = "fa-volleyball-ball", Class = "volleyball" },
                                        new { Name = @DomainResources.SportTennis, Icon = "fa-table-tennis", Class = "tennis" },
                                        new { Name = @DomainResources.SportFitness, Icon = "fa-dumbbell", Class = "fitness" },
                                        new { Name = @DomainResources.SportSwimming, Icon = "fa-swimmer", Class = "swimming" }
                                        };
                    }

                    @foreach (var sport in sportsList)
                    {
                        <a asp-controller="Search" asp-action="Index" asp-route-activity="@sport.Name" class="sport-card @sport.Class">
                            <div class="sport-card-icon">
                                <i class="fas @sport.Icon"></i>
                            </div>
                            <div class="sport-card-info">
                                <span class="name">@sport.Name</span>
                                <span class="count">@GetCount(sport.Name) @DomainResources.Place</span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center flex-row-reverse">
                    <div class="col-lg-6 ps-lg-5 reveal reveal-right delay-1">
                        <span class="text-success fw-bold text-uppercase small">@DomainResources.BenefitsBadge</span>
                        <h2 class="fw-bold mb-4">@DomainResources.BenefitsTitle</h2>
                        <p class="text-muted mb-4">@DomainResources.BenefitsDescription</p>

                        <div class="benefit-list">
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-clock text-success me-3 fs-4"></i>
                                <span class="fw-bold">@DomainResources.BenefitSpeed</span>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <i class="fas fa-wallet text-success me-3 fs-4"></i>
                                <span class="fw-bold">@DomainResources.BenefitSecurity</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="fas fa-mobile-alt text-success me-3 fs-4"></i>
                                <span class="fw-bold">@DomainResources.BenefitAccessibility</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 reveal reveal-left delay-1">
                        <img src="~/images/Help.png" class="img-fluid custom-section-img">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <h2 class="mb-5 text-center fw-bold display-6 reveal reveal-up delay-1">@DomainResources.TopPlacesTitle</h2>
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    @foreach (var place in Model.TopPlaces)
                    {
                        var placeName = isEnglish && !string.IsNullOrEmpty(place.NameEn) ? place.NameEn : place.Name;
                        var placeCityName = isEnglish && place.City != null && !string.IsNullOrEmpty(place.City.NameEn) ? place.City.NameEn : place.City?.Name;
                        <div class="col reveal reveal-up">
                            <div class="card h-100 shadow-sm border-0 top-place-card reveal reveal-up delay-1">
                                <img src="@(place.PlaceImages?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/300x200")"
                                     class="card-img-top" alt="@placeName">
                                <div class="card-body d-flex flex-column">
                                    <div class="flex-grow-1">
                                        <h5 class="card-title fw-bold card-title-limited">@placeName</h5>
                                        <p class="text-muted small mb-2">
                                            <i class="bi bi-geo-alt"></i> @placeCityName
                                        </p>
                                        <p class="card-text text-warning fw-bold">@DomainResources.Rating: ⭐ @place.Rating</p>
                                    </div>
                                    <a asp-controller="Reservation" asp-action="Index" asp-route-id="@place.Id"
                                       class="btn btn-success w-100 fw-bold py-2 shadow-sm mt-3">@DomainResources.ViewMore</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
        <section class="py-5">
            <div class="container">
                <div class="row align-items-center reveal reveal-up delay-1">
                    <div class="col-lg-6">
                        <span class="text-success fw-bold text-uppercase small">@DomainResources.SolutionsBadge</span>
                        <h2 class="fw-bold mb-4">@DomainResources.SolutionsTitle</h2>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">@DomainResources.ProbInfoTitle</h6>
                            <p class="small text-muted mb-0">@DomainResources.ProbInfoDesc</p>
                        </div>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">@DomainResources.ProbScheduleTitle</h6>
                            <p class="small text-muted mb-0">@DomainResources.ProbScheduleDesc</p>
                        </div>
                        <div class="problem-card p-3 mb-3 bg-white rounded shadow-sm border-start border-success border-4">
                            <h6 class="fw-bold mb-1">@DomainResources.ProbReviewTitle</h6>
                            <p class="small text-muted mb-0">@DomainResources.ProbReviewDesc</p>
                        </div>
                    </div>
                    <div class="col-lg-6 text-center reveal reveal-right delay-1">
                        <img src="~/images/Solutions.jpg" class="img-fluid custom-section-img">
                    </div>
                </div>
            </div>
        </section>
        <section class="py-5 bg-dark text-white">
            <div class="container position-relative z-index-2">
                <div class="row align-items-center">
                    <div class="col-lg-5 mb-4 mb-lg-0">
                        <h2 class="display-6 fw-bold mb-3">@DomainResources.OwnerTitle</h2>
                        <p class="lead text-white-50 mb-4">@DomainResources.OwnerSubtitle</p>
                        <a class="btn btn-light btn-lg rounded-pill fw-bold px-5 shadow-lg partner-cta-btn" asp-area="" asp-controller="Owner" asp-action="Index">@DomainResources.OwnerRegisterBtn</a>
                    </div>
                    <div class="col-lg-7">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="step-circle mb-3 reveal reveal-up delay-1">1</div>
                                <h6 class="fw-bold">@DomainResources.Step1Title</h6>
                                <p class="small text-white-50">@DomainResources.Step1Desc</p>
                            </div>
                            <div class="col-4">
                                <div class="step-circle mb-3 reveal reveal-up delay-2">2</div>
                                <h6 class="fw-bold">@DomainResources.Step2Title</h6>
                                <p class="small text-white-50">@DomainResources.Step2Desc</p>
                            </div>
                            <div class="col-4">
                                <div class="step-circle mb-3 reveal reveal-up delay-3">3</div>
                                <h6 class="fw-bold">@DomainResources.Step3Title</h6>
                                <p class="small text-white-50">@DomainResources.Step3Desc</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="decorative-ring"></div>
        </section>
        <section class="py-6">
            <div class="container py-5">
                <div class="row justify-content-center text-center mb-5 reveal reveal-up delay-1">
                    <div class="col-lg-8">
                        <h2 class="display-5 fw-bold mb-3">@DomainResources.StoryTitle</h2>
                        <p class="lead text-muted">@DomainResources.StorySubtitle</p>
                        <div class="mx-auto" style="width: 100px; height: 4px; background-color: #198754; border-radius: 2px;"></div>
                    </div>
                </div>
                <div class="row g-4 pt-4">
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up reveal reveal-left">
                            <div class="about-icon-circle bg-success-soft mb-4">
                                <i class="fas fa-bullseye fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">@DomainResources.MissionTitle</h3>
                            <p class="text-muted fs-5">@DomainResources.MissionDesc</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up reveal reveal-up">
                            <div class="about-icon-circle bg-white-soft mb-4">
                                <i class="fas fa-eye fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">@DomainResources.VisionTitle</h3>
                            <p class="text-light-50 fs-5">@DomainResources.VisionDesc</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="about-item p-5 border-0 shadow-lg rounded-5 h-100 text-center transition-up reveal reveal-right">
                            <div class="about-icon-circle bg-success-soft mb-4">
                                <i class="fas fa-handshake fa-3x text-success"></i>
                            </div>
                            <h3 class="fw-bold mb-3">@DomainResources.ValuesTitle</h3>
                            <p class="text-muted fs-5">@DomainResources.ValuesDesc</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}
<span id="cities-data" style="display:none;">@string.Join("|", Model?.CityNames ?? new List<string>())</span>
<span id="activities-data" style="display:none;">@string.Join("|", Model?.ActivityNames ?? new List<string>())</span>
<script>
    const citiesData = document.getElementById('cities-data').textContent.split('|').filter(x => x);
    const activitiesData = document.getElementById('activities-data').textContent.split('|').filter(x => x);

    function setupAutocomplete(inputId, listId, dataArray, iconClass){
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);

        const popularItemsMap = {
            'cityInput': @Html.Raw("['" + DomainResources.JsPopularCities.Replace(", ", "','") + "']"),
            'activityInput': @Html.Raw("['" + DomainResources.JsDefaultActivities.Replace(", ", "','") + "']")
        };

        const labelsMap = {
            'cityInput': @Html.Raw("'" + DomainResources.JsFamousLocations + "'"),
            'activityInput': @Html.Raw("'" + DomainResources.JsPopularActivities + "'")
        };

        function renderList(items){
            list.innerHTML = '';
            const inputValue = input.value.toLowerCase().trim();
            if (inputValue === ''){
                const label = document.createElement('div');
                label.className = 'dropdown-header-custom';
                label.innerHTML = `<strong>${labelsMap[inputId]}</strong>`;
                list.appendChild(label);

                popularItemsMap[inputId].forEach(item => {
                    list.appendChild(createItemDiv(item));
                });

                const divider = document.createElement('div');
                divider.className = 'dropdown-header-custom mt-2';
                divider.innerHTML = `<strong>@DomainResources.JsAllSuggestions</strong>`;
                list.appendChild(divider);
            }

            if (items.length === 0 && inputValue !== ''){
                list.style.display = 'none';
                return;
            }
            items.forEach(item => {
                list.appendChild(createItemDiv(item));
            });
            list.style.display = 'block';
        }
        function createItemDiv(item){
            const div = document.createElement('div');
            div.className = 'dropdown-item-custom';
            div.innerHTML = `<i class="${iconClass}"></i> ${item}`;
                const activityIcons = {
                    'Бадминтон': 'fas fa-table-tennis',
                    'Badminton': 'fas fa-table-tennis',
                    'Балет': 'fas fa-shoe-prints',
                    'Ballet': 'fas fa-shoe-prints',
                    'Баскетбол': 'fas fa-basketball-ball',
                    'Basketball': 'fas fa-basketball-ball',
                    'Бейзбол': 'fas fa-baseball-ball',
                    'Baseball': 'fas fa-baseball-ball',
                    'Билярд': 'fas fa-circle',
                    'Billiards': 'fas fa-circle',
                    'Бокс': 'fas fa-fist-raised',
                    'Boxing': 'fas fa-fist-raised',
                    'Борба': 'fas fa-hand-rock',
                    'Wrestling': 'fas fa-hand-rock',
                    'Боулинг': 'fas fa-bowling-ball',
                    'Bowling': 'fas fa-bowling-ball',
                    'Волейбол': 'fas fa-volleyball-ball',
                    'Volleyball': 'fas fa-volleyball-ball',
                    'Гимнастика': 'fas fa-walking',
                    'Gymnastics': 'fas fa-walking',
                    'Голф': 'fas fa-golf-ball',
                    'Golf': 'fas fa-golf-ball',
                    'Дартс': 'fas fa-bullseye',
                    'Darts': 'fas fa-bullseye',
                    'Джудо': 'fas fa-user-ninja',
                    'Judo': 'fas fa-user-ninja',
                    'Йога': 'fas fa-spa',
                    'Yoga': 'fas fa-spa',
                    'Карате': 'fas fa-hand-rock',
                    'Karate': 'fas fa-hand-rock',
                    'Конна езда': 'fas fa-horse',
                    'Horseback Riding': 'fas fa-horse',
                    'Лека атлетика': 'fas fa-running',
                    'Athletics': 'fas fa-running',
                    'ММА': 'fas fa-fist-raised',
                    'MMA': 'fas fa-fist-raised',
                    'Падел': 'fas fa-table-tennis',
                    'Padel': 'fas fa-table-tennis',
                    'Плуване': 'fas fa-swimmer',
                    'Swimming': 'fas fa-swimmer',
                    'Ски': 'fas fa-skiing',
                    'Skiing': 'fas fa-skiing',
                    'Стрелба': 'fas fa-crosshairs',
                    'Shooting': 'fas fa-crosshairs',
                    'Таекуондо': 'fas fa-user-ninja',
                    'Taekwondo': 'fas fa-user-ninja',
                    'Танци': 'fas fa-music',
                    'Dancing': 'fas fa-music',
                    'Тенис': 'fas fa-table-tennis',
                    'Tennis': 'fas fa-table-tennis',
                    'Тенис на маса': 'fas fa-table-tennis',
                    'Table Tennis': 'fas fa-table-tennis',
                    'Фехтовка': 'fas fa-pen-nib',
                    'Fencing': 'fas fa-pen-nib',
                    'Фитнес': 'fas fa-dumbbell',
                    'Fitness': 'fas fa-dumbbell',
                    'Футбол': 'fas fa-futbol',
                    'Football': 'fas fa-futbol',
                    'Хандбал': 'fas fa-volleyball-ball',
                    'Handball': 'fas fa-volleyball-ball'
                };
            const currentIcon = activityIcons[item] || iconClass;
            div.innerHTML = `<i class="${currentIcon}"></i> ${item}`;
            div.addEventListener('click', function(){
                input.value = item;
                input.setCustomValidity('');
                list.style.display = 'none';
                input.focus();
            });
            return div;
        }
        function handleFilter(){
            const text = input.value.toLowerCase().trim();
            const filtered = dataArray
                .filter(item => item.toString().toLowerCase().trim().startsWith(text))
                .sort();
            renderList(filtered);
        }
        input.addEventListener('focus', handleFilter);
        input.addEventListener('input', handleFilter);
        document.addEventListener('click', function(e){
            if (e.target !== input && !list.contains(e.target)){
                list.style.display = 'none';
            }
        });
    }
    document.addEventListener("DOMContentLoaded", function(){
        setupAutocomplete('cityInput', 'cityList', citiesData, 'fas fa-map-marker-alt');
        setupAutocomplete('activityInput', 'activityList', activitiesData, 'fas fa-running');
    });

    const searchForm = document.getElementById('mainSearchForm');
    if (searchForm){
        searchForm.addEventListener('submit', function (e){
            const cityInput = document.getElementById('cityInput');
            const activityInput = document.getElementById('activityInput');
            const cityValue = cityInput.value.trim().toLowerCase();
            const activityValue = activityInput.value.trim().toLowerCase();
            const isCityValid = citiesData.some(c => c.toLowerCase() === cityValue);

            if (!isCityValid){
                e.preventDefault();
                toastr.info(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.JsToastSelectCity)));

                cityInput.classList.add('input-error');
                cityInput.value = '';
                cityInput.focus();

                setTimeout(() => cityInput.classList.remove('input-error'), 2000);
                return false;
            }
            const isActivityValid = activitiesData.some(a => a.toLowerCase() === activityValue);

            if (activityValue !== "" && !isActivityValid){
                e.preventDefault();
                toastr.info(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.JsToastSelectActivity)));

                activityInput.classList.add('input-error');
                activityInput.value = '';
                activityInput.focus();

                setTimeout(() => activityInput.classList.remove('input-error'), 2000);
                return false;
            }
        });
    }
        document.addEventListener("DOMContentLoaded", function(){
        const observerOptions = {
            threshold: 0.15
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting){
                    entry.target.classList.add('active');
                }
            });
        }, observerOptions);

        const revealElements = document.querySelectorAll('.reveal');
        revealElements.forEach(el => observer.observe(el));
    });
</script>