@model ActPro.Domain.Models.NewsViewModel
@{
    ViewData["Title"] = DomainResources.News;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en";
    ViewData["SeoTitle"] = isEnglish ? "News and articles about sports - ActPro" : "Новини и статии за спорта - ActPro";
    ViewData["SeoDescription"] = isEnglish 
        ? "Read the latest news and articles about sports, fitness and healthy lifestyle. Find useful information about training, nutrition and motivation in the ActPro blog."
        : "Прочети най-новите новини и статии за спорта, фитнеса и здравословния начин на живот. Намери полезна информация за тренировки, хранене и мотивация в блога на ActPro.";
    ViewData["SeoKeywords"] = isEnglish ? "news, sports, fitness, health, training, blog, articles" : "новини, спорт, фитнес, здраве, тренировки, блог, статии";
}
<section class="news-page py-5 bg-light-custom">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-md-8">
                <h1 class="display-4 fw-800 text-dark mb-2 fw-bold">@DomainResources.News</h1>
                <p class="text-muted lead-custom">@DomainResources.NewsSubtitle</p>
            </div>
            <div class="col-md-4 text-md-end">
                @if (User.IsInRole("Admin"))
                {
                    <button class="btn btn-create-new shadow-sm" data-bs-toggle="modal" data-bs-target="#createModal">
                        <i class="bi bi-plus-lg me-2"></i>@DomainResources.NewPublication
                    </button>
                }
            </div>
        </div>
        <div class="row g-4">
            @if (Model.NewsItems != null && Model.NewsItems.Any())
            {
                foreach (var item in Model.NewsItems)
                {
                    var imageUrl = string.IsNullOrEmpty(item.ImageURL) ? "default.jpg" : item.ImageURL;
                    var dateStr = item.CreatedAt.ToString("dd.MM.yyyy");
                    var itemTitle = isEnglish && !string.IsNullOrEmpty(item.TitleEn) ? item.TitleEn : item.Title;
                    var itemContent = isEnglish && !string.IsNullOrEmpty(item.ContentEn) ? item.ContentEn : item.Content;
                    var dataAttrs = $"data-id=\"{item.Id}\" data-title=\"{itemTitle}\" data-content=\"{System.Web.HttpUtility.JavaScriptStringEncode(itemContent)}\" data-img=\"{imageUrl}\" data-date=\"{dateStr}\" data-likes=\"{item.Likes}\" data-is-liked=\"{item.IsLikedByCurrentUser.ToString().ToLower()}\"";
                    <div class="col-lg-4 col-md-6">
                        <article class="news-card">
                            <div class="card-image-wrapper js-view-news" @Html.Raw(dataAttrs)>
                                <img src="/images/news/@imageUrl" alt="@itemTitle" loading="lazy">
                                <div class="date-badge">
                                    <span class="day">@item.CreatedAt.Day</span>
                                    <span class="month">@item.CreatedAt.ToString("MMM")</span>
                                </div>
                                <div class="image-overlay">
                                    <span class="view-btn">@DomainResources.ReadMore</span>
                                </div>
                            </div>

                            <div class="card-content">
                                <h3 class="card-title-link js-view-news" @Html.Raw(dataAttrs)>
                                    @itemTitle
                                </h3>
                                <p class="card-excerpt">@itemContent</p>

                                <div class="card-footer-custom">
                                    <button class="btn-read-more js-view-news" @Html.Raw(dataAttrs)>
                                        @DomainResources.ViewMore <i class="bi bi-arrow-right ms-1"></i>
                                    </button>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button class="btn-delete-icon" onclick="NewsApp.deleteConfirm('@item.Id', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(itemTitle))')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </article>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="empty-state-container">
                        <i class="bi bi-journal-x display-1 text-muted opacity-25"></i>
                        <h4 class="mt-3">@DomainResources.NoNewsAvailable</h4>
                    </div>
                </div>
            }
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination pagination-modern justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="News" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</section>
<div class="modal fade" id="viewModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header-image">
                <div id="vImgBlur"></div>
                <img id="vImg" src="" alt="News Image">

                <button type="button" class="btn-close-custom" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="article-meta d-flex align-items-center">
                    <span class="badge bg-success me-3">@DomainResources.News.ToUpper()</span>
                    <span class="text-muted fw-bold small" id="vDate"></span>
                </div>

                <h1 class="article-title-large mt-3" id="vTitle"></h1>
                <div class="article-divider"></div>

                <div class="article-body" id="vContent"></div>

                <div class="interaction-bar">
                    <div class="like-section">
                        <button class="btn-like" id="vLikeBtn" data-id="" data-is-logged="@User.Identity.IsAuthenticated.ToString().ToLower()">
                            <i class="bi bi-heart-fill me-2"></i>
                            <span id="vLikesCount">0</span>
                        </button>
                    </div>
                    <div class="share-section d-flex align-items-center">
                        <span class="small fw-bold text-muted me-3 text-uppercase">@DomainResources.ShareArticle</span>
                        <div class="share-buttons">
                            <a href="#" id="shareFB" target="_blank" class="fb-bg">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="javascript:void(0);" id="copyLink" class="ig-bg" onclick="copyToClipboard()" title="@DomainResources.CopyLink">
                                <i class="bi bi-link-45deg"></i>
                            </a>
                        </div>
                        <span id="copyMessage" class="small text-success ms-2" style="display: none;">@DomainResources.Copied</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@if (User.IsInRole("Admin"))
{
    <div class="modal fade" id="createModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <form asp-action="CreateNews" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header border-0 p-4 pb-0">
                        <h5 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>@DomainResources.CreateArticle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">@DomainResources.Title</label>
                            <input name="Title" class="form-control modern-input" placeholder="@DomainResources.TitlePlaceholder" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">@DomainResources.Content</label>
                            <textarea name="Content" class="form-control modern-input" rows="6" placeholder="@DomainResources.ContentPlaceholder" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">@DomainResources.Image</label>
                            <div class="upload-area" id="dropZone" onclick="document.getElementById('mainFileInput').click()">
                                <input type="file" name="imageFile" id="mainFileInput" class="file-input" accept="image/*" required style="display:none" />
                                <div id="prompt">
                                    <i class="bi bi-cloud-arrow-up text-green-gradient fs-1"></i>
                                    <p class="mb-0 fw-bold">@DomainResources.ClickToUpload</p>
                                    <small class="text-muted">@DomainResources.ImageFormats</small>
                                </div>
                                <img id="imgPreview" class="d-none img-preview-box mt-2">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="submit" class="btn btn-green-action w-100 py-3">@DomainResources.PublishNews</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            toastr.success('@TempData["SuccessMessage"]');
        </script>
    }
    <form id="antiForgeryForm" style="display:none">
        @Html.AntiForgeryToken()
    </form>
}
@section Styles
{
    <link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />
}

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const NewsApp = {
            deleteConfirm: function (id, title){
                Swal.fire({
                    title: '@DomainResources.AreYouSure',
                    text: `@DomainResources.WillDeleteNews: "${title}"`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: '@DomainResources.YesDelete',
                    cancelButtonText: '@DomainResources.Cancel'
                }).then((result) => {
                    if (result.isConfirmed){
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = '/Home/DeleteNews';

                        const idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'id';
                        idInput.value = id;

                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '__RequestVerificationToken';
                        tokenInput.value = token;

                        form.appendChild(idInput);
                        form.appendChild(tokenInput);
                        document.body.appendChild(form);
                        form.submit();
                    }
                });
            }
        };
        document.addEventListener('DOMContentLoaded', function (){
            const modalEl = document.getElementById('viewModal');
            const viewModal = new bootstrap.Modal(modalEl);
            const likeBtn = document.getElementById('vLikeBtn');
            const likesCountSpan = document.getElementById('vLikesCount');

            const showToast = (message, icon) => {
                Swal.fire({
                    toast: true,
                    position: 'top',
                    icon: icon,
                    title: message,
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    didOpen: (toast) => { toast.style.zIndex = "3000"; }
                });
            };
            document.querySelectorAll('.js-view-news').forEach(item => {
                item.addEventListener('click', function () {
                    const d = this.dataset;

                    document.getElementById('vTitle').innerText = d.title;
                    document.getElementById('vContent').innerText = d.content;
                    document.getElementById('vImg').src = `/images/news/${d.img}`;
                    document.getElementById('vDate').innerText = d.date;

                    likeBtn.dataset.id = d.id;
                    likesCountSpan.innerText = d.likes || 0;


                    if (this.getAttribute('data-is-liked') === "true") {
                        likeBtn.classList.add('active');
                    } 
                    else {
                        likeBtn.classList.remove('active');
                    }

                    viewModal.show();
                });
            });

            likeBtn.addEventListener('click', async function () 
            {
                const isLogged = this.dataset.isLogged === "true";
                const newsId = this.dataset.id;

                if (!isLogged) {
                    toastr.error(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.MustBeLoggedIn)));
                    return;
                }

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const response = await fetch(`/Home/LikeNews/${newsId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const result = await response.json();

                    if (response.ok && result.success){
                        likesCountSpan.innerText = result.likes;

                        if (result.isLiked){
                            this.classList.add('active');
                        } 
                        else{
                            this.classList.remove('active');
                        }
                        document.querySelectorAll(`.js-view-news[data-id="${newsId}"]`).forEach(el => {
                            el.setAttribute('data-is-liked', result.isLiked.toString());
                            el.setAttribute('data-likes', result.likes);
                        });
                    }
                } 
                catch (err){
                    showToast('@DomainResources.ServerCommunicationError', 'error');
                }
            });
        });
        document.addEventListener("DOMContentLoaded", function () {
        const currentUrl = encodeURIComponent(window.location.href);

        const fbBtn = document.getElementById('shareFB');
        if (fbBtn) {
            fbBtn.href = `https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`;
        }
    });

        function copyToClipboard() {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
                const msg = document.getElementById('copyMessage');
                msg.style.display = 'inline';
                setTimeout(() => {
                    msg.style.display = 'none';
                }, 2000);
            });
        }
        document.getElementById('mainFileInput').addEventListener('change', function (e) {
            const preview = document.getElementById('imgPreview');
            const prompt = document.getElementById('prompt');
            const file = e.target.files[0];

            if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    preview.src = event.target.result;
                    preview.classList.remove('d-none');
                    prompt.classList.add('d-none');
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}