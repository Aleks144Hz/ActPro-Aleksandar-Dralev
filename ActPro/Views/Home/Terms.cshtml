@{
    ViewData["Title"] = DomainResources.TermsOfService;
}
<div class="container my-5" style="max-width: 900px;">
    <div class="terms-header mb-5">
        <h1 class="fw-bold">@DomainResources.TermsOfService</h1>
        <p class="text-muted">@DomainResources.TermsLastUpdated</p>
        <hr>
    </div>
    <div class="terms-body" style="line-height: 1.7; color: #333;">
        <p>@DomainResources.TermsPageContent</p>
        <h4 class="mt-4 fw-bold">@DomainResources.TermsReservations</h4>
        <p>@DomainResources.TermsReservationsText</p>
        <h4 class="mt-4 fw-bold">@DomainResources.TermsRules</h4>
        <p>@DomainResources.TermsRulesList</p>
        <h4 class="mt-4 fw-bold">@DomainResources.TermsRefund</h4>
        <p>@DomainResources.TermsRefundText</p>
        <h4 class="mt-4 fw-bold">@DomainResources.TermsLiability</h4>
        <p>@DomainResources.TermsLiabilityText</p>
        <h4 class="mt-4 fw-bold">@DomainResources.TermsChanges</h4>
        <p>@DomainResources.TermsChangesText</p>
        <div class="mt-5 pt-4 border-top">
            <p class="small text-muted italic"><strong>@DomainResources.TermsContactEmail</strong></p>
        </div>
    </div>
</div>
