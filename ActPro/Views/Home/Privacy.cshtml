@{
    ViewData["Title"] = DomainResources.PrivacyPolicy;
}
<div class="container my-5" style="max-width: 900px;">
    <div class="terms-header mb-5">
        <h1 class="fw-bold">@DomainResources.PrivacyPolicy</h1>
        <p class="text-muted">@DomainResources.PrivacyLastUpdated</p>
        <hr>
    </div>
    <div class="terms-body" style="line-height: 1.7; color: #333;">
        <p>@DomainResources.PrivacyPageContent</p>
        <h4 class="mt-4 fw-bold">@DomainResources.PrivacyInfoWeCollect</h4>
        <p>@DomainResources.PrivacyInfoCollectedList</p>
        <h4 class="mt-4 fw-bold">@DomainResources.PrivacyHowWeUse</h4>
        <p>@DomainResources.PrivacyHowWeUseList</p>
        <h4 class="mt-4 fw-bold">@DomainResources.PrivacySharingInfo</h4>
        <p>@DomainResources.PrivacySharingList</p>
        <h4 class="mt-4 fw-bold">@DomainResources.PrivacyYourRights</h4>
        <p>@DomainResources.PrivacyYourRightsList</p>
        <h4 class="mt-4 fw-bold">@DomainResources.PrivacySecurity</h4>
        <p>@DomainResources.PrivacySecurityText</p>

        <div class="mt-5 pt-4 border-top">
            <p class="small text-muted italic"><strong>@DomainResources.PrivacyContactEmail</strong></p>
        </div>
    </div>
</div>