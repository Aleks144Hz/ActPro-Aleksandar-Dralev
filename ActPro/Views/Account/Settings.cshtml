@using ActPro.DAL
@using ActPro.DAL.Entities
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Настройки на профила";
    var editModel = new ActPro.Models.User.EditProfileViewModel
    {
        FirstName = Model.FirstName,
        LastName = Model.LastName,
        PhoneNumber = Model.PhoneNumber,
        ExistingPicturePath = Model.ProfilePicturePath
    };
    var deleteModel = new ActPro.Models.User.DeleteProfileViewModel();
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <h2 class="fw-bold mb-4"><i class="bi bi-gear-fill me-2 text-primary"></i> Настройки</h2>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h5 class="card-title fw-bold mb-0">Лична информация</h5>
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                data-bs-toggle="modal" data-bs-target="#editProfileModal">
                            <i class="bi bi-pencil me-1"></i> Редактирай
                        </button>
                    </div>
                    <div class="row align-items-center">
                        <div class="col-md-auto text-center mb-3 mb-md-0">
                            @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
                            {
                                <img src="/images/profiles/@Model.ProfilePicturePath" class="rounded-circle shadow-sm" style="width: 100px; height: 100px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm" style="width: 100px; height: 100px;">
                                    <i class="bi bi-person text-secondary fs-1"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <label class="text-muted small text-uppercase fw-bold">Име</label>
                                    <p class="h6 fw-normal">@Model.FirstName @Model.LastName</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="text-muted small text-uppercase fw-bold">Имейл</label>
                                    <p class="h6 fw-normal">@Model.Email</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="text-muted small text-uppercase fw-bold">Телефон</label>
                                    <p class="h6 fw-normal">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Не е въведен" : Model.PhoneNumber)</p>
                                </div>
                                <div class="col-sm-6">
                                    <label class="text-muted small text-uppercase fw-bold">Член от</label>
                                    <p class="h6 fw-normal">@Model.CreatedOn.ToString("dd MMMM yyyy")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 border-start border-primary border-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-primary mb-3">Редактиране на парола</h5>
                    <p class="text-muted small">Внимавайте с кого споделяте паролата. Екипът на ActPro не държи отговорност при открадване на акаунт.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-primary rounded-pill px-4 text-white"
                                data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                            <i class="bi bi-shield-lock me-1"></i> Смени парола
                        </button>
                    </div>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 border-start border-danger border-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-danger mb-3">Зона за сигурност</h5>
                    <p class="text-muted small">Внимавайте с действията в този панел. Изтриването на профила е необратимо.</p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-danger rounded-pill px-4"
                                data-bs-toggle="modal" data-bs-target="#deleteProfileModal">
                            <i class="bi bi-trash3 me-1"></i> Изтрий моя профил
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@await Html.PartialAsync("DeleteProfile", new ActPro.Models.User.DeleteProfileViewModel())
@await Html.PartialAsync("ChangePassword", new ActPro.Models.User.ChangePasswordViewModel())
@await Html.PartialAsync("EditProfile", new ActPro.Models.User.EditProfileViewModel
{
    FirstName = Model.FirstName,
    LastName = Model.LastName,
    PhoneNumber = Model.PhoneNumber,
    ExistingPicturePath = Model.ProfilePicturePath
})
@section Styles
{
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function ()
        {
            @if (ViewData["ShowDeleteModal"] != null && (bool)ViewData["ShowDeleteModal"])
            {
                   <text>
                       var deleteModal = new bootstrap.Modal(document.getElementById('deleteProfileModal'));
                       deleteModal.show();
                   </text>
            }
            @if (ViewData["ShowChangePasswordModal"] != null && (bool)ViewData["ShowChangePasswordModal"])
            {
                   <text>
                       var passModal = new bootstrap.Modal(document.getElementById('changePasswordModal'));
                       passModal.show();
                   </text>
            }
        });
    </script>
}