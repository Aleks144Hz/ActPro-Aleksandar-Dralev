@using ActPro.Models.User
@model UserProfileViewModel
@{
    ViewData["Title"] = DomainResources.Profile;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en";
    ViewData["SeoTitle"] = isEnglish ? "My Profile - ActPro" : "Моят профил - ActPro";
    ViewData["SeoDescription"] = isEnglish 
        ? "Manage your ActPro profile. View favorite facilities, credits, level and privileges. Update personal info and settings."
        : "Управлявай своя профил в ActPro. Виж любими площадки, кредити, ниво и привилегии. Промени лични данни и настройки.";
    ViewData["SeoKeywords"] = isEnglish ? "profile, account, favorites, credits, level, settings, ActPro" : "профил, акаунт, любими, кредити, ниво, настройки, ActPro";
}
<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm text-center p-4 h-100">
                <div class="mb-3 position-relative d-inline-block">
                    <img id="profileImageDisplay"
                         src="@(string.IsNullOrEmpty(Model.ProfilePicturePath) ? "https://cdn-icons-png.flaticon.com/512/1144/1144760.png" : "/images/profiles/" + Model.ProfilePicturePath)"
                         class="rounded-circle img-thumbnail shadow-sm"
                         style="width: 150px; height: 150px; object-fit: cover;"
                         alt="@DomainResources.ProfilePicture">
                </div>
                <h4 class="fw-bold">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <p class="text-muted">@Model.PhoneNumber</p>
                <div>
                    <div class="d-block mt-2">
                        <button type="button" class="fw-bold text-info-emphasis px-3 py-2 border-0 shadow-sm"
                                data-bs-toggle="modal" data-bs-target="#creditsInfoModal">
                            <i class="bi bi-gem me-2"></i><strong>@Model.Credits.ToString("0.##")</strong> @DomainResources.ActProCredits
                        </button>
                    </div>
                </div>
                <hr class="my-4">
                <div class="d-grid gap-2 mt-auto pt-1">
                    <a asp-controller="Reservation" asp-action="MyReservations" class="btn btn-outline-success shadow-sm mb-2">
                        <i class="bi bi-calendar-check-fill me-2"></i>@DomainResources.MyReservations (@ViewBag.ResCount)
                    </a>
                    <a asp-controller="Reservation" asp-action="MyReviews" class="btn btn-outline-primary shadow-sm mb-2">
                        <i class="bi bi-chat-left-text me-2"></i>@DomainResources.MyReviews (@ViewBag.RevCount)
                    </a>
                    <a asp-controller="Account" asp-action="Settings" class="btn btn-outline-dark shadow-sm mb-2">
                        <i class="bi bi-gear me-2"></i>@DomainResources.Settings
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="mb-0 fw-bold text-primary">
                        <i class="bi bi-star-fill me-2 text-warning"></i>@DomainResources.Favorites
                    </h5>
                </div>
                <div class="card-body p-0 p-md-3">
                    <div class="table-responsive d-none d-md-block">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="cursor:pointer;" onclick="sortTable(0)">@DomainResources.Place <i class="bi bi-arrow-down-up small"></i></th>
                                    <th style="cursor:pointer;" onclick="sortTable(1)">@DomainResources.City <i class="bi bi-arrow-down-up small"></i></th>
                                    <th style="cursor:pointer;" onclick="sortTable(2)">@DomainResources.Rating <i class="bi bi-arrow-down-up small"></i></th>
                                    <th class="text-center">@DomainResources.Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Favorites != null && Model.Favorites.Any())
                                {
                                    @foreach (var favorite in Model.Favorites)
                                    {
                                        <tr class="favorite-item" data-place-id="@favorite.PlaceId">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @if (favorite.Place.PlaceImages != null && favorite.Place.PlaceImages.Any())
                                                    {
                                                        <img src="@favorite.Place.PlaceImages.First().ImageUrl" class="rounded me-2 shadow-sm" alt="img" style="width: 50px; height: 50px; object-fit: cover;">
                                                    }
                                                    <span class="fw-bold">@(isEnglish && !string.IsNullOrEmpty(favorite.Place.NameEn) ? favorite.Place.NameEn : favorite.Place.Name)</span>
                                                </div>
                                            </td>
                                            <td>@(isEnglish? favorite.Place.City?.NameEn : favorite.Place.City?.Name)</td>
                                            <td class="text-center"><span class="badge bg-success-subtle text-dark">⭐ @favorite.Place.Rating/5</span></td>
                                            <td class="text-center">
                                                <div class="btn-group">
                                                    <a asp-controller="Reservation" asp-action="Index" asp-route-id="@favorite.PlaceId" class="btn btn-sm btn-outline-success">@DomainResources.View</a>
                                                    <button type="button" class="btn btn-sm btn-outline-danger ms-1 remove-favorite" data-id="@favorite.PlaceId"><i class="bi bi-trash"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-md-none px-3 pt-2" id="mobileFavoritesList">
                        @if (Model.Favorites != null && Model.Favorites.Any())
                        {
                            @foreach (var favorite in Model.Favorites)
                            {
                                <div class="favorite-item mobile-card border rounded-3 p-3 mb-3 shadow-sm bg-white position-relative" data-place-id="@favorite.PlaceId">
                                    <button type="button" class="btn-remove-mobile remove-favorite" data-id="@favorite.PlaceId">
                                        <i class="bi bi-x-circle-fill"></i>
                                    </button>

                                    <div class="d-flex align-items-center mb-2">
                                        @if (favorite.Place.PlaceImages != null && favorite.Place.PlaceImages.Any())
                                        {
                                            <img src="@favorite.Place.PlaceImages.First().ImageUrl" class="rounded-3 me-3" style="width: 70px; height: 70px; object-fit: cover;">
                                        }
                                        <div class="flex-grow-1">
                                            <h6 class="mb-1 fw-bold text-dark pe-4">@(isEnglish && !string.IsNullOrEmpty(favorite.Place.NameEn) ? favorite.Place.NameEn : favorite.Place.Name)</h6>
                                            <div class="text-muted small"><i class="bi bi-geo-alt me-1"></i>@(isEnglish? favorite.Place.City?.NameEn : favorite.Place.City?.Name)</div>
                                            <div class="mt-1"><span class="text-warning">★</span> <span class="small fw-bold">@favorite.Place.Rating/5</span></div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <a asp-controller="Reservation" asp-action="Index" asp-route-id="@favorite.PlaceId" class="btn btn-success w-100 rounded-pill btn-sm">
                                            @DomainResources.View
                                        </a>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div id="noFavoritesMessage" class="text-center py-5 text-muted @(Model.Favorites != null && Model.Favorites.Any() ? "d-none" : "")">
                        <i class="bi bi-star fs-1 d-block mb-3 opacity-50"></i>
                        @DomainResources.NoFavoritesYet
                    </div>

                    <div class="pagination-container p-3 border-top @(Model.Favorites != null && Model.Favorites.Count() <= 5 ? "d-none" : "")">
                        <nav>
                            <ul class="pagination pagination-sm mb-0 justify-content-center" id="favoritesPagination"></ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="creditsInfoModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-gem text-info" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold mb-3">@DomainResources.ActProCredits</h4>
                <p class="text-muted">@DomainResources.CreditsInfo</p>
                <div class="row g-2 mt-4 text-start">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <h5 class="mb-0 fw-bold text-success">+1.0</h5>
                            <small class="text-muted">@DomainResources.CreditsPerReservation</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <h5 class="mb-0 fw-bold text-info">+0.1</h5>
                            <small class="text-muted">@DomainResources.CreditsPerComment</small>
                        </div>
                    </div>
                </div>
                <hr class="my-4">
                <h6 class="fw-bold mb-3">@DomainResources.LevelsAndPrivileges</h6>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-bronze me-2"></i>@DomainResources.Bronze</span>
                        <span class="badge bg-secondary rounded-pill">@DomainResources.Start</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-silver me-2"></i>@DomainResources.Silver</span>
                        <span class="badge bg-primary rounded-pill">@DomainResources.SilverDiscount</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-warning me-2"></i>@DomainResources.Gold</span>
                        <span class="badge bg-warning text-dark rounded-pill">@DomainResources.GoldDiscount</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button type="button" class="btn btn-primary px-5 rounded-pill" data-bs-dismiss="modal">@DomainResources.Understood</button>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}
@section Scripts
{  
    <partial name="_ValidationScriptsPartial" />
    <script>
         $(document).ready(function (){
             const rowsPerPage = 5;
             let currentPage = 1;
             function paginateTable() {
                const isMobile = window.innerWidth < 768;
                const selector = isMobile ? '#mobileFavoritesList .favorite-item' : '.table tbody tr.favorite-item';
                const allItems = $(selector);
                const totalItems = allItems.length;
                const totalPages = Math.ceil(totalItems / rowsPerPage);
                $('.favorite-item').hide();
                allItems.slice((currentPage - 1) * rowsPerPage, currentPage * rowsPerPage).show();
                const paginationHtml = $('#favoritesPagination');
                paginationHtml.empty();
                if (totalPages > 1) {
                    $('.pagination-container').removeClass('d-none');
                    for (let i = 1; i <= totalPages; i++) {
                        const li = $(`<li class="page-item ${i === currentPage ? 'active' : ''}">
                                        <a class="page-link" href="javascript:void(0);">${i}</a>
                                     </li>`);
                        li.click(function () {
                            currentPage = i;
                            paginateTable();
                        });
                        paginationHtml.append(li);
                    }
                } else {
                    $('.pagination-container').addClass('d-none');
                }
            }
             paginateTable();
             $(window).resize(paginateTable);
             $(document).on('click', '.remove-favorite', function (){
                 var btn = $(this);
                 var id = btn.data('id');
                 const elementsToRemove = $(`.favorite-item[data-place-id="${id}"]`);
                 $.post('/Account/ToggleFavorite', { placeId: id }, function (response)
                 {
                    if (response.success && !response.isFavorite) {
                    $.when(elementsToRemove.fadeOut(300)).done(function () {
                    elementsToRemove.remove();
                    if ($('.favorite-item').length === 0) {
                        $('#noFavoritesMessage').removeClass('d-none');
                        $('.pagination-container').addClass('d-none');
                    }
                        const remainingRows = $('.table tbody tr:not(.no-favorites-row)').length;
                        if (remainingRows > 0 && $('.table tbody tr:visible').length === 0)
                        {
                            currentPage = Math.max(1, currentPage - 1);
                        }
                        toastr.success(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(DomainResources.PlaceRemovedSuccessfully)));
                        paginateTable()
                        });
                    }
                 });
             });              
             const originalSortTable = window.sortTable;
             window.sortTable = function(n){
                 originalSortTable(n);
                 currentPage = 1;
                 paginateTable();
             };
         });
        function sortTable(n){
             var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
             table = document.querySelector(".table");
             switching = true;
             dir = "asc";

             while (switching){
                 switching = false;
                 rows = table.rows;

                 for (i = 1; i < (rows.length - 1); i++) {
                     shouldSwitch = false;
                     x = rows[i].getElementsByTagName("TD")[n];
                     y = rows[i + 1].getElementsByTagName("TD")[n];
                     var xContent = x.textContent.toLowerCase().trim();
                     var yContent = y.textContent.toLowerCase().trim();

                     if (n === 2) {
                         xContent = parseFloat(xContent.replace(/[^0-9.]/g, '')) || 0;
                         yContent = parseFloat(yContent.replace(/[^0-9.]/g, '')) || 0;
                     }

                     if (dir == "asc") {
                         if (xContent > yContent){
                             shouldSwitch = true;
                             break;
                         }
                     }
                     else if (dir == "desc"){
                         if (xContent < yContent){
                             shouldSwitch = true;
                             break;
                         }
                     }
                 }
                 if (shouldSwitch) {
                     rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                     switching = true;
                     switchcount++;
                 }
                 else {
                     if (switchcount == 0 && dir == "asc") {
                         dir = "desc";
                         switching = true;
                     }
                 }
             }
         }
    </script>
}