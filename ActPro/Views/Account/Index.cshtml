@model ActPro.DAL.ApplicationUser
@using System.Linq
@using ActPro.DAL.Entities
@{
    ViewData["Title"] = "Профил";
}
<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm text-center p-4 h-100">
                <div class="mb-3 position-relative d-inline-block">
                    <img id="profileImageDisplay"
                         src="@(string.IsNullOrEmpty(Model.ProfilePicturePath)
                                                                           ? "https://cdn-icons-png.flaticon.com/512/1144/1144760.png"
                                                                           : "/images/profiles/" + Model.ProfilePicturePath)"
                         class="rounded-circle img-thumbnail shadow-sm"
                         style="width: 150px; height: 150px; object-fit: cover;"
                         alt="Профилна снимка">
                </div>
                <h4 class="fw-bold">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted mb-1">@Model.Email</p>
                <p class="text-muted">@Model.PhoneNumber</p>
                <div>
                    <div class="d-block mt-2">
                        <button type="button" class="fw-bold text-info-emphasis px-3 py-2 border-0 shadow-sm"
                                data-bs-toggle="modal" data-bs-target="#creditsInfoModal">
                            <i class="bi bi-gem me-2"></i><strong>@Model.Credits</strong> ActPro Кредити
                        </button>
                    </div>
                </div>
                <hr class="my-4">
                <div class="d-grid gap-2 mt-auto pt-1">
                    <a asp-controller="Reservation" asp-action="MyReservations" class="btn btn-outline-success shadow-sm mb-2">
                        <i class="bi bi-calendar-check-fill me-2"></i>Моите резервации (@ViewBag.ResCount)
                    </a>
                    <a asp-controller="Reservation" asp-action="MyReviews" class="btn btn-outline-primary shadow-sm mb-2">
                        <i class="bi bi-chat-left-text me-2"></i>Моите отзиви (@ViewBag.RevCount)
                    </a>
                    <a asp-controller="Account" asp-action="Settings" class="btn btn-outline-dark shadow-sm mb-2">
                        <i class="bi bi-gear me-2"></i>Настройки
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h5 class="mb-0 fw-bold text-primary">
                        <i class="bi bi-star-fill me-2 text-warning"></i>Фаворити
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th style="cursor:pointer;" onclick="sortTable(0)">Обект <i class="bi bi-arrow-down-up small"></i></th>
                                    <th style="cursor:pointer;" onclick="sortTable(1)">Град <i class="bi bi-arrow-down-up small"></i></th>
                                    <th style="cursor:pointer;" onclick="sortTable(2)">Рейтинг <i class="bi bi-arrow-down-up small"></i></th>
                                    <th class="text-center">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Favorites != null && Model.Favorites.Any())
                                {
                                    @foreach (var favorite in Model.Favorites)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @if (favorite.Place.PlaceImages != null && favorite.Place.PlaceImages.Any())
                                                    {
                                                        <img src="@favorite.Place.PlaceImages.First().ImageUrl" class="rounded me-2" alt="img" style="width: 50px; height: 50px; object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                            <i class="bi bi-image text-muted"></i>
                                                        </div>
                                                    }
                                                    <span class="fw-bold text-dark">@favorite.Place.Name</span>
                                                </div>
                                            </td>
                                            <td>@favorite.Place.City?.Name</td>
                                            <td>
                                                <span class="badge bg-success-subtle text-dark">
                                                    ⭐ @favorite.Place.Rating.ToString()/5
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group">
                                                    <a asp-controller="Reservation" asp-action="Index" asp-route-id="@favorite.PlaceId" class="btn btn-sm btn-outline-primary">Виж</a>
                                                    <button type="button" class="btn btn-sm btn-outline-danger ms-1 remove-favorite" data-id="@favorite.PlaceId">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr class="no-favorites-row">
                                        <td colspan="4" class="text-center py-4 text-muted">
                                            <i class="bi bi-star me-2"></i>Все още нямате добавени любими обекти.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <div class="pagination-container">
                            <div class="d-flex justify-content-between align-items-center">
                                <nav>
                                    <ul class="pagination pagination-sm mb-0" id="favoritesPagination">
                                    </ul>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="creditsInfoModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-gem text-info" style="font-size: 3rem;"></i>
                </div>
                <h4 class="fw-bold mb-3">ActPro Кредити</h4>
                <p class="text-muted">Събирайте кредити чрез активност в платформата и отключвайте ексклузивни нива и отстъпки!</p>
                <div class="row g-2 mt-4 text-start">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <h5 class="mb-0 fw-bold text-success">+1.0</h5>
                            <small class="text-muted">за резервация</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <h5 class="mb-0 fw-bold text-info">+0.1</h5>
                            <small class="text-muted">за коментар</small>
                        </div>
                    </div>
                </div>
                <hr class="my-4">
                <h6 class="fw-bold mb-3">Нива и Привилегии</h6>
                <div class="list-group list-group-flush">
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-bronze me-2"></i>Бронз (0-99 кр.)</span>
                        <span class="badge bg-secondary rounded-pill">Начало</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-silver me-2"></i>Сребро (100-499 кр.)</span>
                        <span class="badge bg-primary rounded-pill">2% отстъпка</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                        <span><i class="bi bi-award text-warning me-2"></i>Злато (500+ кр.)</span>
                        <span class="badge bg-warning text-dark rounded-pill">5% отстъпка</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button type="button" class="btn btn-primary px-5 rounded-pill" data-bs-dismiss="modal">Разбрах!</button>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />
}
@section Scripts
{  
    <partial name="_ValidationScriptsPartial" />
    <script>
         $(document).ready(function ()
         {
             const rowsPerPage = 5;
             let currentPage = 1;
             function paginateTable()
             {
                 const rows = $('.table tbody tr:not(.no-favorites-row)');
                 const totalRows = rows.length;
                 const totalPages = Math.ceil(totalRows / rowsPerPage);
                 rows.hide();
                 rows.slice((currentPage - 1) * rowsPerPage, currentPage * rowsPerPage).show();
                 const paginationHtml = $('#favoritesPagination');
                 paginationHtml.empty();
                 if (totalPages > 1)
                 {
                     for (let i = 1; i <= totalPages; i++)
                     {
                         const li = $(`<li class="page-item ${i === currentPage ? 'active' : ''}">
                                         <a class="page-link" href="javascript:void(0);">${i}</a>
                                      </li>`);
                         li.click(function ()
                         {
                             currentPage = i;
                             paginateTable();
                         });
                         paginationHtml.append(li);
                     }
                 }
             }
             paginateTable();

             $(document).on('click', '.remove-favorite', function ()
             {
                 var btn = $(this);
                 var id = btn.data('id');
                 var row = btn.closest('tr');
                 $.post('/Account/ToggleFavorite', { placeId: id }, function (response)
                 {
                     if (response.success && !response.isFavorite)
                     {
                         row.fadeOut(300, function ()
                         {
                             $(this).remove();
                             const remainingRows = $('.table tbody tr:not(.no-favorites-row)').length;
                             if (remainingRows > 0 && $('.table tbody tr:visible').length === 0)
                             {
                                 currentPage = Math.max(1, currentPage - 1);
                             }
                             toastr.success("Обектът беше премахнат успешно!");
                             paginateTable()
                             paginateTable();
                         });
                     }
                 });
             });
             const originalSortTable = window.sortTable;
             window.sortTable = function(n)
             {
                 originalSortTable(n);
                 currentPage = 1;
                 paginateTable();
             };
         });
        function sortTable(n)
        {
             var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
             table = document.querySelector(".table");
             switching = true;
             dir = "asc";

             while (switching)
             {
                 switching = false;
                 rows = table.rows;

                 for (i = 1; i < (rows.length - 1); i++) {
                     shouldSwitch = false;
                     x = rows[i].getElementsByTagName("TD")[n];
                     y = rows[i + 1].getElementsByTagName("TD")[n];
                     var xContent = x.textContent.toLowerCase().trim();
                     var yContent = y.textContent.toLowerCase().trim();

                     if (n === 2)
                     {
                         xContent = parseFloat(xContent.replace(/[^0-9.]/g, '')) || 0;
                         yContent = parseFloat(yContent.replace(/[^0-9.]/g, '')) || 0;
                     }

                     if (dir == "asc")
                     {
                         if (xContent > yContent)
                         {
                             shouldSwitch = true;
                             break;
                         }
                     }
                     else if (dir == "desc")
                     {
                         if (xContent < yContent)
                         {
                             shouldSwitch = true;
                             break;
                         }
                     }
                 }
                 if (shouldSwitch)
                 {
                     rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                     switching = true;
                     switchcount++;
                 }
                 else
                 {
                     if (switchcount == 0 && dir == "asc")
                     {
                         dir = "desc";
                         switching = true;
                     }
                 }
             }
         }
    </script>
}