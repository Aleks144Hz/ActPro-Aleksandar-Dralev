@using ActPro.Domain.Models.Account
@model object
@{
    ViewData["Title"] = DomainResources.ForgotPassword;
    bool isReset = Model is ResetPasswordViewModel;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5 text-center">

                    @if (!isReset)
                    {
                        <i class="bi bi-envelope-at text-success display-1"></i>
                        <h3 class="fw-bold mt-3">@DomainResources.ForgotPassword</h3>
                        <p class="text-muted mb-4">@DomainResources.ForgotEnterEmail</p>

                        <form asp-action="ForgotPassword" method="post">
                            <div class="form-floating mb-3">
                                <input name="Email" type="email" class="form-control" required>
                                <label>@DomainResources.Email</label>
                            </div>
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">@DomainResources.ForgotSendLink</button>
                        </form>
                    }
                    else
                    {
                        var resetModel = (ResetPasswordViewModel)Model;
                        <i class="bi bi-shield-lock text-success display-1"></i>
                        <h3 class="fw-bold mt-3">@DomainResources.NewPassword</h3>
                        <p class="text-muted mb-4">@DomainResources.ForgotEnterNewPassword @resetModel.Email</p>
                        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                        <form asp-action="ResetPassword" method="post">
                            <input type="hidden" name="Email" value="@resetModel.Email" />
                            <input type="hidden" name="Token" value="@resetModel.Token" />

                            <div class="form-floating mb-2 text-start">
                                <input name="Password" class="form-control" type="password" />
                                <label>@DomainResources.NewPassword</label>
                                <span class="text-danger small">@Html.ValidationMessage("Password")</span>
                            </div>

                            <div class="form-floating mb-3 text-start">
                                <input name="ConfirmPassword" class="form-control" type="password" />
                                <label>@DomainResources.ConfirmPassword</label>
                                <span class="text-danger small">@Html.ValidationMessage("ConfirmPassword")</span>
                                <span class="text-danger small">@Html.ValidationMessage("resetModel.Password")</span>

                            </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm">@DomainResources.ForgotSavePassword</button>
                        </form>
                    }

                    <div class="mt-4">
                        <a asp-action="Login" class="text-success text-decoration-none">@DomainResources.ForgotBackToLogin</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}