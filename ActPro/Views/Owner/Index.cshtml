@using ActPro.Domain.Models.Owner
@model PlaceEntryViewModel
@{
    ViewData["Title"] = DomainResources.JoinActPro;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-success text-white p-4 border-0">
                    <h3 class="card-title fw-bold mb-0">
                        <i class="bi bi-briefcase me-2"></i> @DomainResources.JoinActPro
                    </h3>
                    <p class="mb-0 mt-2 opacity-75">@DomainResources.FillPlaceDetails</p>
                </div>

                <form asp-action="Index" method="post" enctype="multipart/form-data" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>                 
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.PlaceName</label>
                                <input asp-for="Name" class="form-control rounded-pill shadow-sm px-4"
                                       placeholder="@DomainResources.PlaceNamePlaceholder" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.ExactAddress</label>
                                <input asp-for="Address" class="form-control rounded-pill shadow-sm px-4"
                                       placeholder="@DomainResources.ExactAddressPlaceholder" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.PlaceType</label>
                                <select asp-for="IsOutdoor" class="form-select rounded-pill shadow-sm px-4">
                                    <option value="">@DomainResources.SelectType</option>
                                    <option value="true">@DomainResources.Outdoor</option>
                                    <option value="false">@DomainResources.Indoor</option>
                                </select>
                                <span asp-validation-for="IsOutdoor" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.City</label>
                                <select asp-for="CityId" class="form-select rounded-pill shadow-sm px-4"
                                        asp-items="ViewBag.Cities">
                                    <option value="">@DomainResources.SelectCity</option>
                                </select>
                                <span asp-validation-for="CityId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.ActivityType</label>
                                <select asp-for="ActivityId" class="form-select rounded-pill shadow-sm px-4"
                                        asp-items="ViewBag.ActivityTypes">
                                    <option value="">@DomainResources.SelectActivity</option>
                                </select>
                                <span asp-validation-for="ActivityId" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.PricePerHour</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0 rounded-start-pill text-success fw-bold">€</span>
                                    <input asp-for="Price" type="number" step="0.01"
                                           class="form-control border-start-0 rounded-end-pill shadow-sm px-3" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.CapacityLabel</label>
                                <input asp-for="Capacity" type="number" class="form-control rounded-pill shadow-sm px-4" />
                                <span asp-validation-for="Capacity" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label small fw-bold text-muted text-uppercase">@DomainResources.Description</label>
                                <textarea asp-for="Description" class="form-control shadow-sm px-4"
                                          rows="4" style="border-radius: 20px;"
                                          placeholder="@DomainResources.DescriptionPlaceholder"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                            <div class="col-md-12">
                                <div id="drop-zone" class="p-3 bg-light rounded-4 text-center position-relative transition-all"
                                     style="border: 2px dashed #dee2e6; cursor: pointer;">

                                    <i class="bi bi-cloud-arrow-up-fill fs-1 text-primary mb-3"></i>
                                    <h5 class="fw-bold">@DomainResources.DragDropImages</h5>
                                    <p class="text-muted small">@DomainResources.SupportedFormats</p>

                                    <input type="file" name="imageFiles" id="file-input"
                                           class="position-absolute opacity-0 w-100 h-100 top-0 start-0"
                                           style="cursor: pointer;" accept="image/*" multiple />

                                    <div id="preview-container" class="d-flex flex-wrap gap-3 justify-content-center mt-3"></div>
                                </div>
                            </div>                    
                        </div>
                    </div>
                    <div class="card-footer border-0 p-4 bg-light text-center">
                        <button type="submit" class="btn btn-success text-white rounded-pill px-5 py-3 fw-bold shadow-sm mb-2 mb-md-0">
                            <i class="bi bi-send me-2"></i> @DomainResources.SubmitForApproval
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
    #drop-zone
    {
        transition: all 0.3s ease;
    }

    #drop-zone.dragover
    {
        background-color: #e9ecef !important;
        border-color: #0d6efd !important;
        transform: scale(1.01);
    }

    .preview-img 
    {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>
<script>
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');
    const previewContainer = document.getElementById('preview-container');

    fileInput.addEventListener('dragenter', () => dropZone.classList.add('dragover'));
    fileInput.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    fileInput.addEventListener('drop', () => dropZone.classList.remove('dragover'));

    fileInput.addEventListener('change', function(){
        previewContainer.innerHTML = '';
        const files = this.files;

        if (files){
            Array.from(files).forEach(file => 
                {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.classList.add('preview-img');
                    previewContainer.appendChild(img);
                }
                reader.readAsDataURL(file);
            });
        }
    });
</script>