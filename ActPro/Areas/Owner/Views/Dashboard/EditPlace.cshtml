@using ActPro.Domain.Models.Areas
@model PlaceFormViewModel
<div class="modal fade" id="editPlaceModal-@Model.Id" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
            <div class="modal-header bg-info text-white p-3" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-pencil-square me-2" style="font-style: normal;"></i> Редактиране: @Model.Name
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Налични снимки:</label>
                    <div class="d-flex flex-wrap gap-3 mt-2">
                        @if (Model.ExistingImages.Any())
                        {
                            @foreach (var img in Model.ExistingImages)
                            {
                                <div class="position-relative border rounded p-1 shadow-sm bg-white overflow-visible">
                                    <img src="@img.Url" class="rounded" style="width: 100px; height: 100px; object-fit: cover;" />

                                    <button type="button"
                                            class="btn btn-danger btn-sm rounded-circle p-0 shadow position-absolute"
                                            style="width: 24px; height: 24px; border: 2px solid white; top: -10px; right: -10px; z-index: 10;"
                                            onclick="deleteImageAjax(this, @img.Id)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="w-100 p-2 bg-light rounded border-dashed text-center">
                                <span class="text-muted small">Няма снимки.</span>
                            </div>
                        }
                    </div>
                </div>
                <hr class="my-4 opacity-25" />
                <form asp-area="Owner" asp-controller="Places" asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="OwnerId" />
                    <input type="hidden" asp-for="Rating" />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Име на обекта</label>
                            <input asp-for="Name" class="form-control rounded-pill shadow-sm px-4 border-info-subtle" required />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small fw-bold text-muted text-uppercase">Точен адрес</label>
                            <input asp-for="Address" class="form-control rounded-pill shadow-sm px-4 border-info-subtle" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Тип база</label>
                            <select asp-for="IsOutdoor" class="form-select rounded-pill shadow-sm px-4 border-info-subtle" required>
                                <option value="true">Открито</option>
                                <option value="false">Закрито</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Град</label>
                            <select asp-for="CityId" class="form-select rounded-pill shadow-sm px-4 border-info-subtle"
                                    asp-items="Model.CityOptions" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Тип дейност</label>
                            <select asp-for="ActivityId" class="form-select rounded-pill shadow-sm px-4 border-info-subtle"
                                    asp-items="Model.ActivityOptions" required></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Цена (€/ч)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 rounded-start-pill text-info fw-bold">€</span>
                                <input asp-for="Price" type="number" step="0.01"
                                       class="form-control border-start-0 rounded-end-pill shadow-sm px-3 border-info-subtle" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Капацитет (лица)</label>
                            <input asp-for="Capacity" type="number" class="form-control rounded-pill shadow-sm px-4 border-info-subtle" required />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small fw-bold text-muted text-uppercase">Описание</label>
                            <textarea asp-for="Description" class="form-control shadow-sm px-4 border-info-subtle"
                                      rows="3" style="border-radius: 20px;"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div id="drop-zone" class="p-3 bg-light rounded-4 text-center position-relative transition-all"
                                 style="border: 2px dashed #dee2e6; cursor: pointer;">
                                <label class="form-label small fw-bold text-info d-block mb-2">
                                    <i class="bi bi-upload me-1"></i> ДОБАВИ НОВИ СНИМКИ
                                </label>
                                <h5 class="fw-bold">Плъзнете снимки тук или кликнете за избор</h5>
                                <p class="text-muted small">Поддържани формати: JPG, PNG (Максимум 5MB на файл)</p>

                                <input type="file" name="imageFiles" id="file-input"
                                       class="position-absolute opacity-0 w-100 h-100 top-0 start-0"
                                       style="cursor: pointer;" accept="image/*" multiple />

                                <div id="preview-container" class="d-flex flex-wrap gap-3 justify-content-center mt-3"></div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0 mt-4">
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 fw-bold shadow-sm">
                            <i class="bi bi-save me-1"></i> ЗАПАЗИ ПРОМЕНИТЕ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
    .modal
    {
        z-index: 1055;
    }

    .modal-backdrop 
    {
        z-index: 1050;
    }

    .modal-dialog 
    {
        margin-top: 100px;
    }

    .rounded-pill-custom 
    {
        border-radius: 50px !important;
    }

    .modal-title, .form-label 
    {
        font-style: normal !important;
        font-weight: 600;
    }

    #drop-zone 
    {
        transition: all 0.3s ease;
    }

    #drop-zone.dragover 
    {
        background-color: #e9ecef !important;
        border-color: #0d6efd !important;
        transform: scale(1.01);
    }

    .preview-img 
    {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>

<script>
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');
    const previewContainer = document.getElementById('preview-container');

    fileInput.addEventListener('dragenter', () => dropZone.classList.add('dragover'));
    fileInput.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    fileInput.addEventListener('drop', () => dropZone.classList.remove('dragover'));

    fileInput.addEventListener('change', function()
    {
        previewContainer.innerHTML = '';
        const files = this.files;

        if (files)
        {
            Array.from(files).forEach(file =>
                {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.classList.add('preview-img');
                    previewContainer.appendChild(img);
                }
                reader.readAsDataURL(file);
            });
        }
    });
</script>