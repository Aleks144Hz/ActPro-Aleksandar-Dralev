@using ActPro.Domain.Models.Areas
@model OwnerDashboardViewModel
@{
    ViewData["Title"] = "Бизнес Панел";
}
<div class="container-fluid mt-4">
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-header bg-white border-0 py-2">
                    <h6 class="fw-bold mb-0 text-primary"><i class="bi bi-building me-2"></i>Моите обекти</h6>
                </div>
                <div class="card-body pt-0 px-2" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var item in Model.MyPlaces)
                    {
                        <div class="place-item px-2 pb-1 pt-0 border-bottom mb-1">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold small" style="line-height: 1.2;">
                                    <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@item.Id"
                                       class="text-decoration-none text-dark hover-success">
                                        @item.Name
                                    </a>
                                </span>
                                <div class="btn-group gap-1">
                                    <button class="btn btn-outline-primary btn-sm border-0 p-1" title="Редактирай"
                                            data-bs-toggle="modal" data-bs-target="#editPlaceModal-@item.Id">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm border-0 p-1" title="График"
                                            data-bs-toggle="modal" data-bs-target="#manageScheduleModal-@item.Id">
                                        <i class="bi bi-calendar3"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="text-muted d-flex align-items-center" style="font-size: 0.8rem; margin-top: -3px;">
                                <span class="me-2">
                                    <i class="bi bi-geo-alt me-1"></i>@item.City?.Name
                                </span>
                                <span class="mx-1">|</span>
                                <span class="ms-2 text-truncate">
                                    <i class="fas fa-running me-1"></i>@item.Activity?.Name
                                </span>
                                <span class="mx-1">|</span>
                                <span class="ms-2 fw-bold text-success">
                                    <i class="bi bi-cash-stack me-1"></i>@item.Price €/час
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 text-white" style="background: linear-gradient(45deg, #1cc88a, #13855c);">
                        <div class="card-body py-3">
                            <h6 class="text-uppercase small opacity-75 mb-1">Общ приход</h6>
                            <h3 class="fw-bold mb-0">@Model.TotalIncome €</h3>
                            <i class="bi bi-currency-euro float-end fs-2 opacity-25" style="margin-top: -30px;"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 text-white" style="background: linear-gradient(45deg, #E88C31, #BD640D);">
                        <div class="col-body py-3 px-3">
                            <h6 class="text-uppercase small opacity-75 mb-1">Брой Резервации</h6>
                            <h3 class="fw-bold mb-0">@Model.TotalReservationsCount</h3>
                            <i class="bi bi-calendar-check float-end fs-2 opacity-25" style="margin-top: -30px;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <h4 class="fw-bold mb-3"><i class="bi bi-calendar-event me-2 text-primary"></i>Последни Резервации</h4>
            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-dark">
                            <tr>
                                <th>Обект</th>
                                <th>Клиент</th>
                                <th>Телефон</th>
                                <th>Дата и Час</th>
                                <th>Направена на</th>
                                <th class="text-center no-sort">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentReservations != null && Model.RecentReservations.Any())
                            {
                                @foreach (var res in Model.RecentReservations)
                                {
                                    <tr>
                                        <td data-label="ОБЕКТ">
                                            <div class="fw-bold">
                                                <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@res.PlaceId"
                                                   class="text-decoration-none text-dark hover-success">
                                                    @res.Place?.Name
                                                </a>
                                            </div>
                                        </td>
                                        <td data-label="КЛИЕНТ">@res.FirstName @res.LastName</td>
                                        <td data-label="ТЕЛЕФОН">@res.Phone</td>
                                        <td data-label ="ДАТА И ЧАС">
                                            @res.ReservationDate @res.ReservationTime
                                        </td>
                                        <td data-label="НАПРАВЕНА НА">
                                            <div class="fw-bold">@res.CreatedAt</div>
                                        </td>
                                        <td class="text-center" data-label="ДЕЙСТВИЯ">
                                            <div class="d-flex justify-content-center gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal" data-bs-target="#editTimeModal-@res.Id">
                                                    <i class="bi bi-clock"></i> Промяна
                                                </button>
                                                <form asp-area="Owner" asp-controller="Reservations" asp-action="Delete" asp-route-id="@res.Id" method="post">
                                                    <button type="submit" class="btn btn-sm btn-danger confirm-action"
                                                            data-message="Сигурни ли сте, че искате да анулирате тази резервация?">
                                                        <i class="bi bi-trash"></i> Анулирай
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@foreach (var item in Model.MyPlaces)
{
    if (Model.EditPlaces.ContainsKey(item.Id))
    {
        @await Html.PartialAsync("EditPlace", Model.EditPlaces[item.Id])
    }

    if (Model.PlaceSchedules.ContainsKey(item.Id))
    {
        @await Html.PartialAsync("ManageSchedule", Model.PlaceSchedules[item.Id])
    }
}
@if (Model.RecentReservations != null)
{
    @foreach (var res in Model.RecentReservations)
    {
        @await Html.PartialAsync("EditTime", new EditTimeViewModel
        {
            Id = res.Id,
            PlaceName = res.Place?.Name,
            CustomerName = $"{res.FirstName} {res.LastName}",
            ReservationTime = res.ReservationTime?.ToString("HH:mm") ?? ""
        })
    }
}
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}
@section Scripts 
{
    <script>
        $(document).ready(function () {
            $('.modal').on('shown.bs.modal', function () 
            {
                $(this).find('.select2-setup').select2({
                    theme: 'bootstrap-5',
                    dropdownParent: $(this),
                    width: '100%'
                });
            });
        });

        function deleteImageAjax(btn, imageId){
            var token = $('input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/Owner/Places/DeleteImage',
                type: 'POST',
                data: {
                    imageId: imageId,
                    __RequestVerificationToken: token
                },
                success: function () {
                    $(btn).closest('.position-relative').fadeOut(300, function()
                    {
                        $(this).remove();
                    });
                },
                error: function (xhr) {
                    console.error("Грешка:", xhr.status, xhr.responseText);
                    alert("Грешка " + xhr.status + ": Нямате достъп или сесията е изтекла.");
                }
            });
        }
    </script>
}