@model ActPro.Domain.Models.Areas.EditTimeViewModel

<div class="modal fade" id="editTimeModal-@Model.Id" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">

            <div class="modal-header border-0 p-4" style="background: linear-gradient(45deg, #0d6efd, #0099ff); color: white;">
                <h5 class="modal-title fw-bold d-flex align-items-center">
                    <i class="bi bi-clock-history me-2 fs-4"></i> @DomainResources.EditTime
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="EditTime" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4 bg-white">
                    <input type="hidden" asp-for="Id" />

                    <div class="bg-light p-3 rounded-4 mb-4 border border-info-subtle shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 45px; height: 45px;">
                                <i class="bi bi-geo-alt-fill text-white fs-5"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">@DomainResources.Place</div>
                                <div class="text-dark fw-bold" style="font-size: 1rem; line-height: 1.2;">@Model.PlaceName</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 45px; height: 45px;">
                                <i class="bi bi-person-fill text-white fs-5"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">@DomainResources.CustomerLabel</div>
                                <div class="text-dark fw-bold" style="font-size: 1rem; line-height: 1.2;">@Model.CustomerName</div>
                            </div>
                        </div>
                    </div>

                    <div class="px-2">
                        <label asp-for="ReservationTime" class="form-label d-block text-center small fw-bold text-muted text-uppercase mb-3">
                            @DomainResources.SelectNewTime
                        </label>

                        <div class="input-group input-group-lg shadow-sm rounded-pill border overflow-hidden">
                            <span class="input-group-text bg-white border-0 ps-4">
                                <i class="bi bi-alarm-fill text-primary"></i>
                            </span>
                            <input type="time" asp-for="ReservationTime"
                                   class="form-control border-0 py-3 fw-bold text-primary text-center pe-4"
                                   style="font-size: 1.4rem; letter-spacing: 1px;" required />
                        </div>

                        <div class="mt-3 text-center">
                            <div class="d-inline-flex align-items-center badge bg-warning-subtle text-dark border border-warning-subtle px-3 py-2 rounded-pill shadow-sm">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                <span class="fw-bold text-dark">@DomainResources.CurrentTime @Model.ReservationTime</span>
                            </div>
                        </div>

                        <div class="text-center">
                            <span asp-validation-for="ReservationTime" class="text-danger small mt-2 d-block"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold text-muted border shadow-sm" data-bs-dismiss="modal" style="min-width: 120px;">
                        @DomainResources.Cancel
                    </button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" style="min-width: 150px; background: linear-gradient(45deg, #0d6efd, #0099ff); border: none;">
                        <i class="bi bi-check2-circle me-1"></i> @DomainResources.Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>