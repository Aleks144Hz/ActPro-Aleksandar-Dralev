@using ActPro.Domain.Models.Areas
@model ActPro.Domain.Models.Areas.ReservationsIndexViewModel
@{
    ViewData["Title"] = DomainResources.AllReservations;
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-calendar-check"></i> @DomainResources.AllReservations</h2>
            </div>
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-dark">
                            <tr>
                                <th>@DomainResources.Place</th>
                                <th>@DomainResources.CustomerLabel</th>
                                <th>@DomainResources.PhoneNumber</th>
                                <th>@DomainResources.DateAndTime</th>
                                <th>@DomainResources.ReservationCreated</th>
                                <th class="text-center no-sort">@DomainResources.Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var res in Model.Reservations)
                            {
                                <tr>
                                    <td data-label="@DomainResources.Place.ToUpper()">
                                        <div class="fw-bold">
                                            <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@res.PlaceId"
                                               class="text-decoration-none text-dark hover-success">
                                                @res.PlaceName
                                            </a>
                                        </div>
                                    </td>
                                    <td data-label="@DomainResources.CustomerLabel.ToUpper()">@res.FirstName @res.LastName</td>
                                    <td data-label="@DomainResources.PhoneNumber.ToUpper()">@res.Phone</td>
                                    <td data-label="@DomainResources.DateAndTime.ToUpper()">
                                        @(res.ReservationDate.HasValue && res.ReservationTime.HasValue ? res.ReservationDate.Value.ToString("d.M.yyyy") + " г. " + res.ReservationTime.Value.ToString("H:mm") : "")
                                    </td>
                                    <td data-label ="@DomainResources.ReservationCreated.ToUpper()">
                                        <div class="fw-bold">@res.CreatedAt.ToString("d.M.yyyy") г. @res.CreatedAt.ToString("H:mm:ss")</div>
                                    </td>
                                    <td class="text-center" data-label="@DomainResources.Actions.ToUpper()">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="modal" data-bs-target="#editTimeModal-@res.Id">
                                                <i class="bi bi-clock"></i> @DomainResources.EditTimeHour
                                            </button>

                                            <form asp-action="Delete" asp-route-id="@res.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-danger confirm-action"
                                                        data-message="@DomainResources.ConfirmCancelReservation">
                                                    <i class="bi bi-trash"></i> @DomainResources.Cancellation
                                                </button>
                                            </form>
                                        </div>
                                        @await Html.PartialAsync("EditTime", new EditTimeViewModel
                                        {
                                            Id = res.Id,
                                            PlaceName = res.PlaceName,
                                            CustomerName = res.FullName,
                                            ReservationTime = res.ReservationTime?.ToString("HH:mm") ?? ""
                                        })
                                    </td>
                                </tr>
                            }
                            @if (!Model.Reservations.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">@DomainResources.NoReservationsFound</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}