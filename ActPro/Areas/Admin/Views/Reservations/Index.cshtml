@model IEnumerable<ActPro.DAL.Entities.Reservation>
@{
    ViewData["Title"] = "Всички Резервации";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-calendar-check"></i> Списък с всички резервации</h2>
            </div>
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-dark">
                            <tr>
                                <th>Обект</th>
                                <th>Клиент</th>
                                <th>Телефон</th>
                                <th>Дата и Час</th>
                                <th>Направена на</th>
                                <th class="text-center no-sort">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var res in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">
                                            <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@res.PlaceId"
                                               class="text-decoration-none text-dark hover-success">
                                                @res.Place?.Name
                                            </a>
                                        </div>
                                    </td>
                                    <td>@res.FirstName @res.LastName</td>
                                    <td>@res.Phone</td>
                                    <td>
                                        @res.ReservationDate @res.ReservationTime
                                    </td>
                                    <td>
                                        <div class="fw-bold">@res.CreatedAt</div>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="modal" data-bs-target="#editTimeModal-@res.Id">
                                                <i class="bi bi-clock"></i> Промяна
                                            </button>

                                            <form asp-action="Delete" asp-route-id="@res.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-danger confirm-action"
                                                        data-message="Сигурни ли сте, че искате да анулирате тази резервация?">
                                                    <i class="bi bi-trash"></i> Анулирай
                                                </button>
                                            </form>
                                        </div>
                                        @await Html.PartialAsync("EditTime", res)
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">Няма намерени резервации.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}