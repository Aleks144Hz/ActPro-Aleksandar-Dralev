@using Microsoft.AspNetCore.Identity
@using ActPro.DAL
@inject UserManager<ActPro.DAL.ApplicationUser> UserManager
@model IEnumerable<ActPro.DAL.ApplicationUser>
@{
    ViewData["Title"] = "Потребители";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-9">
            <h2><i class="bi bi-people"></i> Управление на потребители</h2>
            <div class="card shadow-sm">
                <table class="table table-hover align-middle mb-0 admin-table">
                    <thead class="table-dark">
                        <tr>
                            <th>Име</th>
                            <th>Имейл</th>
                            <th>Телефон</th>
                            <th>Роля</th>
                            <th class="text-center no-sort">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var isAdmin = await UserManager.IsInRoleAsync(user, "Admin");
                            <tr>
                                <td data-label="ИМЕ"> <div class="fw-bold">@user.FirstName @user.LastName</div></td>
                                <td data-label="ИМЕЙЛ"> <div class="fw-bold">@user.Email</div></td>
                                <td data-label="ТЕЛЕФОН"> <div class="fw-bold">@user.PhoneNumber</div></td>
                                <td data-label="ДЕЙСТВИЯ">
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    @if (await UserManager.IsInRoleAsync(user, "Owner"))
                                    {
                                        <span class="badge bg-warning text-dark">Owner</span>
                                    }
                                    @if (!isAdmin && !(await UserManager.IsInRoleAsync(user, "Owner")))
                                    {
                                        <span class="badge bg-secondary">User</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <form asp-action="ToggleAdmin" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm @(isAdmin ? "btn-outline-danger" : "btn-outline-success")">
                                                <i class="bi @(isAdmin ? "bi-person-dash" : "bi-person-check")"></i> Admin
                                            </button>
                                        </form>
                                        <form asp-action="ToggleOwner" method="post" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            @{
                                                var isOwner = await UserManager.IsInRoleAsync(user, "Owner");
                                            }
                                            <button type="submit" class="btn btn-sm @(isOwner ? "btn-outline-danger" : "btn-outline-primary")">
                                                <i class="bi bi-shop"></i> @(isOwner ? "Махни Owner" : "Направи Owner")
                                            </button>
                                        </form>
                                        <form asp-action="BanUser" asp-route-userId="@user.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger confirm-action"
                                                    data-message="ВНИМАНИЕ: Това ще добави имейла и телефона в черен списък и ще изтрие профила!">
                                                <i class="bi bi-shield-slash"></i> БАН
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}