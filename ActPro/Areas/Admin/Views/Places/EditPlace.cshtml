@model ActPro.DAL.Entities.Place

<div class="modal fade" id="editPlaceModal-@Model.Id" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
            <div class="modal-header bg-info text-white p-3" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-pencil-square me-2" style="font-style: normal;"></i> Редактиране: @Model.Name
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary small text-uppercase">Налични снимки:</label>
                    <div class="d-flex flex-wrap gap-3 mt-2">
                        @if (Model.PlaceImages != null && Model.PlaceImages.Any())
                        {
                            @foreach (var img in Model.PlaceImages)
                            {
                                <div class="position-relative border rounded p-1 shadow-sm bg-white overflow-visible">
                                    <img src="@img.ImageUrl" class="rounded" style="width: 100px; height: 100px; object-fit: cover;" />
                                    <form asp-action="DeleteImage" asp-route-imageId="@img.Id" method="post"
                                          class="position-absolute" style="top: -10px; right: -10px; z-index: 10;">
                                        <button type="submit" class="btn btn-danger btn-sm rounded-circle p-0 shadow"
                                                style="width: 24px; height: 24px; border: 2px solid white;">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="w-100 p-2 bg-light rounded border-dashed text-center">
                                <span class="text-muted small">Няма снимки.</span>
                            </div>
                        }
                    </div>
                </div>

                <hr class="my-4 opacity-25" />

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Rating" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Име на обекта</label>
                        <input asp-for="Name" class="form-control border-info-subtle shadow-sm" style="border-radius: 10px;" />
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Град</label>
                            <select asp-for="CityId" class="form-select border-info-subtle shadow-sm" style="border-radius: 10px;" asp-items="ViewBag.Cities"></select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Тип дейност</label>
                            <select asp-for="ActivityId" class="form-select border-info-subtle shadow-sm" style="border-radius: 10px;" asp-items="ViewBag.ActivityTypes"></select>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Цена (€/час)</label>
                            <div class="input-group rounded-pill border border-info-subtle shadow-sm overflow-hidden">
                                <span class="input-group-text bg-info bg-opacity-10 border-0 px-3 text-info fw-bold">€</span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control border-0 px-3" />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Капацитет</label>
                            <input asp-for="Capacity" type="number" class="form-control border-info-subtle shadow-sm" style="border-radius: 10px;" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание</label>
                        <textarea asp-for="Description" class="form-control border-info-subtle shadow-sm" style="border-radius: 10px;" rows="3"></textarea>
                    </div>

                    <div class="mb-4 p-3 bg-light rounded border border-info-subtle">
                        <label class="form-label fw-bold text-info"><i class="bi bi-upload"></i> Качи нови снимки:</label>
                        <input type="file" name="imageFiles" class="form-control border-0 bg-white" accept="image/*" multiple />
                    </div>

                    <div class="modal-footer border-0 px-0 pb-0">
                        <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" data-bs-dismiss="modal">Отказ</button>
                        <button type="submit" class="btn btn-info text-white px-5 rounded-pill shadow-sm fw-bold">
                            <i class="bi bi-save me-1"></i> Запази
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
    .modal 
    {
        z-index: 1055;
    }

    .modal-backdrop 
    {
        z-index: 1050;
    }

    .modal-dialog 
    {
        margin-top: 100px;
    }

    .rounded-pill-custom 
    {
        border-radius: 50px !important;
    }

    .modal-title, .form-label 
    {
        font-style: normal !important;
        font-weight: 600;
    }
</style>