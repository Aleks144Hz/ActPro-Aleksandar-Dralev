@using ActPro.Domain.Models.Areas
@model PlacesIndexViewModel
@{
    ViewData["Title"] = DomainResources.Places;
    var isEnglish = System.Threading.Thread.CurrentThread.CurrentUICulture.Name == "en";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-geo-alt"></i> @DomainResources.PlaceManagement</h2>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createPlaceModal">
                    <i class="bi bi-plus-circle"></i> @DomainResources.AddPlace
                </button>
            </div>
            <div class="card shadow-sm">
                <table class="table table-hover align-middle mb-0 admin-table">
                    <thead class="table-dark">
                        <tr>
                            <th>@DomainResources.Place</th>
                            <th>@DomainResources.City</th>
                            <th>@DomainResources.ActivityType</th>
                            <th>@DomainResources.Price</th>
                            <th>@DomainResources.Status</th>
                            <th class="text-center no-sort">@DomainResources.Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Places)
                        {
                            var placeName = isEnglish && !string.IsNullOrEmpty(item.NameEn) ? item.NameEn : item.Name;
                            var placeCity = isEnglish && !string.IsNullOrEmpty(item.CityNameEn) ? item.CityNameEn : item.CityName;
                            <tr>
                                <td data-label="@DomainResources.Place.ToUpper()">
                                    <strong>
                                        <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@item.Id"
                                           class="text-decoration-none text-dark hover-success">
                                            @placeName
                                        </a>
                                    </strong>
                                </td>
                                <td data-label="@DomainResources.City.ToUpper()">@placeCity</td>
                                <td data-label ="@DomainResources.ActivityType.ToUpper()">@item.ActivityName</td>
                                <td data-label="@DomainResources.Price.ToUpper()" data-sort="@item.Price">
                                    @item.Price @DomainResources.CurrencyEuro@DomainResources.PerHour
                                </td>
                                <td data-label="@DomainResources.Status.ToUpper()" class="text-center">
                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> @DomainResources.Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> @DomainResources.PendingApprovals</span>
                                    }
                                </td>
                                <td class="text-center" data-label="@DomainResources.Actions.ToUpper()">
                                    <div class="d-flex justify-content-center gap-2">

                                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#manageScheduleModal-@item.Id">
                                            <i class="bi bi-calendar-x"></i> @DomainResources.Schedule
                                        </button>
                                        <button type="button" class="btn btn-sm btn-info text-white"
                                                data-bs-toggle="modal" data-bs-target="#editPlaceModal-@item.Id">
                                            <i class="bi bi-pencil-square" style="font-style: normal;"></i>
                                            <span style="font-style: normal;">@DomainResources.Edit</span>
                                        </button>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        <button type="button" class="bi bi-trash btn btn-sm btn-danger confirm-action"
                                                data-message="@DomainResources.ConfirmDeletePlace @placeName?">
                                                @DomainResources.Delete
                                            </button>
                                        </form>
                                        @if (!item.IsApproved)
                                        {
                                            <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-lg"></i> @DomainResources.Approve
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@foreach (var item in Model.Places)
{
    @if (Model.EditPlaces.ContainsKey(item.Id))
    {
        @await Html.PartialAsync("EditPlace", Model.EditPlaces[item.Id])
    }

    @if (Model.PlaceSchedules.ContainsKey(item.Id))
    {
        @await Html.PartialAsync("ManageSchedule", Model.PlaceSchedules[item.Id])
    }
}

@await Html.PartialAsync("CreatePlace", new PlaceFormViewModel
{
    CityOptions = Model.CityOptions,
    ActivityOptions = Model.ActivityOptions
})
@section Styles
{ 
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<script>
    function deleteImageAjax(btn, imageId){
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        $.ajax({
            url: '/Admin/Places/DeleteImage',
            type: 'POST',
            data: { imageId: imageId },
            headers: {
                "RequestVerificationToken": token
            },
            success: function(){
                $(btn).closest('.position-relative').fadeOut(300, function()
                {
                    $(this).remove();
                });
            },
            error: function(xhr){
                console.error(xhr.responseText);
                alert("@DomainResources.ErrorProcessing: " + xhr.status);
            }
        });
    }
</script>