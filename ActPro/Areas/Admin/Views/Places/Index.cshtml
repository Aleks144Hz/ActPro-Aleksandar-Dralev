@model IEnumerable<ActPro.DAL.Entities.Place>
@{
    ViewData["Title"] = "Управление на обекти";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="bi bi-geo-alt"></i> Управление на обекти</h2>
                <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#createPlaceModal">
                    <i class="bi bi-plus-circle"></i> Добави нов обект
                </button>
            </div>
            <div class="card shadow-sm">
                <table class="table table-hover align-middle mb-0 admin-table">
                    <thead class="table-dark">
                        <tr>
                            <th>Обект</th>
                            <th>Град</th>
                            <th>Тип дейност</th>
                            <th>Цена</th>
                            <th>Статус</th>
                            <th class="text-center no-sort">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-label="ОБЕКТ">
                                    <strong>
                                        <a asp-area="" asp-controller="Reservation" asp-action="Index" asp-route-id="@item.Id"
                                           class="text-decoration-none text-dark hover-success">
                                            @item.Name
                                        </a>
                                    </strong>
                                </td>
                                <td data-label="ГРАД">@item.City?.Name</td>
                                <td data-label ="ТИП ДЕЙНОСТ">@item.Activity?.Name</td>
                                <td data-label="ЦЕНА" data-sort="@item.Price">
                                    @item.Price €/ч
                                </td>
                                <td data-label="СТАТУС">
                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Активен</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Чака одобрение</span>
                                    }
                                </td>
                                <td class="text-center" data-label="ДЕЙСТВИЯ">
                                    <div class="d-flex justify-content-center gap-2">

                                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#manageScheduleModal-@item.Id">
                                            <i class="bi bi-calendar-x"></i> График
                                        </button>
                                        <button type="button" class="btn btn-sm btn-info text-white"
                                                data-bs-toggle="modal" data-bs-target="#editPlaceModal-@item.Id">
                                            <i class="bi bi-pencil-square" style="font-style: normal;"></i>
                                            <span style="font-style: normal;">Редактирай</span>
                                        </button>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="button" class="bi bi-trash btn btn-sm btn-danger confirm-action"
                                                    data-message="Наистина ли искате да изтриете @item.Name?">
                                                Изтрий
                                            </button>
                                        </form>   
                                        @if (!item.IsApproved)
                                        {
                                            <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-lg"></i> Одобри
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@foreach (var item in Model)
{
    @await Html.PartialAsync("EditPlace", item)
    @await Html.PartialAsync("ManageSchedule", item)
}
@await Html.PartialAsync("CreatePlace", new ActPro.DAL.Entities.Place())

@section Styles
{ 
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}

<script>
    function deleteImageAjax(btn, imageId)
    {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        $.ajax({
            url: '/Admin/Places/DeleteImage',
            type: 'POST',
            data: { imageId: imageId },
            headers: {
                "RequestVerificationToken": token
            },
            success: function()
            {
                $(btn).closest('.position-relative').fadeOut(300, function()
                {
                    $(this).remove();
                });
            },
            error: function(xhr)
            {
                console.error(xhr.responseText);
                alert("Грешка при изтриването. Сървърът върна: " + xhr.status);
            }
        });
    }
</script>