@model ActPro.DAL.Entities.Place
@{
    ViewData["Title"] = "Редакция на обект";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Редактиране: @Model.Name</h4>
                </div>
                <div class="card-body">

                    <div class="mb-4">
                        <label class="form-label d-block">Текущи снимки:</label>
                        <div class="d-flex flex-wrap gap-2">
                            @if (Model.PlaceImages != null && Model.PlaceImages.Any())
                            {
                                @foreach (var img in Model.PlaceImages)
                                {
                                    <div class="position-relative border p-1 rounded">
                                        <img src="@img.ImageUrl" class="img-thumbnail" style="width: 120px; height: 120px; object-fit: cover;" />

                                        <form asp-action="DeleteImage" asp-route-imageId="@img.Id" method="post"
                                              class="position-absolute" style="top: -5px; right: -5px;">
                                            <button type="submit" class="btn btn-danger btn-sm rounded-circle p-0" style="width: 24px; height: 24px;">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Няма добавени снимки.</span>
                            }
                        </div>
                    </div>

                    <hr />

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />

                        <input type="hidden" asp-for="Rating" />

                        <div class="mb-3">
                            <label class="form-label">Име на обекта</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Град</label>
                                <select asp-for="CityId" class="form-select" asp-items="ViewBag.Cities"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Тип дейност</label>
                                <select asp-for="ActivityId" class="form-select" asp-items="ViewBag.ActivityTypes"></select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Цена</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Капацитет</label>
                                <input asp-for="Capacity" type="number" class="form-control" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="mb-4 p-3 bg-light rounded border">
                            <label class="form-label fw-bold">Добави нови снимки:</label>
                            <input type="file" name="imageFiles" class="form-control" accept="image/*" multiple />
                            <small class="text-muted">Можете да изберете няколко файла едновременно.</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
                            <button type="submit" class="btn btn-info text-white px-4 shadow-sm">
                                <i class="bi bi-save"></i> Запази промените
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}