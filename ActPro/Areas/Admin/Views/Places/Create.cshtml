@model ActPro.DAL.Entities.Place
@{
    ViewData["Title"] = "Нов Обект";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Добавяне на нов обект</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Име на обекта</label>
                            <input asp-for="Name" class="form-control" placeholder="Въведете име..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Град</label>
                                <select asp-for="CityId" class="form-select" asp-items="ViewBag.Cities">
                                    <option value="">-- Избери град --</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Тип дейност</label>
                                <select asp-for="ActivityId" class="form-select" asp-items="ViewBag.ActivityTypes">
                                    <option value="">-- Избери дейност --</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Цена</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Капацитет (брой места)</label>
                                <input asp-for="Capacity" type="number" class="form-control" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3 p-3 bg-light rounded border">
                            <label class="form-label fw-bold">Снимки на обекта</label>
                            <input type="file" name="imageFiles" class="form-control" accept="image/*" multiple />
                            <small class="text-muted">Можете да изберете няколко снимки наведнъж.</small>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                            <button type="submit" class="btn btn-success px-4 shadow-sm">Създай обекта</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}