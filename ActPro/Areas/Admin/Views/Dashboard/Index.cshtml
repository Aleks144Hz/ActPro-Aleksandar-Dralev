@model IEnumerable<ActPro.DAL.Entities.Reservation>
@{
    ViewData["Title"] = "Админ Панел";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="list-group">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
                   class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> Табло
                </a>
                <a asp-area="Admin" asp-controller="Reservations" asp-action="Index"
                   class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservations" ? "active" : "")">
                    <i class="bi bi-calendar-check"></i> Резервации
                </a>
                <a asp-area="Admin" asp-controller="Places" asp-action="Index"
                   class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"]?.ToString() == "Places" ? "active" : "")">
                    <i class="bi bi-geo-alt"></i> Обекти
                </a>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                   class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people"></i> Потребители
                </a>
                <a asp-area="Admin" asp-controller="AuditLogs" asp-action="Index"
                   class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["controller"]?.ToString() == "AuditLogs" ? "active" : "")">
                    <i class="bi bi-journal-text"></i> Логове
                </a>
            </div>
        </div>
        <div class="col-md-9">
            <div class="row g-3">
                <div class="col-lg-4 col-md-6">
                    <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" class="text-decoration-none">
                        <div class="card admin-card text-white shadow-sm h-100" style="background: linear-gradient(45deg, #4e73df, #224abe);">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="text-white-50 small text-uppercase mb-1">Общо Резервации</h6>
                                        <h3 class="fw-bold mb-0">@ViewBag.TotalReservations</h3>
                                    </div>
                                    <div class="icon-shape bg-white bg-opacity-25 rounded p-2">
                                        <i class="bi bi-calendar-check fs-3"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <a asp-area="Admin" asp-controller="Places" asp-action="Index" class="text-decoration-none">
                        <div class="card admin-card text-white shadow-sm h-100" style="background: linear-gradient(45deg, #1cc88a, #13855c);">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="text-white-50 small text-uppercase mb-1">Активни Обекти</h6>
                                        <h3 class="fw-bold mb-0">@ViewBag.TotalPlaces</h3>
                                    </div>
                                    <div class="icon-shape bg-white bg-opacity-25 rounded p-2">
                                        <i class="bi bi-geo-alt fs-3"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-lg-4 col-md-12">
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="text-decoration-none">
                        <div class="card admin-card text-white shadow-sm h-100" style="background: linear-gradient(45deg, #f6c23e, #dda20a);">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="text-white-50 small text-uppercase mb-1">Потребители</h6>
                                        <h3 class="fw-bold mb-0">@ViewBag.TotalUsers</h3>
                                    </div>
                                    <div class="icon-shape bg-white bg-opacity-25 rounded p-2">
                                        <i class="bi bi-people fs-3"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row mt-4">
    <div class="col-12">
        <div class="card chart-card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="chart-title fw-bold mb-0">
                        <i class="bi bi-bar-chart-line me-2 text-primary"></i>Активност на платформата
                    </h5>
                    <div class="btn-group chart-filter-group shadow-sm">
                        <button id="btn-week" class="btn btn-sm btn-primary active" onclick="updateChart('week')">Седмица</button>
                        <button id="btn-month" class="btn btn-sm btn-light border" onclick="updateChart('month')">Месец</button>
                        <button id="btn-year" class="btn btn-sm btn-light border" onclick="updateChart('year')">Година</button>
                    </div>
                </div>
                <div class="chart-container" style="position: relative; height: 400px; width: 100%;">
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}
@section Scripts 
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let activityChart;

        document.addEventListener("DOMContentLoaded", function () 
        {
            const ctx = document.getElementById('activityChart').getContext('2d');

            activityChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [
                        {
                            label: 'Резервации',
                            data: [],
                            borderColor: '#4e73df',
                            backgroundColor: '#4e73df',
                            fill: false,
                            tension: 0.4,
                            borderWidth: 3
                        },
                        {
                            label: 'Нови Потребители',
                            data: [],
                            borderColor: '#1cc88a',
                            backgroundColor: '#1cc88a',
                            fill: false,
                            tension: 0.4,
                            borderWidth: 3
                        },
                        {
                            label: 'Коментари',
                            data: [],
                            borderColor: '#f6c23e',
                            backgroundColor: '#f6c23e',
                            fill: false,
                            tension: 0.4,
                            borderWidth: 3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: {
                                usePointStyle: true,
                                pointStyle: 'circle',
                                padding: 20,
                                generateLabels: function(chart) 
                                {
                                    const data = chart.data;
                                    return data.datasets.map((dataset, i) => ({
                                        text: dataset.label,
                                        datasetIndex: i,
                                        fillStyle: chart.isDatasetVisible(i) ? dataset.borderColor : 'transparent',
                                        strokeStyle: dataset.borderColor,
                                        lineWidth: 2,
                                        pointStyle: 'circle',
                                        hidden: false,
                                        index: i
                                    }));
                                }
                            },
                            onClick: function(e, legendItem, legend) {
                                const index = legendItem.datasetIndex;
                                const ci = legend.chart;

                                if (ci.isDatasetVisible(index)) {
                                    ci.hide(index);
                                } else {
                                    ci.show(index);
                                }
                            }
                        },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f1f1f1' }, ticks: { stepSize: 1 } },
                        x: { grid: { display: false } }
                    }
                }
            });

            updateChart('week');
        });

        async function updateChart(period)
        {
           const buttons = document.querySelectorAll('.chart-filter-group button');
            buttons.forEach(btn => {
                btn.classList.remove('btn-primary', 'active');
                btn.classList.add('btn-light');
            });

            const activeBtn = document.getElementById(`btn-${period}`);

            if (activeBtn) 
            {
                activeBtn.classList.remove('btn-light');
                activeBtn.classList.add('btn-primary', 'active');
            }
            const response = await fetch(`/Admin/Dashboard/GetChartData?period=${period}`);
            const data = await response.json();
            activityChart.data.labels = data.labels;
            activityChart.data.datasets[0].data = data.reservations;
            activityChart.data.datasets[1].data = data.users;
            activityChart.data.datasets[2].data = data.comments;
            activityChart.update();
        }
    </script>
}