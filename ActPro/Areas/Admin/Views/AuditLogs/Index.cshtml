@using ActPro.Domain.Models.Areas
@model AuditLogsViewModel
@{
    ViewData["Title"] = DomainResources.AuditLogs;
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0"><i class="bi bi-journal-text me-2"></i>@DomainResources.AuditLogs</h2>
            </div>

            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-dark">
                            <tr>
                                <th>@DomainResources.CreatedAt</th>
                                <th>@DomainResources.User</th>
                                <th>@DomainResources.Action</th>
                                <th>@DomainResources.DescriptionLabel</th>
                                <th>IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.Logs.OrderByDescending(l => l.CreatedAt))
                            {
                                <tr>
                                    <td class="small" data-label="@DomainResources.CreatedAt.ToUpper()"><strong>@log.CreatedAt</strong></td>
                                    <td data-label ="@DomainResources.User.ToUpper()">
                                        <span class="fw-bold text-primary">@log.UserEmail</span>
                                    </td>
                                    <td data-label="@DomainResources.Action.ToUpper()">
                                        <span class="badge @GetBadgeClass(log.Action) shadow-sm" style="min-width: 100px;">
                                            @log.Action
                                        </span>
                                    </td>
                                    <td style="min-width: 250px; max-width: 400px; white-space: normal; word-wrap: break-word;" data-label="@DomainResources.DescriptionLabel.ToUpper()">
                                        <div style="font-size: 0.9rem; line-height: 1.2;">
                                            @log.Details
                                        </div>
                                    </td>
                                    <td data-label="IP"><small class="text-muted">@log.IpAddress</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@functions
{
    string GetBadgeClass(string action) => action switch
    {
        "Delete Place" or "Delete Review" or "Delete Reservation" or "Delete User" or "Ban User" or "Remove Closure" or "Cancel Reservation" or "Delete News" => "bg-danger",
        "Create Place" or "Add Review" or "Create Reservation" or "Add Closure" or "Create User" or "Create News" or "Approve Place" or "Manual Reservation" => "bg-success",
        "Edit Place" or "Update Settings" or "Edit User" or "Edit Reservation" => "bg-info text-dark",
        "User Login" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}