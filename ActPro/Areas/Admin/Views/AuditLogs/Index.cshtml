@model IEnumerable<ActPro.DAL.Entities.AuditLog>
@{
    ViewData["Title"] = "Логове";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminMenu")
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0"><i class="bi bi-journal-text me-2"></i>Дневник на събитията</h2>
            </div>

            <div class="card shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-dark">
                            <tr>
                                <th>Направено на</th>
                                <th>Потребител</th>
                                <th>Действие</th>
                                <th>Детайли</th>
                                <th>IP адрес</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.OrderByDescending(l => l.CreatedAt))
                            {
                                <tr>
                                    <td class="small" data-label="НАПРАВЕНО НА">@log.CreatedAt</td>
                                    <td data-label ="ПОТРЕБИТЕЛ">
                                        <span class="fw-bold text-primary">@log.UserEmail</span>
                                    </td>
                                    <td data-label="ДЕЙСТВИЕ">
                                        <span class="badge @GetBadgeClass(log.Action) shadow-sm" style="min-width: 100px;">
                                            @log.Action
                                        </span>
                                    </td>
                                    <td style="max-width: 300px;" class="text-truncate" title="@log.Details" data-label="ДЕТАЙЛИ">
                                        @log.Details
                                    </td>
                                    <td data-label="IP АДРЕС"><small class="text-muted">@log.IpAddress</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@functions
{
    string GetBadgeClass(string action) => action switch
    {
        "Delete Place" or "Delete Review" or "Delete Reservation" or "Delete User" or "Ban User" or "Remove Closure" or "Cancel Reservation" => "bg-danger",
        "Create Place" or "Add Review" or "Create Reservation" or "Add Closure" or "Create User" => "bg-success",
        "Edit Place" or "Update Settings" or "Edit User" or "Edit Reservation" => "bg-info text-dark",
        "User Login" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

@section Styles
{
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
}